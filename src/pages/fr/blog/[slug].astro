---
import BlogLayout from '../../../layouts/BlogLayout.astro';
import BlogCard from '../../../components/BlogCard.astro';
import {
  BLOG_CATEGORY_COLORS,
  BLOG_CATEGORY_LABELS,
  buildTocFromHeadings,
  findRelated,
  formatDateFr,
  slugFromEntry,
} from '../../../lib/blog';
import { getCollection, render } from 'astro:content';
import { APP_URL } from '../../../data/landingContent';

export async function getStaticPaths() {
  const entries = await getCollection('blog', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: slugFromEntry(entry) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const slug = slugFromEntry(entry);
const { Content, headings } = await render(entry);

const { data } = entry;
const colors = BLOG_CATEGORY_COLORS[data.category];
const toc = buildTocFromHeadings(headings);
const showToc = toc.length >= 3;

const canonicalPath = `/fr/blog/${slug}/`;
const alternates = [
  { hreflang: 'fr', href: `/fr/blog/${slug}/` },
  { hreflang: 'en', href: `/en/blog/${slug}/` },
  { hreflang: 'x-default', href: `/fr/blog/${slug}/` },
];

const all = await getCollection('blog', ({ data }) => !data.draft);
const related = findRelated(all, entry, 3);

const site = Astro.site ?? new URL('https://strivn.net');
const ogImageUrl = new URL(`/og-blog-${slug}.png`, site).toString();

const jsonLdExtra = [
  {
    '@type': 'BlogPosting',
    '@id': `https://strivn.net/fr/blog/${slug}/#article`,
    headline: data.title,
    description: data.description,
    datePublished: data.pubDate.toISOString(),
    ...(data.updatedDate ? { dateModified: data.updatedDate.toISOString() } : {}),
    inLanguage: 'fr',
    keywords: data.keywords.join(', '),
    mainEntityOfPage: {
      '@type': 'WebPage',
      '@id': `https://strivn.net/fr/blog/${slug}/`,
    },
    author: {
      '@type': 'Person',
      name: data.author,
    },
    publisher: {
      '@id': 'https://strivn.net/#organization',
    },
    image: ogImageUrl,
    articleSection: BLOG_CATEGORY_LABELS[data.category],
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://strivn.net/fr/' },
      { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://strivn.net/fr/blog/' },
      { '@type': 'ListItem', position: 3, name: BLOG_CATEGORY_LABELS[data.category], item: `https://strivn.net/fr/blog/categorie/${data.category}/` },
      { '@type': 'ListItem', position: 4, name: data.title, item: `https://strivn.net/fr/blog/${slug}/` },
    ],
  },
];
---

<BlogLayout
  locale="fr"
  title={`${data.title} | strivn blog`}
  description={data.description}
  canonicalPath={canonicalPath}
  jsonLdExtra={jsonLdExtra}
  bodyClass="b-article"
  ogImage={`/og-blog-${slug}.png`}
  switchHrefs={{ en: `/en/blog/${slug}/`, fr: `/fr/blog/${slug}/` }}
>
  <nav aria-label="Fil d'Ariane">
    <ol class="b-crumb">
      <li><a href="/fr/">Accueil</a></li>
      <li class="b-crumb__sep" aria-hidden="true">/</li>
      <li><a href="/fr/blog/">Blog</a></li>
      <li class="b-crumb__sep" aria-hidden="true">/</li>
      <li>
        <a href={`/fr/blog/categorie/${data.category}/`}>
          {BLOG_CATEGORY_LABELS[data.category]}
        </a>
      </li>
      <li class="b-crumb__sep" aria-hidden="true">/</li>
      <li class="b-crumb__here" aria-current="page">{data.title}</li>
    </ol>
  </nav>

  <header class="b-article__head">
    <div class="b-article__meta">
      <span
        class="b-article__cat"
        style={`background:${colors.bg};color:${colors.fg};border-color:${colors.border};`}
      >
        {BLOG_CATEGORY_LABELS[data.category]}
      </span>
      <span>
        <time datetime={data.pubDate.toISOString()}>{formatDateFr(data.pubDate)}</time>
      </span>
      <span aria-hidden="true">·</span>
      <span>{data.readingTime} min de lecture</span>
      {data.updatedDate && (
        <>
          <span aria-hidden="true">·</span>
          <span>Mis à jour le {formatDateFr(data.updatedDate)}</span>
        </>
      )}
    </div>
    <h1 class="b-article__title">{data.title}</h1>
    <p class="b-article__lede">{data.description}</p>
    <p class="b-article__byline">Par {data.author}</p>
  </header>

  {showToc && (
    <aside class="b-toc" aria-label="Sommaire de l'article">
      <span class="b-toc__label">Sommaire</span>
      <ol class="b-toc__list">
        {toc.map((h) => (
          <li class={h.depth === 3 ? 'b-toc__sub' : undefined}>
            <a href={`#${h.slug}`}>{h.text}</a>
          </li>
        ))}
      </ol>
    </aside>
  )}

  <div class="b-prose">
    <Content />
  </div>

  <section class="b-cta" aria-label="Mise en pratique">
    <p class="b-cta__text">
      <strong>Tu veux arrêter de tout noter à la main ?</strong>
      Convocations, présences, charge, séances : strivn rassemble ton intendance
      sur une seule page, partagée avec ton staff.
    </p>
    <a href={APP_URL} target="_blank" rel="noopener" class="b-cta__btn">
      Tester strivn gratuitement →
    </a>
  </section>

  {related.length > 0 && (
    <section class="b-related" aria-label="Articles similaires">
      <h2 class="b-related__title">Sur le même sujet</h2>
      <div class="b-related__grid">
        {related.map((r) => <BlogCard entry={r} compact />)}
      </div>
    </section>
  )}
</BlogLayout>
