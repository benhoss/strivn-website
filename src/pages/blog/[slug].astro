---
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('blog', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.md$/, '') },
  }));
}
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <title>Redirection…</title>
    <meta http-equiv="refresh" content={`0; url=/fr/blog/${Astro.params.slug}/`} />
    <link rel="canonical" href={`/fr/blog/${Astro.params.slug}/`} />
    <meta name="robots" content="noindex" />
  </head>
  <body>
    <p>Redirection vers <a href={`/fr/blog/${Astro.params.slug}/`}>/fr/blog/{Astro.params.slug}/</a></p>
  </body>
</html>
