---
import type { CollectionEntry } from 'astro:content';
import {
  BLOG_CATEGORY_COLORS,
  BLOG_CATEGORY_LABELS,
  formatDateFr,
  slugFromEntry,
} from '../lib/blog';

interface Props {
  entry: CollectionEntry<'blog'>;
  /** When true, render compact horizontal layout (used in "related" list). */
  compact?: boolean;
}

const { entry, compact = false } = Astro.props;
const slug = slugFromEntry(entry);
const { data } = entry;
const colors = BLOG_CATEGORY_COLORS[data.category];
---

<article class={`blog-card ${compact ? 'blog-card--compact' : ''}`}>
  <a href={`/fr/blog/${slug}/`} class="blog-card__link" aria-label={data.title}>
    <header class="blog-card__head">
      <span
        class="blog-card__cat"
        style={`background:${colors.bg};color:${colors.fg};border-color:${colors.border};`}
      >
        {BLOG_CATEGORY_LABELS[data.category]}
      </span>
      <span class="blog-card__date">
        <time datetime={data.pubDate.toISOString()}>{formatDateFr(data.pubDate)}</time>
      </span>
    </header>
    <h3 class="blog-card__title">{data.title}</h3>
    <p class="blog-card__excerpt">{data.description}</p>
    <footer class="blog-card__foot">
      <span class="blog-card__author">{data.author}</span>
      <span class="blog-card__sep" aria-hidden="true">·</span>
      <span class="blog-card__reading">{data.readingTime} min de lecture</span>
    </footer>
  </a>
</article>

<style>
  .blog-card {
    --radius: 12px;
    background: var(--surface, #0b1e3a);
    border: 1px solid var(--rule, rgba(248,250,252,0.08));
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color 220ms cubic-bezier(0.16,1,0.3,1),
                transform 220ms cubic-bezier(0.16,1,0.3,1);
  }
  .blog-card:hover {
    border-color: var(--rule-strong, rgba(248,250,252,0.18));
    transform: translateY(-2px);
  }
  .blog-card__link {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.25rem 1.25rem 1.1rem;
    color: inherit;
    text-decoration: none;
    height: 100%;
  }
  .blog-card__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .blog-card__cat {
    display: inline-block;
    padding: 0.18rem 0.55rem;
    border: 1px solid;
    border-radius: 999px;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .blog-card__date {
    color: var(--ink-3, #8497bd);
    font-size: 0.75rem;
  }
  .blog-card__title {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--ink, #f8fafc);
    letter-spacing: -0.01em;
  }
  .blog-card__excerpt {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--ink-2, #b5c2d7);
    /* clamp to ~3 lines */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .blog-card__foot {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: auto;
    padding-top: 0.5rem;
    border-top: 1px solid var(--rule, rgba(248,250,252,0.06));
    font-size: 0.75rem;
    color: var(--ink-3, #8497bd);
  }
  .blog-card__sep { opacity: 0.6; }
  .blog-card__author { color: var(--ink-2, #b5c2d7); }

  /* Compact variant (related articles list). */
  .blog-card--compact .blog-card__link { padding: 0.9rem 1rem; gap: 0.4rem; }
  .blog-card--compact .blog-card__title { font-size: 1rem; }
  .blog-card--compact .blog-card__excerpt { -webkit-line-clamp: 2; font-size: 0.8125rem; }
</style>
