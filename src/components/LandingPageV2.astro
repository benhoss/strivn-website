---
import BaseLayout from '../layouts/BaseLayout.astro';
import { landingContentV2, type Locale } from '../data/landingContentV2';
import '../styles/v2.css';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const c = landingContentV2[locale];
const isFrench = locale === 'fr';
const enPath = '/en/';
const frPath = '/fr/';
const canonical = locale === 'fr' ? '/' : enPath;
---

<BaseLayout
  lang={locale}
  title={c.meta.title}
  description={c.meta.description}
  canonicalPath={canonical}
  alternates={[
    { hreflang: 'en', href: enPath },
    { hreflang: 'fr', href: frPath },
    { hreflang: 'x-default', href: '/' },
  ]}
>
  <main class="bg-[#08080c] text-[#f4f4f5] antialiased selection:bg-[#C9A96E]/30 selection:text-[#f4f4f5]">
    {/* ================================================================
        NAV
        ================================================================ */}
    <nav class="fixed top-0 left-0 right-0 z-50 border-b border-white/[0.06] bg-[#08080c]/80 backdrop-blur-md">
      <div class="mx-auto flex max-w-[1280px] items-center justify-between px-6 py-4">
        <a href="#top" class="flex items-center gap-2.5">
          <img src="/strivn-logo.png" alt="STRIVN" class="h-7 w-auto opacity-90" loading="eager" />
          <span class="text-sm font-semibold tracking-wide text-[#f4f4f5]">STRIVN</span>
        </a>

        <div class="hidden items-center gap-8 md:flex">
          {c.nav.items.map((item) => (
            <a href={item.href} class="text-sm text-[#71717a] transition-colors hover:text-[#f4f4f5]">
              {item.label}
            </a>
          ))}
        </div>

        <div class="flex items-center gap-4">
          <div class="flex items-center gap-2 text-xs text-[#71717a]">
            <a href={enPath} class:list={['hover:text-[#f4f4f5] transition-colors', !isFrench && 'text-[#C9A96E]']}>EN</a>
            <span class="text-white/10">/</span>
            <a href={frPath} class:list={['hover:text-[#f4f4f5] transition-colors', isFrench && 'text-[#C9A96E]']}>FR</a>
          </div>
          <a
            href={c.hero.secondaryHref}
            class="hidden rounded-full border border-white/10 px-4 py-2 text-xs font-medium text-[#f4f4f5] transition-colors hover:border-[#C9A96E]/50 hover:text-[#C9A96E] sm:inline-block"
          >
            {c.hero.secondaryCta}
          </a>
        </div>
      </div>
    </nav>

    {/* ================================================================
        HERO
        ================================================================ */}
    <section id="top" class="relative overflow-hidden pt-32 pb-20 md:pt-40 md:pb-32">
      {/* Ambient glow */}
      <div class="pointer-events-none absolute inset-0" aria-hidden="true">
        <div class="absolute -top-40 left-1/4 h-[500px] w-[500px] rounded-full bg-[#C9A96E]/[0.03] blur-[120px]"></div>
        <div class="absolute top-20 right-1/4 h-[400px] w-[400px] rounded-full bg-[#C9A96E]/[0.02] blur-[100px]"></div>
      </div>

      <div class="relative mx-auto max-w-[1280px] px-6">
        <div class="grid gap-12 lg:grid-cols-2 lg:gap-16 lg:items-center">
          {/* Text */}
          <div class="max-w-xl">
            <p class="mb-6 text-xs font-medium uppercase tracking-[0.2em] text-[#C9A96E]">
              {c.hero.overline}
            </p>

            <h1 class="font-['Playfair_Display'] text-5xl font-semibold leading-[1.05] tracking-tight text-[#f4f4f5] md:text-6xl lg:text-[4.2rem]">
              {c.hero.title}
              <span class="block text-[#C9A96E]">{c.hero.titleAccent}</span>
            </h1>

            <p class="mt-6 text-base leading-relaxed text-[#a1a1aa] md:text-lg">
              {c.hero.body}
            </p>

            <div class="mt-8 flex flex-wrap items-center gap-4">
              <a
                href={c.hero.ctaHref}
                class="inline-flex items-center rounded-full bg-[#C9A96E] px-6 py-3 text-sm font-semibold text-[#08080c] transition-all hover:bg-[#b8985e] hover:shadow-lg hover:shadow-[#C9A96E]/10"
              >
                {c.hero.cta}
                <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </a>
              <a
                href={c.hero.secondaryHref}
                class="text-sm text-[#71717a] underline underline-offset-4 transition-colors hover:text-[#f4f4f5]"
              >
                {c.hero.secondaryCta}
              </a>
            </div>
          </div>

          {/* Dashboard preview */}
          <div class="relative">
            <div class="relative rounded-2xl border border-white/[0.08] bg-[#0f0f14] p-1 shadow-2xl shadow-black/50">
              <div class="rounded-xl bg-[#0a0a0f] p-5">
                {/* Mini header */}
                <div class="mb-4 flex items-center justify-between">
                  <div class="flex items-center gap-2">
                    <div class="h-2 w-2 rounded-full bg-[#C9A96E]"></div>
                    <span class="text-[10px] font-medium uppercase tracking-wider text-[#71717a]">app.strivn.ai</span>
                  </div>
                  <span class="text-[10px] text-[#52525b]">Semaine 20</span>
                </div>

                {/* Mini cards */}
                <div class="grid grid-cols-2 gap-3">
                  <div class="rounded-lg border border-white/[0.05] bg-white/[0.02] p-3">
                    <p class="text-[10px] uppercase tracking-wider text-[#71717a]">Présences</p>
                    <p class="mt-1 text-lg font-semibold text-[#f4f4f5]">14/18</p>
                    <div class="mt-1.5 h-1 w-full rounded-full bg-white/5">
                      <div class="h-1 rounded-full bg-[#C9A96E]" style="width: 78%"></div>
                    </div>
                  </div>
                  <div class="rounded-lg border border-white/[0.05] bg-white/[0.02] p-3">
                    <p class="text-[10px] uppercase tracking-wider text-[#71717a]">Bien-être</p>
                    <p class="mt-1 text-lg font-semibold text-[#f4f4f5]">7.8/10</p>
                    <p class="mt-1 text-[9px] text-[#52525b]">2 alertes · Mollet droit</p>
                  </div>
                  <div class="col-span-2 rounded-lg border border-white/[0.05] bg-white/[0.02] p-3">
                    <div class="flex items-center justify-between">
                      <div>
                        <p class="text-[10px] uppercase tracking-wider text-[#71717a]">Prochaine action</p>
                        <p class="mt-0.5 text-sm text-[#f4f4f5]">Convocation mardi 20h</p>
                      </div>
                      <span class="rounded-full bg-[#C9A96E]/10 px-2 py-0.5 text-[10px] font-medium text-[#C9A96E]">En attente</span>
                    </div>
                  </div>
                </div>

                {/* Mini roster */}
                <div class="mt-3 rounded-lg border border-white/[0.05] bg-white/[0.02] p-3">
                  <p class="mb-2 text-[10px] uppercase tracking-wider text-[#71717a]">Roster</p>
                  <div class="space-y-1.5">
                    {[
                      { name: 'M. Cordeiro', status: 'OK', color: 'bg-emerald-500/20 text-emerald-400' },
                      { name: 'T. Mendes', status: 'Risque', color: 'bg-amber-500/20 text-amber-400' },
                      { name: 'Y. Ribot', status: 'RSVP', color: 'bg-[#C9A96E]/10 text-[#C9A96E]' },
                      { name: 'A. Dupin', status: 'OK', color: 'bg-emerald-500/20 text-emerald-400' },
                    ].map((p) => (
                      <div class="flex items-center justify-between text-xs">
                        <span class="text-[#a1a1aa]">{p.name}</span>
                        <span class={`rounded px-1.5 py-0.5 text-[9px] font-medium ${p.color}`}>{p.status}</span>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>

            {/* Floating phone mock */}
            <div class="absolute -bottom-6 -left-6 hidden w-48 rounded-xl border border-white/[0.08] bg-[#0f0f14] p-3 shadow-xl shadow-black/40 lg:block">
              <div class="mb-2 flex items-center gap-1.5">
                <div class="h-5 w-5 rounded-full bg-[#C9A96E]/20 flex items-center justify-center text-[8px] font-bold text-[#C9A96E]">S</div>
                <div>
                  <p class="text-[9px] font-medium text-[#f4f4f5]">Strivn team</p>
                  <p class="text-[8px] text-[#52525b]">online</p>
                </div>
              </div>
              <div class="space-y-1.5">
                <div class="rounded-lg rounded-tl-none bg-white/5 p-1.5 text-[9px] text-[#a1a1aa]">
                  Entraînement mardi 20h. Tu viens ?
                </div>
                <div class="rounded-lg rounded-tr-none bg-[#C9A96E]/10 p-1.5 text-[9px] text-[#C9A96E]">
                  Oui, présent.
                </div>
                <div class="rounded-lg rounded-tl-none bg-white/5 p-1.5 text-[9px] text-[#a1a1aa]">
                  Comment tu te sens ?
                </div>
                <div class="rounded-lg rounded-tr-none bg-[#C9A96E]/10 p-1.5 text-[9px] text-[#C9A96E]">
                  Bien-être 8/10. Mollet droit un peu tendu.
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* ================================================================
        PAIN SECTION
        ================================================================ */}
    <section id="pain" class="relative py-24 md:py-32">
      <div class="mx-auto max-w-[1280px] px-6">
        <p class="mb-3 text-xs font-medium uppercase tracking-[0.2em] text-[#C9A96E]">{c.pain.eyebrow}</p>
        <h2 class="max-w-2xl font-['Playfair_Display'] text-3xl font-semibold leading-tight tracking-tight text-[#f4f4f5] md:text-4xl">
          {c.pain.title}
        </h2>

        <div class="mt-16 grid gap-6 md:grid-cols-3">
          {c.pain.cards.map((card, i) => (
            <div class:list={[
              'group rounded-2xl border border-white/[0.06] bg-white/[0.02] p-7 transition-all hover:border-[#C9A96E]/20 hover:bg-white/[0.03]',
              i === 1 && 'md:translate-y-4',
            ]}>
              <span class="font-['JetBrains_Mono'] text-xs text-[#52525b]">{card.num}</span>
              <h3 class="mt-4 text-lg font-semibold text-[#f4f4f5]">{card.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-[#71717a]">{card.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ================================================================
        LOOP SECTION
        ================================================================ */}
    <section id="loop" class="relative py-24 md:py-32">
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#C9A96E]/[0.015] to-transparent" aria-hidden="true"></div>
      <div class="relative mx-auto max-w-[1280px] px-6">
        <p class="mb-3 text-xs font-medium uppercase tracking-[0.2em] text-[#C9A96E]">{c.loop.eyebrow}</p>
        <h2 class="font-['Playfair_Display'] text-3xl font-semibold leading-tight tracking-tight text-[#f4f4f5] md:text-4xl">
          {c.loop.title}
        </h2>

        <div class="mt-16 grid gap-8 md:grid-cols-3">
          {c.loop.steps.map((step, i) => (
            <div class="relative">
              {/* Connector line */}
              {i < 2 && (
                <div class="absolute top-8 left-full hidden h-px w-8 bg-gradient-to-r from-[#C9A96E]/30 to-transparent md:block"></div>
              )}

              <div class="flex items-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-full border border-[#C9A96E]/20 bg-[#C9A96E]/5">
                  <span class="font-['JetBrains_Mono'] text-xs font-medium text-[#C9A96E]">{String(i + 1).padStart(2, '0')}</span>
                </div>
                <span class="text-xs font-medium uppercase tracking-wider text-[#52525b]">{step.phase}</span>
              </div>
              <h3 class="mt-5 text-lg font-semibold text-[#f4f4f5]">{step.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-[#71717a]">{step.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ================================================================
        PROOF SECTION
        ================================================================ */}
    <section class="relative py-24 md:py-32">
      <div class="mx-auto max-w-[1280px] px-6">
        <p class="mb-3 text-xs font-medium uppercase tracking-[0.2em] text-[#C9A96E]">{c.proof.eyebrow}</p>

        {/* Stats */}
        <div class="grid gap-8 sm:grid-cols-3">
          {c.proof.stats.map((stat) => (
            <div class="text-center">
              <p class="font-['Playfair_Display'] text-5xl font-semibold text-[#C9A96E] md:text-6xl">{stat.value}</p>
              <p class="mt-2 text-sm text-[#71717a]">{stat.label}</p>
            </div>
          ))}
        </div>

        {/* Quote */}
        <div class="mt-20 mx-auto max-w-2xl text-center">
          <svg class="mx-auto h-8 w-8 text-[#C9A96E]/20" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
          <p class="mt-6 font-['Playfair_Display'] text-xl italic leading-relaxed text-[#d4d4d8] md:text-2xl">
            {c.proof.quote.text}
          </p>
          <div class="mt-6">
            <p class="text-sm font-medium text-[#f4f4f5]">{c.proof.quote.author}</p>
            <p class="text-xs text-[#71717a]">{c.proof.quote.role}</p>
          </div>
        </div>
      </div>
    </section>

    {/* ================================================================
        ROLES SECTION
        ================================================================ */}
    <section id="roles" class="relative py-24 md:py-32">
      <div class="mx-auto max-w-[1280px] px-6">
        <p class="mb-3 text-xs font-medium uppercase tracking-[0.2em] text-[#C9A96E]">{c.roles.eyebrow}</p>
        <h2 class="font-['Playfair_Display'] text-3xl font-semibold leading-tight tracking-tight text-[#f4f4f5] md:text-4xl">
          {c.roles.title}
        </h2>

        <div class="mt-16 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {c.roles.cards.map((card, i) => (
            <div class:list={[
              'rounded-2xl border border-white/[0.06] bg-white/[0.02] p-6 transition-all hover:border-white/[0.1] hover:bg-white/[0.03]',
              i === 3 && 'sm:col-span-2 lg:col-span-1',
            ]}>
              <div class="mb-4 h-8 w-8 rounded-lg bg-[#C9A96E]/10 flex items-center justify-center">
                <span class="text-xs font-bold text-[#C9A96E]">{card.role[0]}</span>
              </div>
              <h3 class="text-sm font-semibold text-[#f4f4f5]">{card.role}</h3>
              <p class="mt-2 text-xs leading-relaxed text-[#71717a]">{card.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ================================================================
        CTA SECTION
        ================================================================ */}
    <section id="cta" class="relative py-24 md:py-32">
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#C9A96E]/[0.02] to-transparent" aria-hidden="true"></div>
      <div class="relative mx-auto max-w-[1280px] px-6 text-center">
        <h2 class="font-['Playfair_Display'] text-3xl font-semibold leading-tight tracking-tight text-[#f4f4f5] md:text-4xl">
          {c.cta.title}
        </h2>
        <p class="mx-auto mt-4 max-w-lg text-sm leading-relaxed text-[#71717a]">
          {c.cta.body}
        </p>
        <a
          href={c.cta.href}
          class="mt-8 inline-flex items-center rounded-full bg-[#C9A96E] px-8 py-3.5 text-sm font-semibold text-[#08080c] transition-all hover:bg-[#b8985e] hover:shadow-lg hover:shadow-[#C9A96E]/10"
        >
          {c.cta.button}
        </a>
      </div>
    </section>

    {/* ================================================================
        FOOTER
        ================================================================ */}
    <footer class="border-t border-white/[0.06] py-12">
      <div class="mx-auto flex max-w-[1280px] flex-col items-center justify-between gap-6 px-6 md:flex-row">
        <div class="text-center md:text-left">
          <p class="text-sm font-semibold text-[#f4f4f5]">{c.footer.brand}</p>
          <p class="mt-1 text-xs text-[#52525b]">{c.footer.tagline}</p>
        </div>

        <div class="flex items-center gap-6">
          {c.footer.links.map((link) => (
            <a href={link.href} class="text-xs text-[#71717a] transition-colors hover:text-[#f4f4f5]">
              {link.label}
            </a>
          ))}
        </div>

        <p class="text-xs text-[#52525b]">{c.footer.copyright}</p>
      </div>
    </footer>
  </main>
</BaseLayout>
