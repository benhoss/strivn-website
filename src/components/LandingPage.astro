---
import BaseLayout from '../layouts/BaseLayout.astro';
import { landingContent, type Locale } from '../data/landingContent';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const content = landingContent[locale];
const isFrench = locale === 'fr';
const enPath = '/en/';
const frPath = '/fr/';
const canonical = locale === 'fr' ? '/' : enPath;

const soonLabel = isFrench ? 'A venir' : 'Soon';

// Hero signals icons (Plan / Follow / Act) — Lucide-style stroke 2
const signalIcons = [
  // 0 — Plan (calendar)
  `<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>`,
  // 1 — Follow (trending-up)
  `<polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>`,
  // 2 — Act (check-square)
  `<polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>`,
];

// Icons mapped by index for Why cards (Lucide-style, stroke 2 marketing)
const whyIcons = [
  // 0 — Inputs (activity / signal)
  `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`,
  // 1 — Surfaces (layers)
  `<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>`,
  // 2 — Actions (zap)
  `<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>`,
  // 3 — Control (shield-check)
  `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/>`,
];

// Icons for Confidence points
const confidenceIcons = [
  // 0 — scoped target
  `<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>`,
  // 1 — proposal (send)
  `<line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>`,
  // 2 — evidence (eye)
  `<path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/>`,
  // 3 — channel (message-circle)
  `<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>`,
];

const planDayLabels = isFrench
  ? ['Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam', 'Dim']
  : ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];

const planRosterRows = isFrench
  ? [
      { name: 'M. Cordeiro', status: 'OK', tone: 'positive' },
      { name: 'T. Mendes', status: 'Risque', tone: 'warn' },
      { name: 'Y. Ribot', status: 'RSVP', tone: 'info' },
      { name: 'A. Dupin', status: 'OK', tone: 'positive' },
    ]
  : [
      { name: 'M. Cordeiro', status: 'OK', tone: 'positive' },
      { name: 'T. Mendes', status: 'Risk', tone: 'warn' },
      { name: 'Y. Ribot', status: 'RSVP', tone: 'info' },
      { name: 'A. Dupin', status: 'OK', tone: 'positive' },
    ];

const actMockText = isFrench
  ? {
      label: 'Action proposée',
      title: 'Envoyer la convocation pour mardi 20h ?',
      sub: 'Notification WhatsApp 24h avant la séance',
      metrics: [
        { label: 'Cible', value: '18 joueurs' },
        { label: 'Canal', value: 'WhatsApp' },
        { label: 'Timing', value: '24h avant' },
      ],
      approve: 'Envoyer',
      reject: 'Pas maintenant',
      badge: 'En attente',
    }
  : {
      label: 'Proposed action',
      title: 'Send the Tuesday 20:00 convocation?',
      sub: 'WhatsApp notification, 24 hours ahead',
      metrics: [
        { label: 'Reach', value: '18 players' },
        { label: 'Channel', value: 'WhatsApp' },
        { label: 'Timing', value: '24h ahead' },
      ],
      approve: 'Send',
      reject: 'Not yet',
      badge: 'Pending',
    };

const planMockText = isFrench
  ? { label: 'Semaine 20', stamp: '4 événements préparés', matchTag: 'MATCH', sessionTag: 'SÉANCE' }
  : { label: 'Week 20', stamp: '4 events drafted', matchTag: 'MATCH', sessionTag: 'SESSION' };

const rosterMockText = isFrench
  ? { label: 'Roster', live: 'En direct', counter: '14/18 presences' }
  : { label: 'Roster', live: 'Live', counter: '14/18 attendance' };

type WeekCell = { day: string; kind: 'empty' | 'training' | 'match'; time?: string; primary?: boolean };
const planWeek: WeekCell[] = [
  { day: planDayLabels[0], kind: 'empty' },
  { day: planDayLabels[1], kind: 'training', time: '20:00', primary: true },
  { day: planDayLabels[2], kind: 'empty' },
  { day: planDayLabels[3], kind: 'training', time: '20:00', primary: false },
  { day: planDayLabels[4], kind: 'training', time: '20:00', primary: false },
  { day: planDayLabels[5], kind: 'empty' },
  { day: planDayLabels[6], kind: 'match', time: '15:00', primary: false },
];
---

<BaseLayout
  lang={locale}
  title={content.meta.title}
  description={content.meta.description}
  canonicalPath={canonical}
  alternates={[
    { hreflang: 'en', href: enPath },
    { hreflang: 'fr', href: frPath },
    { hreflang: 'x-default', href: '/' },
  ]}
>
  <main id="top" class="landing-shell">
    <!-- ============================================================
         HERO
         ============================================================ -->
    <section class="hero">
      <div class="hero__atmosphere" aria-hidden="true"></div>
      <canvas class="hero__field" aria-hidden="true"></canvas>

      <div class="page-frame">
        <header class="topbar">
          <a href="#top" class="brand">
            <img src="/strivn-logo.png" alt="STRIVN" class="brand__logo" loading="eager" />
            <div class="brand__copy">
              <span class="brand__name">STRIVN</span>
              <span class="brand__tag">{content.header.brandTag}</span>
            </div>
          </a>

          <nav class="topbar__nav" aria-label={content.header.navLabel}>
            <a href="#why">{content.header.nav.why}</a>
            <a href="#how-it-works">{content.header.nav.howItWorks}</a>
            <a href="#for-whom">{content.header.nav.forWhom}</a>
            <a href="#confidence">{content.header.nav.confidence}</a>
            <a href="#faq">{content.header.nav.faq}</a>
          </nav>

          <div class="topbar__actions">
            <div class="lang-switch" aria-label="Language switcher">
              <a href={enPath} class:list={['lang-switch__link', !isFrench && 'is-active']}>
                {content.header.languages.en}
              </a>
              <a href={frPath} class:list={['lang-switch__link', isFrench && 'is-active']}>
                {content.header.languages.fr}
              </a>
            </div>
            <a href="#contact" class="button button--ghost">{content.header.cta}</a>
          </div>
        </header>

        <div class="hero__layout">
          <div class="hero__content">
            <div class="hero__eyebrow animate-rise" style="animation-delay: 90ms;">
              <span class="hero__eyebrow-dot" aria-hidden="true"></span>
              <span>{content.hero.eyebrowChips[0]}</span>
              <span class="hero__eyebrow-sep" aria-hidden="true"></span>
              <span>{content.hero.eyebrowChips[1]}</span>
            </div>

            <h1 class="hero__title animate-rise" style="animation-delay: 180ms;">
              {content.hero.title}
            </h1>

            <p class="hero__lede animate-rise" style="animation-delay: 280ms;">
              {content.hero.body}
            </p>

            <div class="hero__actions animate-rise" style="animation-delay: 380ms;">
              <a href="#contact" class="button button--primary">{content.hero.primaryCta}</a>
              <a href="#how-it-works" class="button button--ghost">{content.hero.secondaryCta}</a>
            </div>

            <div class="hero__signals animate-rise" style="animation-delay: 480ms;">
              {content.hero.signals.map((signal, index) => (
                <div class="signal">
                  <div class="signal__head">
                    <span class="signal__icon" aria-hidden="true">
                      <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        set:html={signalIcons[index] ?? ''}
                      />
                    </span>
                    <span class="signal__label">{signal.label}</span>
                  </div>
                  <ul class="signal__list">
                    {signal.features.map((feature) => (
                      <li class="signal__item">
                        <span class="signal__text">{feature.text}</span>
                        {feature.soon && <span class="signal__soon">{soonLabel}</span>}
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>

            <div class="hero__ai-strip animate-rise" style="animation-delay: 560ms;">
              <span class="ai-strip__badge">
                <span class="ai-strip__spark" aria-hidden="true">
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M12 3l1.6 4.8L18.4 9.4l-4.8 1.6L12 15.8l-1.6-4.8L5.6 9.4l4.8-1.6z"/>
                    <path d="M19 16l.7 1.9 1.9.7-1.9.7-.7 1.9-.7-1.9-1.9-.7 1.9-.7z"/>
                    <path d="M5 17.5l.5 1.4 1.4.5-1.4.5-.5 1.4-.5-1.4-1.4-.5 1.4-.5z"/>
                  </svg>
                </span>
                <span>{content.hero.aiStrip.badge}</span>
              </span>

              <span class="ai-strip__sep" aria-hidden="true"></span>

              <div class="ai-strip__assistants">
                <div class="ai-strip__assistant">
                  <strong class="ai-strip__assistant-label">{content.hero.aiStrip.coach.label}</strong>
                  <span class="ai-strip__assistant-body">{content.hero.aiStrip.coach.body}</span>
                </div>
                <span class="ai-strip__sep ai-strip__sep--inner" aria-hidden="true"></span>
                <div class="ai-strip__assistant">
                  <strong class="ai-strip__assistant-label">{content.hero.aiStrip.player.label}</strong>
                  <span class="ai-strip__assistant-body">{content.hero.aiStrip.player.body}</span>
                </div>
              </div>
            </div>
          </div>

          <aside class="app animate-rise" style="animation-delay: 240ms;" aria-label="STRIVN app preview">
            <!-- Browser-style chrome -->
            <div class="app__chrome">
              <div class="app__dots" aria-hidden="true">
                <span></span><span></span><span></span>
              </div>
              <div class="app__url">
                <span class="app__url-lock" aria-hidden="true"></span>
                <span>{content.hero.panel.urlLabel}</span>
              </div>
              <div class="app__avatar" aria-hidden="true"></div>
            </div>

            <div class="app__subchrome">
              <nav class="app__sections" aria-label="Sections">
                {content.hero.panel.sections.map((section) => (
                  <a
                    href="#"
                    class:list={['app__section-link', section === content.hero.panel.activeSection && 'is-active']}
                  >
                    {section}
                  </a>
                ))}
              </nav>
              <div class="app__context">
                <span class="app__context-dot" aria-hidden="true"></span>
                <span>{content.hero.panel.contextLine}</span>
              </div>
            </div>

            <div class="app__workspace" id="hero-flow">
              <div class="pane-viewport">
                <div class="pane-track">
                  <!-- Pane 01 — Voice dictation -->
                  <article class="pane is-active" data-step="1">
                    <div class="pane__head">
                      <span class="pane__index">01</span>
                      <span class="pane__label sub-animate" style="animation-delay: 220ms;">{content.hero.panel.stepVoiceLabel}</span>
                    </div>
                    <p class="step__quote pane__quote" data-typing data-typing-start="380" data-typing-speed="22">{content.hero.panel.stepVoiceQuote}</p>
                    <div
                      class="step__echo sub-animate"
                      style={`animation-delay: ${380 + content.hero.panel.stepVoiceQuote.length * 22 + 260}ms;`}
                    >{content.hero.panel.stepVoiceEcho}</div>
                  </article>

                  <!-- Pane 02 — Week state -->
                  <article class="pane" data-step="2">
                    <div class="pane__head">
                      <span class="pane__index">02</span>
                      <span class="pane__label sub-animate" style="animation-delay: 220ms;">{content.hero.panel.stepStateLabel}</span>
                    </div>
                    <div class="state-pills">
                      <span class="pill pill--info sub-animate" style="animation-delay: 360ms;">{content.hero.panel.stepStatePillAttendance}</span>
                      <span class="pill pill--info sub-animate" style="animation-delay: 480ms;">{content.hero.panel.stepStatePillRisk}</span>
                      <span class="pill sub-animate" style="animation-delay: 600ms;">{content.hero.panel.stepStatePillRsvp}</span>
                    </div>
                    <p class="step__explain sub-animate" style="animation-delay: 780ms;">{content.hero.panel.stepStateExplain}</p>
                    <ul class="insight-list">
                      {content.hero.panel.stepStateInsights.map((insight, i) => (
                        <li class="sub-animate" style={`animation-delay: ${980 + i * 110}ms;`}>{insight}</li>
                      ))}
                    </ul>
                  </article>

                  <!-- Pane 03 — Proposal -->
                  <article class="pane" data-step="3">
                    <div class="pane__head">
                      <div class="pane__head-left">
                        <span class="pane__index">03</span>
                        <span class="pane__label sub-animate" style="animation-delay: 220ms;">{content.hero.panel.stepProposalLabel}</span>
                      </div>
                      <span class="proposal__badge sub-animate" style="animation-delay: 480ms;">{content.hero.panel.stepProposalBadge}</span>
                    </div>
                    <h2 class="proposal-head__title sub-animate" style="animation-delay: 340ms;">{content.hero.panel.stepProposalTitle}</h2>
                    <div class="proposal__metrics">
                      {content.hero.panel.stepProposalMetrics.map((metric, i) => (
                        <div class="proposal__metric sub-animate" style={`animation-delay: ${620 + i * 110}ms;`}>
                          <span class="proposal__metric-label">{metric.label}</span>
                          <span class="proposal__metric-value">{metric.value}</span>
                        </div>
                      ))}
                    </div>
                    <div class="proposal__actions">
                      <button class="button button--small button--primary sub-animate" style="animation-delay: 1000ms;">{content.hero.panel.stepProposalApprove}</button>
                      <button class="button button--small button--ghost sub-animate" style="animation-delay: 1100ms;">{content.hero.panel.stepProposalReject}</button>
                    </div>
                  </article>

                  <!-- Pane 04 — Player WhatsApp frame -->
                  <article class="pane pane--player" data-step="4">
                    <div class="pane__head">
                      <span class="pane__index">04</span>
                      <span class="pane__label sub-animate" style="animation-delay: 220ms;">{content.hero.panel.player.label}</span>
                    </div>
                    <div class="phone sub-animate" style="animation-delay: 320ms;" aria-hidden="true">
                      <div class="phone__bar">
                        <span class="phone__time">{content.hero.panel.player.phoneTime}</span>
                        <span class="phone__dots">
                          <span></span><span></span><span></span>
                        </span>
                      </div>
                      <div class="phone__app">
                        <div class="phone__header">
                          <span class="phone__avatar">{content.hero.panel.player.phoneAvatar}</span>
                          <div class="phone__id">
                            <span class="phone__name">{content.hero.panel.player.phoneName}</span>
                            <span class="phone__sub">{content.hero.panel.player.phoneSub}</span>
                          </div>
                        </div>
                        <div class="phone__chat">
                          {content.hero.panel.player.bubbles.map((b, i) => (
                            <div
                              class:list={['bubble', `bubble--${b.direction}`, 'sub-animate']}
                              style={`animation-delay: ${560 + i * 500}ms;`}
                            >
                              <p>{b.text}</p>
                              <span class="bubble__time">
                                {b.time}
                                {b.direction === 'out' && (
                                  <svg class="bubble__check" width="11" height="8" viewBox="0 0 11 8" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                    <polyline points="0.6 4.4 3 6.8 7 1.2"/>
                                    <polyline points="3.6 4.4 6 6.8 10 1.2"/>
                                  </svg>
                                )}
                              </span>
                            </div>
                          ))}
                          <div
                            class="wellness-chip sub-animate"
                            style={`animation-delay: ${560 + 4 * 500 + 180}ms;`}
                          >
                            <span class="wellness-chip__label">{content.hero.panel.player.wellness.label}</span>
                            <span class="wellness-chip__value">{content.hero.panel.player.wellness.value}</span>
                            <span class="wellness-chip__note">{content.hero.panel.player.wellness.note}</span>
                          </div>
                        </div>
                      </div>
                    </div>
                  </article>
                </div>
              </div>

              <div class="pane-progress" aria-label="Hero animation progress">
                <button type="button" class="pane-dot is-active" data-pane="0" aria-label="Pane 1"></button>
                <button type="button" class="pane-dot" data-pane="1" aria-label="Pane 2"></button>
                <button type="button" class="pane-dot" data-pane="2" aria-label="Pane 3"></button>
                <button type="button" class="pane-dot" data-pane="3" aria-label="Pane 4"></button>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- ============================================================
         METRICS STRIP
         ============================================================ -->
    <section class="metrics" aria-label="Key metrics">
      <div class="page-frame">
        <ul class="metrics__row">
          {content.metrics.items.map((m, index) => (
            <li class="metric reveal" data-reveal-delay={index * 90}>
              <div class="metric__value">
                <span class="metric__number" data-count-target={m.value}>{m.value}</span>
                {m.unit && <span class="metric__unit">{m.unit}</span>}
              </div>
              <span class="metric__label">{m.label}</span>
              <p class="metric__body">{m.body}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ============================================================
         WHY STRIVN
         ============================================================ -->
    <section id="why" class="section">
      <div class="page-frame">
        <div class="section-intro reveal">
          <p class="eyebrow">{content.why.eyebrow}</p>
          <h2 class="section-title">{content.why.title}</h2>
          <p class="section-body">{content.why.body}</p>
        </div>

        <div class="why-grid">
          {content.why.items.map((item, index) => (
            <article class="why-card reveal" data-reveal-delay={index * 100}>
              <div class="why-card__icon" aria-hidden="true">
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  set:html={whyIcons[index] ?? ''}
                />
              </div>
              <span class="why-card__label">{item.label}</span>
              <h3 class="why-card__title">{item.title}</h3>
              <p class="why-card__body">{item.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ============================================================
         HOW IT WORKS
         ============================================================ -->
    <section id="how-it-works" class="section">
      <div class="page-frame">
        <div class="section-intro reveal">
          <p class="eyebrow">{content.howItWorks.eyebrow}</p>
          <h2 class="section-title">{content.howItWorks.title}</h2>
          <p class="section-body">{content.howItWorks.body}</p>
        </div>

        <div class="moments">
          {content.howItWorks.moments.map((moment, index) => (
            <article class:list={['moment', index % 2 === 1 && 'moment--reverse', 'reveal']}>
              <div class="moment__body">
                <div class="moment__head">
                  <span class="moment__index">{String(index + 1).padStart(2, '0')}</span>
                  <span class="moment__phase">{moment.phase}</span>
                </div>
                <h3 class="moment__title">{moment.title}</h3>
                <p class="moment__lede">{moment.body}</p>
                <ul class="moment__bullets">
                  {moment.bullets.map((bullet) => (
                    <li>{bullet}</li>
                  ))}
                </ul>
              </div>
              <div class="moment__viz" aria-hidden="true">
                {index === 0 && (
                  <div class="viz viz--week">
                    <div class="viz__head">
                      <span class="viz__label">{planMockText.label}</span>
                      <span class="viz__stamp">{planMockText.stamp}</span>
                    </div>
                    <div class="viz__week">
                      {planWeek.map((d) => (
                        <div class:list={['viz__day', d.kind !== 'empty' && 'is-active', d.primary && 'is-primary']}>
                          <span class="viz__day-label">{d.day}</span>
                          {d.kind === 'empty' && <span class="viz__block"></span>}
                          {d.kind === 'training' && d.primary && (
                            <span class="viz__block viz__block--active">
                              <span class="viz__block-tag">{planMockText.sessionTag}</span>
                              <span class="viz__block-time">{d.time}</span>
                            </span>
                          )}
                          {d.kind === 'training' && !d.primary && (
                            <span class="viz__block viz__block--secondary">
                              <span class="viz__block-tag">{planMockText.sessionTag}</span>
                              <span class="viz__block-time">{d.time}</span>
                            </span>
                          )}
                          {d.kind === 'match' && (
                            <span class="viz__block viz__block--match">
                              <span class="viz__block-tag">{planMockText.matchTag}</span>
                              <span class="viz__block-time">{d.time}</span>
                            </span>
                          )}
                        </div>
                      ))}
                    </div>
                  </div>
                )}
                {index === 1 && (
                  <div class="viz viz--roster">
                    <div class="viz__head">
                      <span class="viz__label">{rosterMockText.label}</span>
                      <span class="viz__stamp">{rosterMockText.counter}</span>
                    </div>
                    <div class="viz__roster">
                      {planRosterRows.map((row) => (
                        <div class="viz__row">
                          <span class="viz__avatar"></span>
                          <span class="viz__name">{row.name}</span>
                          <span class:list={['pill', `pill--${row.tone}`]}>{row.status}</span>
                        </div>
                      ))}
                    </div>
                  </div>
                )}
                {index === 2 && (
                  <div class="viz viz--action">
                    <div class="viz__head">
                      <span class="viz__label">{actMockText.label}</span>
                      <span class="viz__badge">{actMockText.badge}</span>
                    </div>
                    <p class="viz__title">{actMockText.title}</p>
                    <p class="viz__sub">{actMockText.sub}</p>
                    <div class="viz__metrics">
                      {actMockText.metrics.map((m) => (
                        <div class="viz__metric">
                          <span class="viz__metric-label">{m.label}</span>
                          <span class="viz__metric-value">{m.value}</span>
                        </div>
                      ))}
                    </div>
                    <div class="viz__cta">
                      <span class="viz__btn viz__btn--primary">{actMockText.approve}</span>
                      <span class="viz__btn">{actMockText.reject}</span>
                    </div>
                  </div>
                )}
              </div>
            </article>
          ))}
        </div>

        <div class="board reveal">
          <div class="board__head">
            <div>
              <p class="eyebrow">{content.howItWorks.board.eyebrow}</p>
              <h3 class="board__title">{content.howItWorks.board.title}</h3>
            </div>
            <span class="board__stamp">{content.howItWorks.board.stamp}</span>
          </div>
          <div class="board__grid">
            {content.howItWorks.board.items.map((item, index) => (
              <article class="board__item reveal" data-reveal-delay={index * 90}>
                <span class="board__item-label">{item.label}</span>
                <p class="board__item-body">{item.body}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         FOR WHOM
         ============================================================ -->
    <section id="for-whom" class="section">
      <div class="page-frame">
        <div class="section-intro reveal">
          <p class="eyebrow">{content.forWhom.eyebrow}</p>
          <h2 class="section-title">{content.forWhom.title}</h2>
          <p class="section-body">{content.forWhom.body}</p>
        </div>

        <div class="personas">
          {content.forWhom.cards.map((card, index) => (
            <article class="persona reveal" data-reveal-delay={index * 110}>
              <div class="persona__head">
                <span class="persona__role">{card.role}</span>
                <span class="persona__index">0{index + 1}</span>
              </div>
              <h3 class="persona__title">{card.title}</h3>
              <p class="persona__body">{card.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ============================================================
         CONFIDENCE & CONTROL
         ============================================================ -->
    <section id="confidence" class="section">
      <div class="page-frame">
        <div class="confidence-shell">
          <div class="section-intro section-intro--compact reveal">
            <p class="eyebrow">{content.confidence.eyebrow}</p>
            <h2 class="section-title">{content.confidence.title}</h2>
            <p class="section-body">{content.confidence.body}</p>
          </div>

          <ul class="confidence-list">
            {content.confidence.points.map((point, index) => (
              <li class="confidence-item reveal" data-reveal-delay={index * 110}>
                <span class="confidence-item__icon" aria-hidden="true">
                  <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    set:html={confidenceIcons[index] ?? ''}
                  />
                </span>
                <p>{point}</p>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- ============================================================
         FAQ
         ============================================================ -->
    <section id="faq" class="section">
      <div class="page-frame faq-shell">
        <div class="section-intro section-intro--compact reveal">
          <p class="eyebrow">{content.faq.eyebrow}</p>
          <h2 class="section-title">{content.faq.title}</h2>
          <p class="section-body">{content.faq.body}</p>
        </div>

        <div class="faq-list">
          {content.faq.items.map((item, index) => (
            <details class="faq-item reveal" data-reveal-delay={index * 80}>
              <summary>
                <span>{item.question}</span>
                <span class="faq-item__icon" aria-hidden="true"></span>
              </summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ============================================================
         CONTACT
         ============================================================ -->
    <section id="contact" class="section">
      <div class="page-frame">
        <div class="cta-band reveal">
          <div class="cta-band__lead">
            <p class="eyebrow">{content.contact.eyebrow}</p>
            <h2 class="cta-band__title">{content.contact.title}</h2>
          </div>

          <div class="cta-band__aside">
            <p>{content.contact.body}</p>
            <div class="cta-band__actions">
              <a href={content.contact.primaryHref} class="button button--primary">
                {content.contact.primaryCta}
              </a>
              <a href="#top" class="button button--ghost">{content.contact.secondaryCta}</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <footer class="footer-bar">
      <div class="page-frame footer-bar__inner">
        <div class="footer-bar__brand">
          <img src="/strivn-logo.png" alt="STRIVN" class="brand__logo" loading="lazy" />
          <p>{content.footer.brandLine}</p>
        </div>

        <div class="footer-bar__meta">
          <span class="footer-bar__label">{content.footer.contactLabel}</span>
          <a href={`mailto:${content.footer.email}`}>{content.footer.email}</a>
          <a href="#top">{content.footer.backToTop}</a>
        </div>
      </div>
    </footer>
  </main>
</BaseLayout>

<script>
  // ============================================================
  // Hero reactive dot field — cursor-following illumination
  // ============================================================
  (function () {
    const cv = document.querySelector<HTMLCanvasElement>('.hero__field');
    if (!cv) return;
    const hero = cv.closest<HTMLElement>('.hero');
    if (!hero) return;
    const ctx = cv.getContext('2d');
    if (!ctx) return;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const GRID = 26;
    const DOT_R = 1.05;
    const RADIUS = 200;
    const BASE_ALPHA = 0.055;
    const GLOW_ALPHA = 0.42;
    const BASE_RGB: [number, number, number] = [132, 151, 189];
    const GLOW_RGB: [number, number, number] = [78, 168, 252];

    let dpr = 1;
    let w = 0;
    let h = 0;
    let dots: Array<{ x: number; y: number }> = [];
    let raf = 0;
    let alive = false;
    const mouse = { x: -9999, y: -9999, tx: -9999, ty: -9999 };

    function resize() {
      const rect = hero!.getBoundingClientRect();
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      w = Math.max(1, Math.floor(rect.width));
      h = Math.max(1, Math.floor(rect.height));
      cv!.width = Math.floor(w * dpr);
      cv!.height = Math.floor(h * dpr);
      cv!.style.width = w + 'px';
      cv!.style.height = h + 'px';
      ctx!.setTransform(1, 0, 0, 1, 0, 0);
      ctx!.scale(dpr, dpr);
      layoutDots();
    }
    function layoutDots() {
      dots = [];
      const cols = Math.ceil(w / GRID) + 1;
      const rows = Math.ceil(h / GRID) + 1;
      const offX = (w - (cols - 1) * GRID) / 2;
      for (let i = 0; i < cols; i++) {
        for (let j = 0; j < rows; j++) {
          dots.push({ x: offX + i * GRID, y: j * GRID });
        }
      }
    }
    function frame() {
      ctx!.clearRect(0, 0, w, h);
      mouse.x += (mouse.tx - mouse.x) * 0.16;
      mouse.y += (mouse.ty - mouse.y) * 0.16;
      const cx = mouse.x;
      const cy = mouse.y;
      const r2 = RADIUS * RADIUS;
      for (let i = 0; i < dots.length; i++) {
        const d = dots[i];
        const dx = d.x - cx;
        const dy = d.y - cy;
        const d2 = dx * dx + dy * dy;
        let alpha = BASE_ALPHA;
        let r = BASE_RGB[0];
        let g = BASE_RGB[1];
        let b = BASE_RGB[2];
        if (d2 < r2) {
          const t = 1 - Math.sqrt(d2) / RADIUS;
          const k = t * t;
          alpha = BASE_ALPHA + (GLOW_ALPHA - BASE_ALPHA) * k;
          r = Math.round(BASE_RGB[0] + (GLOW_RGB[0] - BASE_RGB[0]) * k);
          g = Math.round(BASE_RGB[1] + (GLOW_RGB[1] - BASE_RGB[1]) * k);
          b = Math.round(BASE_RGB[2] + (GLOW_RGB[2] - BASE_RGB[2]) * k);
        }
        ctx!.fillStyle = 'rgba(' + r + ',' + g + ',' + b + ',' + alpha + ')';
        ctx!.beginPath();
        ctx!.arc(d.x, d.y, DOT_R, 0, Math.PI * 2);
        ctx!.fill();
      }
      raf = requestAnimationFrame(frame);
    }
    function staticFrame() {
      ctx!.clearRect(0, 0, w, h);
      ctx!.fillStyle = 'rgba(' + BASE_RGB.join(',') + ',' + BASE_ALPHA + ')';
      for (let i = 0; i < dots.length; i++) {
        const d = dots[i];
        ctx!.beginPath();
        ctx!.arc(d.x, d.y, DOT_R, 0, Math.PI * 2);
        ctx!.fill();
      }
    }
    function onMove(e: MouseEvent) {
      const rect = hero!.getBoundingClientRect();
      mouse.tx = e.clientX - rect.left;
      mouse.ty = e.clientY - rect.top;
      if (!alive) {
        mouse.x = mouse.tx;
        mouse.y = mouse.ty;
        alive = true;
      }
    }
    function start() {
      if (raf) cancelAnimationFrame(raf);
      raf = requestAnimationFrame(frame);
    }
    resize();
    if (reduced) {
      staticFrame();
      window.addEventListener('resize', () => {
        resize();
        staticFrame();
      });
      return;
    }
    const hasFinePointer = window.matchMedia('(pointer: fine)').matches;
    if (!hasFinePointer) {
      staticFrame();
      return;
    }
    window.addEventListener('mousemove', onMove, { passive: true });
    window.addEventListener('resize', resize);
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        cancelAnimationFrame(raf);
        raf = 0;
      } else if (!raf) {
        start();
      }
    });
    start();
  })();

  // ============================================================
  // Hero flow sequencer — sliding panes (left → right)
  // + sub-animations: typing dictation, cascading pills, metrics
  // ============================================================
  (function () {
    const flow = document.getElementById('hero-flow');
    if (!flow) return;
    const track = flow.querySelector<HTMLElement>('.pane-track');
    if (!track) return;
    const panes = Array.from(track.querySelectorAll<HTMLElement>('.pane'));
    const dots = Array.from(flow.querySelectorAll<HTMLButtonElement>('.pane-dot'));
    if (panes.length === 0) return;

    // Split typing targets into spans (unicode-aware) with cascading delays
    const typingTargets = flow.querySelectorAll<HTMLElement>('[data-typing]');
    typingTargets.forEach((el) => {
      if (el.dataset.typingPrepared) return;
      el.dataset.typingPrepared = '1';
      const text = el.textContent || '';
      const baseDelay = Number(el.dataset.typingStart || 380);
      const perChar = Number(el.dataset.typingSpeed || 18);
      el.textContent = '';
      const chars = Array.from(text);
      chars.forEach((c, i) => {
        if (c === ' ') {
          el.appendChild(document.createTextNode(' '));
        } else {
          const span = document.createElement('span');
          span.className = 'tchar';
          span.textContent = c;
          span.style.animationDelay = baseDelay + i * perChar + 'ms';
          el.appendChild(span);
        }
      });
    });

    const dwellMs = [3800, 3600, 4200, 7000];
    let current = 0;
    let timer = 0;

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function activate(idx: number) {
      // Slide the track
      track!.style.transform = 'translateX(-' + idx * 100 + '%)';
      // Update dots
      dots.forEach((d, i) => d.classList.toggle('is-active', i === idx));
      // Restart sub-animations on the active pane: remove on all → reflow → add on idx
      panes.forEach((p) => p.classList.remove('is-active'));
      void panes[idx].offsetWidth;
      panes[idx].classList.add('is-active');
    }

    function advance() {
      current = (current + 1) % panes.length;
      activate(current);
      timer = window.setTimeout(advance, dwellMs[current]);
    }

    // Click a dot to jump to that pane
    dots.forEach((dot, idx) => {
      dot.addEventListener('click', () => {
        window.clearTimeout(timer);
        current = idx;
        activate(current);
        if (!reduced) {
          timer = window.setTimeout(advance, dwellMs[current]);
        }
      });
    });

    if (reduced) {
      // Show pane 1 stationary; user can jump via dots
      panes[0].classList.add('is-active');
      return;
    }

    timer = window.setTimeout(advance, dwellMs[0]);
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        window.clearTimeout(timer);
      } else {
        timer = window.setTimeout(advance, 1200);
      }
    });
  })();

  // ============================================================
  // Scroll-triggered reveal — 220ms fade-rise per element on enter viewport
  // ============================================================
  (function () {
    const targets = document.querySelectorAll<HTMLElement>('.reveal');
    if (targets.length === 0) return;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) {
      targets.forEach((el) => el.classList.add('is-visible'));
      return;
    }
    if (typeof IntersectionObserver === 'undefined') {
      targets.forEach((el) => el.classList.add('is-visible'));
      return;
    }
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const delay = Number(el.dataset.revealDelay || 0);
            window.setTimeout(() => el.classList.add('is-visible'), delay);
            io.unobserve(el);
          }
        }
      },
      { rootMargin: '0px 0px -10% 0px', threshold: 0.12 }
    );
    targets.forEach((el) => io.observe(el));
  })();

  // ============================================================
  // Viz reveal — cascade content inside each viz when it enters viewport.
  // The viz itself fades in via .reveal; this triggers the internal cascade
  // (week cells appearing one-by-one, roster rows dropping in, action card
  // building itself). Threshold higher (0.25) so it triggers when the viz
  // is comfortably in view, not the moment its first pixel scrolls in.
  // ============================================================
  (function () {
    const vizs = document.querySelectorAll<HTMLElement>('.viz');
    if (vizs.length === 0) return;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced || typeof IntersectionObserver === 'undefined') {
      vizs.forEach((v) => v.classList.add('is-revealed'));
      return;
    }
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-revealed');
            io.unobserve(entry.target);
          }
        }
      },
      { rootMargin: '0px 0px -15% 0px', threshold: 0.25 }
    );
    vizs.forEach((v) => io.observe(v));
  })();

  // ============================================================
  // Metric count-up — numbers ease from 0 to their target when visible.
  // Stripe-style anchor effect. Skips zero values, respects reduced motion.
  // ============================================================
  (function () {
    const nums = document.querySelectorAll<HTMLElement>('.metric__number[data-count-target]');
    if (nums.length === 0) return;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced || typeof IntersectionObserver === 'undefined') return; // leave as-is

    function countUp(el: HTMLElement, target: number, duration = 1200) {
      if (target === 0) {
        el.textContent = '0';
        return;
      }
      const startTime = performance.now();
      function tick(now: number) {
        const t = Math.min(1, (now - startTime) / duration);
        const eased = 1 - Math.pow(1 - t, 3); // easeOutCubic
        el.textContent = String(Math.round(target * eased));
        if (t < 1) requestAnimationFrame(tick);
      }
      el.textContent = '0';
      requestAnimationFrame(tick);
    }

    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const target = Number(el.dataset.countTarget || '0');
            countUp(el, target);
            io.unobserve(el);
          }
        }
      },
      { threshold: 0.4 }
    );
    nums.forEach((n) => io.observe(n));
  })();
</script>
