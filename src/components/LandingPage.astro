---
import BaseLayout from '../layouts/BaseLayout.astro';
import { landingContent, type Locale } from '../data/landingContent';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const content = landingContent[locale];
const isFrench = locale === 'fr';
const enPath = '/en/';
const frPath = '/fr/';
const canonical = locale === 'fr' ? '/' : enPath;

const soonLabel = isFrench ? 'A venir' : 'Soon';

// Hero signals icons (Plan / Monitor / Act) — Lucide-style stroke 2
const signalIcons = [
  // 0 — Plan (calendar)
  `<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>`,
  // 1 — Monitor (trending-up)
  `<polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>`,
  // 2 — Act (check-square)
  `<polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>`,
];

// Confidence point icons
const confidenceIcons = [
  // 0 — scoped target
  `<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>`,
  // 1 — proposal (send)
  `<line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>`,
  // 2 — evidence (eye)
  `<path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/>`,
  // 3 — channel (message-circle)
  `<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>`,
];

// WhatsApp logo glyph (used in channel-side header + persona chip)
const whatsappGlyph = `<path d="M16.6 14.2c-.3-.1-1.6-.8-1.9-.9-.2-.1-.4-.1-.6.1-.2.2-.7.8-.8.9-.1.1-.3.2-.5 0-.3-.1-1.1-.4-2.1-1.3-.8-.7-1.3-1.5-1.5-1.8-.1-.3 0-.4.1-.6l.4-.4.2-.3c0-.1.1-.2 0-.4 0-.1-.5-1.4-.8-1.8-.2-.5-.4-.4-.5-.4h-.5c-.2 0-.4.1-.7.3-.2.2-.9.9-.9 2.2 0 1.3.9 2.6 1.1 2.7.1.2 1.9 2.9 4.6 4 2.2.9 2.7.7 3.2.7.5-.1 1.6-.6 1.8-1.3.2-.6.2-1.2.2-1.3-.1-.1-.2-.2-.5-.3zM12 3a9 9 0 0 0-7.6 13.8L3 21l4.4-1.2A9 9 0 1 0 12 3z"/>`;

// AI principle icons (Lucide-style, stroke 2, 18px)
const principleIcons = [
  // 0 — Learns your team (users — your specific squad)
  `<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
  // 1 — Less admin (audio waveform / voice)
  `<path d="M2 12h2"/><path d="M6 8v8"/><path d="M10 5v14"/><path d="M14 8v8"/><path d="M18 11v2"/><path d="M22 12h-2"/>`,
  // 2 — Squad in one read (graph / connected nodes)
  `<circle cx="6" cy="6" r="2"/><circle cx="18" cy="6" r="2"/><circle cx="6" cy="18" r="2"/><circle cx="18" cy="18" r="2"/><line x1="6" y1="8" x2="6" y2="16"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="8" y1="18" x2="16" y2="18"/><line x1="18" y1="8" x2="18" y2="16"/><line x1="8" y1="8" x2="16" y2="16"/>`,
  // 3 — Whole staff (layout-grid · four cells = four angles in one layout)
  `<rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/>`,
];

const planDayLabels = isFrench
  ? ['Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam', 'Dim']
  : ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];

const planMockText = isFrench
  ? { label: 'Semaine 20', stamp: '4 evenements prepares', matchTag: 'MATCH', sessionTag: 'SEANCE' }
  : { label: 'Week 20', stamp: '4 events drafted', matchTag: 'MATCH', sessionTag: 'SESSION' };

const rosterMockText = isFrench
  ? { label: 'Roster', live: 'En direct', counter: '14/18 presences' }
  : { label: 'Roster', live: 'Live', counter: '14/18 attendance' };

const actMockText = isFrench
  ? {
      label: 'Action proposee',
      title: 'Envoyer la convocation pour mardi 20h ?',
      sub: 'Diffusion WhatsApp 24h avant la seance',
      metrics: [
        { label: 'Cible', value: '18 joueurs' },
        { label: 'Canal', value: 'WhatsApp' },
        { label: 'Timing', value: '24h avant' },
      ],
      approve: 'Envoyer',
      reject: 'Pas maintenant',
      badge: 'En attente',
    }
  : {
      label: 'Proposed action',
      title: 'Send the Tuesday 20:00 convocation?',
      sub: 'WhatsApp dispatch, 24 hours ahead',
      metrics: [
        { label: 'Reach', value: '18 players' },
        { label: 'Channel', value: 'WhatsApp' },
        { label: 'Timing', value: '24h ahead' },
      ],
      approve: 'Send',
      reject: 'Not yet',
      badge: 'Pending',
    };

const rosterMomentRows = isFrench
  ? [
      { name: 'M. Cordeiro', status: 'OK', tone: 'positive' },
      { name: 'T. Mendes', status: 'Risque', tone: 'warn' },
      { name: 'Y. Ribot', status: 'RSVP', tone: 'info' },
      { name: 'A. Dupin', status: 'OK', tone: 'positive' },
    ]
  : [
      { name: 'M. Cordeiro', status: 'OK', tone: 'positive' },
      { name: 'T. Mendes', status: 'Risk', tone: 'warn' },
      { name: 'Y. Ribot', status: 'RSVP', tone: 'info' },
      { name: 'A. Dupin', status: 'OK', tone: 'positive' },
    ];

type WeekCell = { day: string; kind: 'empty' | 'training' | 'match'; time?: string; primary?: boolean };
const planWeek: WeekCell[] = [
  { day: planDayLabels[0], kind: 'empty' },
  { day: planDayLabels[1], kind: 'training', time: '20:00', primary: true },
  { day: planDayLabels[2], kind: 'empty' },
  { day: planDayLabels[3], kind: 'training', time: '20:00', primary: false },
  { day: planDayLabels[4], kind: 'training', time: '20:00', primary: false },
  { day: planDayLabels[5], kind: 'empty' },
  { day: planDayLabels[6], kind: 'match', time: '15:00', primary: false },
];
---

<BaseLayout
  lang={locale}
  title={content.meta.title}
  description={content.meta.description}
  canonicalPath={canonical}
  alternates={[
    { hreflang: 'en', href: enPath },
    { hreflang: 'fr', href: frPath },
    { hreflang: 'x-default', href: '/' },
  ]}
>
  <main id="top" class="landing-shell">
    <!-- ============================================================
         HERO — Platform-first
         ============================================================ -->
    <section class="hero">
      <div class="hero__atmosphere" aria-hidden="true"></div>
      <canvas class="hero__field" aria-hidden="true"></canvas>

      <div class="page-frame">
        <header class="topbar">
          <a href="#top" class="brand">
            <img src="/strivn-logo.png" alt="STRIVN" class="brand__logo" loading="eager" />
            <div class="brand__copy">
              <span class="brand__name">STRIVN</span>
              <span class="brand__tag">{content.header.brandTag}</span>
            </div>
          </a>

          <nav class="topbar__nav" aria-label={content.header.navLabel}>
            <a href="#platform">{content.header.nav.platform}</a>
            <a href="#how-it-works">{content.header.nav.loop}</a>
            <a href="#ai">{content.header.nav.ai}</a>
            <a href="#for-whom">{content.header.nav.forWhom}</a>
            <a href="#confidence">{content.header.nav.confidence}</a>
            <a href="#faq">{content.header.nav.faq}</a>
          </nav>

          <div class="topbar__actions">
            <div class="lang-switch" aria-label="Language switcher">
              <a href={enPath} class:list={['lang-switch__link', !isFrench && 'is-active']}>
                {content.header.languages.en}
              </a>
              <a href={frPath} class:list={['lang-switch__link', isFrench && 'is-active']}>
                {content.header.languages.fr}
              </a>
            </div>
            <a href="#contact" class="button button--ghost">{content.header.cta}</a>
          </div>
        </header>

        <div class="hero__layout">
          <div class="hero__content">
            <div class="hero__eyebrow animate-rise" style="animation-delay: 90ms;">
              <span class="hero__eyebrow-dot" aria-hidden="true"></span>
              <span>{content.hero.eyebrowChips[0]}</span>
              <span class="hero__eyebrow-sep" aria-hidden="true"></span>
              <span class="hero__eyebrow-wa" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="11" height="11" fill="currentColor" set:html={whatsappGlyph} />
              </span>
              <span>{content.hero.eyebrowChips[1]}</span>
            </div>

            <h1 class="hero__title animate-rise" style="animation-delay: 180ms;">
              {content.hero.title}
              <span class="hero__title-accent">{content.hero.titleAccent}</span>
            </h1>

            <p class="hero__lede animate-rise" style="animation-delay: 280ms;">
              {content.hero.body}
            </p>

            <div class="hero__actions animate-rise" style="animation-delay: 380ms;">
              <a href="#contact" class="button button--primary">{content.hero.primaryCta}</a>
              <a href="#how-it-works" class="button button--ghost">{content.hero.secondaryCta}</a>
            </div>

            <div class="hero__signals animate-rise" style="animation-delay: 480ms;">
              {content.hero.signals.map((signal, index) => (
                <div class="signal">
                  <div class="signal__head">
                    <span class="signal__icon" aria-hidden="true">
                      <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        set:html={signalIcons[index] ?? ''}
                      />
                    </span>
                    <span class="signal__label">{signal.label}</span>
                  </div>
                  <ul class="signal__list">
                    {signal.features.map((feature) => (
                      <li class="signal__item">
                        <span class="signal__text">{feature.text}</span>
                        {feature.soon && <span class="signal__soon">{soonLabel}</span>}
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>

            <div class="hero__ai-strip animate-rise" style="animation-delay: 560ms;">
              <span class="ai-strip__badge">
                <span class="ai-strip__spark" aria-hidden="true">
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M12 3l1.6 4.8L18.4 9.4l-4.8 1.6L12 15.8l-1.6-4.8L5.6 9.4l4.8-1.6z"/>
                    <path d="M19 16l.7 1.9 1.9.7-1.9.7-.7 1.9-.7-1.9-1.9-.7 1.9-.7z"/>
                    <path d="M5 17.5l.5 1.4 1.4.5-1.4.5-.5 1.4-.5-1.4-1.4-.5 1.4-.5z"/>
                  </svg>
                </span>
                <span>{content.hero.aiStrip.badge}</span>
              </span>

              <span class="ai-strip__sep" aria-hidden="true"></span>

              <div class="ai-strip__assistants">
                <div class="ai-strip__assistant">
                  <strong class="ai-strip__assistant-label">{content.hero.aiStrip.staff.label}</strong>
                  <span class="ai-strip__assistant-body">{content.hero.aiStrip.staff.body}</span>
                </div>
                <span class="ai-strip__sep ai-strip__sep--inner" aria-hidden="true"></span>
                <div class="ai-strip__assistant">
                  <strong class="ai-strip__assistant-label">{content.hero.aiStrip.team.label}</strong>
                  <span class="ai-strip__assistant-body">{content.hero.aiStrip.team.body}</span>
                </div>
              </div>
            </div>
          </div>

          <aside class="app animate-rise" style="animation-delay: 240ms;" aria-label="STRIVN platform preview">
            <!-- Browser-style chrome (the platform IS the staff surface) -->
            <div class="app__chrome">
              <div class="app__dots" aria-hidden="true">
                <span></span><span></span><span></span>
              </div>
              <div class="app__url">
                <span class="app__url-lock" aria-hidden="true"></span>
                <span>{content.hero.panel.urlLabel}</span>
              </div>
              <div class="app__avatar" aria-hidden="true"></div>
            </div>

            <div class="app__subchrome">
              <nav class="app__sections" aria-label="Sections">
                {content.hero.panel.sections.map((section) => (
                  <a
                    href="#"
                    class:list={['app__section-link', section === content.hero.panel.activeSection && 'is-active']}
                  >
                    {section}
                  </a>
                ))}
              </nav>
              <div class="app__context">
                <span class="app__context-dot" aria-hidden="true"></span>
                <span>{content.hero.panel.contextLine}</span>
              </div>
            </div>

            <div class="app__workspace" id="hero-flow">
              <div class="pane-viewport">
                <div class="pane-track">
                  <!-- Pane 01 — Voice dictation (in-platform) -->
                  <article class="pane is-active" data-step="1">
                    <div class="pane__head">
                      <span class="pane__index">01</span>
                      <span class="pane__label sub-animate" style="animation-delay: 220ms;">{content.hero.panel.stepVoiceLabel}</span>
                    </div>
                    <p class="step__quote pane__quote" data-typing data-typing-start="380" data-typing-speed="22">{content.hero.panel.stepVoiceQuote}</p>
                    <div
                      class="step__echo sub-animate"
                      style={`animation-delay: ${380 + content.hero.panel.stepVoiceQuote.length * 22 + 260}ms;`}
                    >{content.hero.panel.stepVoiceEcho}</div>
                  </article>

                  <!-- Pane 02 — Week state (platform read-out) -->
                  <article class="pane" data-step="2">
                    <div class="pane__head">
                      <span class="pane__index">02</span>
                      <span class="pane__label sub-animate" style="animation-delay: 220ms;">{content.hero.panel.stepStateLabel}</span>
                    </div>
                    <div class="state-pills">
                      <span class="pill pill--info sub-animate" style="animation-delay: 360ms;">{content.hero.panel.stepStatePillAttendance}</span>
                      <span class="pill pill--info sub-animate" style="animation-delay: 480ms;">{content.hero.panel.stepStatePillRisk}</span>
                      <span class="pill sub-animate" style="animation-delay: 600ms;">{content.hero.panel.stepStatePillRsvp}</span>
                    </div>
                    <p class="step__explain sub-animate" style="animation-delay: 780ms;">{content.hero.panel.stepStateExplain}</p>
                    <ul class="insight-list">
                      {content.hero.panel.stepStateInsights.map((insight, i) => (
                        <li class="sub-animate" style={`animation-delay: ${980 + i * 110}ms;`}>{insight}</li>
                      ))}
                    </ul>
                  </article>

                  <!-- Pane 03 — Proposal (platform action card) -->
                  <article class="pane" data-step="3">
                    <div class="pane__head">
                      <div class="pane__head-left">
                        <span class="pane__index">03</span>
                        <span class="pane__label sub-animate" style="animation-delay: 220ms;">{content.hero.panel.stepProposalLabel}</span>
                      </div>
                      <span class="proposal__badge sub-animate" style="animation-delay: 480ms;">{content.hero.panel.stepProposalBadge}</span>
                    </div>
                    <h2 class="proposal-head__title sub-animate" style="animation-delay: 340ms;">{content.hero.panel.stepProposalTitle}</h2>
                    <div class="proposal__metrics">
                      {content.hero.panel.stepProposalMetrics.map((metric, i) => (
                        <div class="proposal__metric sub-animate" style={`animation-delay: ${620 + i * 110}ms;`}>
                          <span class="proposal__metric-label">{metric.label}</span>
                          <span class="proposal__metric-value">{metric.value}</span>
                        </div>
                      ))}
                    </div>
                    <div class="proposal__actions">
                      <button class="button button--small button--primary sub-animate" style="animation-delay: 1000ms;">{content.hero.panel.stepProposalApprove}</button>
                      <button class="button button--small button--ghost sub-animate" style="animation-delay: 1100ms;">{content.hero.panel.stepProposalReject}</button>
                    </div>
                  </article>

                  <!-- Pane 04 — Player WhatsApp frame (team channel reveal) -->
                  <article class="pane pane--player" data-step="4">
                    <div class="pane__head">
                      <span class="pane__index">04</span>
                      <span class="pane__label sub-animate" style="animation-delay: 220ms;">{content.hero.panel.player.label}</span>
                    </div>
                    <div class="phone sub-animate" style="animation-delay: 320ms;" aria-hidden="true">
                      <div class="phone__bar">
                        <span class="phone__time">{content.hero.panel.player.phoneTime}</span>
                        <span class="phone__dots">
                          <span></span><span></span><span></span>
                        </span>
                      </div>
                      <div class="phone__app">
                        <div class="phone__header">
                          <span class="phone__avatar">{content.hero.panel.player.phoneAvatar}</span>
                          <div class="phone__id">
                            <span class="phone__name">{content.hero.panel.player.phoneName}</span>
                            <span class="phone__sub">{content.hero.panel.player.phoneSub}</span>
                          </div>
                          <span class="phone__wa" aria-hidden="true">
                            <svg viewBox="0 0 24 24" width="11" height="11" fill="currentColor" set:html={whatsappGlyph} />
                          </span>
                        </div>
                        <div class="phone__chat">
                          {content.hero.panel.player.bubbles.map((b, i) => (
                            <div
                              class:list={['bubble', `bubble--${b.direction}`, 'sub-animate']}
                              style={`animation-delay: ${560 + i * 500}ms;`}
                            >
                              <p>{b.text}</p>
                              <span class="bubble__time">
                                {b.time}
                                {b.direction === 'out' && (
                                  <svg class="bubble__check" width="11" height="8" viewBox="0 0 11 8" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                    <polyline points="0.6 4.4 3 6.8 7 1.2"/>
                                    <polyline points="3.6 4.4 6 6.8 10 1.2"/>
                                  </svg>
                                )}
                              </span>
                            </div>
                          ))}
                          <div
                            class="wellness-chip sub-animate"
                            style={`animation-delay: ${560 + 4 * 500 + 180}ms;`}
                          >
                            <span class="wellness-chip__label">{content.hero.panel.player.wellness.label}</span>
                            <span class="wellness-chip__value">{content.hero.panel.player.wellness.value}</span>
                            <span class="wellness-chip__note">{content.hero.panel.player.wellness.note}</span>
                          </div>
                        </div>
                      </div>
                    </div>
                  </article>
                </div>
              </div>

              <div class="pane-progress" aria-label="Hero animation progress">
                <button type="button" class="pane-dot is-active" data-pane="0" aria-label="Pane 1"></button>
                <button type="button" class="pane-dot" data-pane="1" aria-label="Pane 2"></button>
                <button type="button" class="pane-dot" data-pane="2" aria-label="Pane 3"></button>
                <button type="button" class="pane-dot" data-pane="3" aria-label="Pane 4"></button>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- ============================================================
         AI INSIDE — principles + evidence trace
         ============================================================ -->
    <section id="ai" class="section section--ai" aria-label="AI inside">
      <div class="page-frame">
        <div class="section-intro reveal">
          <p class="eyebrow">{content.ai.eyebrow}</p>
          <h2 class="section-title">{content.ai.title}</h2>
          <p class="section-body">{content.ai.body}</p>
        </div>

        <div class="ai-grid">
          <!-- Left column: 4 numbered principles -->
          <ol class="ai-principles" aria-label="Principles">
            {content.ai.principles.map((principle, i) => (
              <li class="ai-principle reveal" data-reveal-delay={i * 80}>
                <span class="ai-principle__index">{String(i + 1).padStart(2, '0')}</span>
                <span class="ai-principle__icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={principleIcons[i] ?? ''} />
                </span>
                <div class="ai-principle__copy">
                  <span class="ai-principle__label">{principle.label}</span>
                  <span class="ai-principle__verb">{principle.verb}</span>
                  <p class="ai-principle__body">{principle.body}</p>
                </div>
              </li>
            ))}
          </ol>

          <!-- Right column: evidence trace card -->
          <aside class="ai-trace reveal" data-reveal-delay={120}>
            <header class="ai-trace__head">
              <p class="eyebrow eyebrow--accent">{content.ai.trace.eyebrow}</p>
              <span class="ai-trace__badge">{content.ai.trace.badge}</span>
            </header>
            <h3 class="ai-trace__title">{content.ai.trace.title}</h3>

            <div class="ai-trace__block">
              <span class="ai-trace__block-label">{content.ai.trace.evidenceLabel}</span>
              <ul class="ai-trace__evidence">
                {content.ai.trace.evidence.map((line) => (
                  <li>
                    <span class="ai-trace__bullet" aria-hidden="true"></span>
                    <span>{line}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="ai-trace__block ai-trace__block--row">
              <span class="ai-trace__block-label">{content.ai.trace.confidenceLabel}</span>
              <div class="ai-trace__confidence">
                <div class="ai-trace__bars" role="img" aria-label={`${content.ai.trace.confidenceLevel} · ${content.ai.trace.confidenceSegments} of ${content.ai.trace.confidenceTotal}`}>
                  {Array.from({ length: content.ai.trace.confidenceTotal }).map((_, i) => (
                    <span class:list={['ai-trace__bar', i < content.ai.trace.confidenceSegments && 'is-filled']}></span>
                  ))}
                </div>
                <span class="ai-trace__confidence-label">{content.ai.trace.confidenceLevel}</span>
              </div>
            </div>

            <footer class="ai-trace__actions">
              <span class="button button--small button--primary ai-trace__btn">{content.ai.trace.approve}</span>
              <span class="button button--small button--ghost ai-trace__btn">{content.ai.trace.adjust}</span>
            </footer>

            <p class="ai-trace__caption">{content.ai.trace.caption}</p>
          </aside>
        </div>
      </div>
    </section>

    <!-- ============================================================
         PLATFORM + CHANNEL — Two surfaces, one operating loop
         ============================================================ -->
    <section id="platform" class="section section--platform-channel">
      <div class="page-frame">
        <div class="section-intro reveal">
          <p class="eyebrow">{content.platformChannel.eyebrow}</p>
          <h2 class="section-title">{content.platformChannel.title}</h2>
