<script>
  // ============================================================
  // Hero reactive dot field — cursor-following illumination
  // ============================================================
  (function () {
    const cv = document.querySelector<HTMLCanvasElement>('.hero__field');
    if (!cv) return;
    const hero = cv.closest<HTMLElement>('.hero');
    if (!hero) return;
    const ctx = cv.getContext('2d');
    if (!ctx) return;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const GRID = 26;
    const DOT_R = 1.05;
    const RADIUS = 200;
    const BASE_ALPHA = 0.055;
    const GLOW_ALPHA = 0.42;
    const BASE_RGB: [number, number, number] = [132, 151, 189];
    const GLOW_RGB: [number, number, number] = [78, 168, 252];

    let dpr = 1;
    let w = 0;
    let h = 0;
    let dots: Array<{ x: number; y: number }> = [];
    let raf = 0;
    let alive = false;
    const mouse = { x: -9999, y: -9999, tx: -9999, ty: -9999 };

    function resize() {
      const rect = hero!.getBoundingClientRect();
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      w = Math.max(1, Math.floor(rect.width));
      h = Math.max(1, Math.floor(rect.height));
      cv!.width = Math.floor(w * dpr);
      cv!.height = Math.floor(h * dpr);
      cv!.style.width = w + 'px';
      cv!.style.height = h + 'px';
      ctx!.setTransform(1, 0, 0, 1, 0, 0);
      ctx!.scale(dpr, dpr);
      layoutDots();
    }
    function layoutDots() {
      dots = [];
      const cols = Math.ceil(w / GRID) + 1;
      const rows = Math.ceil(h / GRID) + 1;
      const offX = (w - (cols - 1) * GRID) / 2;
      for (let i = 0; i < cols; i++) {
        for (let j = 0; j < rows; j++) {
          dots.push({ x: offX + i * GRID, y: j * GRID });
        }
      }
    }
    function frame() {
      ctx!.clearRect(0, 0, w, h);
      mouse.x += (mouse.tx - mouse.x) * 0.16;
      mouse.y += (mouse.ty - mouse.y) * 0.16;
      const cx = mouse.x;
      const cy = mouse.y;
      const r2 = RADIUS * RADIUS;
      for (let i = 0; i < dots.length; i++) {
        const d = dots[i];
        const dx = d.x - cx;
        const dy = d.y - cy;
        const d2 = dx * dx + dy * dy;
        let alpha = BASE_ALPHA;
        let r = BASE_RGB[0];
        let g = BASE_RGB[1];
        let b = BASE_RGB[2];
        if (d2 < r2) {
          const t = 1 - Math.sqrt(d2) / RADIUS;
          const k = t * t;
          alpha = BASE_ALPHA + (GLOW_ALPHA - BASE_ALPHA) * k;
          r = Math.round(BASE_RGB[0] + (GLOW_RGB[0] - BASE_RGB[0]) * k);
          g = Math.round(BASE_RGB[1] + (GLOW_RGB[1] - BASE_RGB[1]) * k);
          b = Math.round(BASE_RGB[2] + (GLOW_RGB[2] - BASE_RGB[2]) * k);
        }
        ctx!.fillStyle = 'rgba(' + r + ',' + g + ',' + b + ',' + alpha + ')';
        ctx!.beginPath();
        ctx!.arc(d.x, d.y, DOT_R, 0, Math.PI * 2);
        ctx!.fill();
      }
      raf = requestAnimationFrame(frame);
    }
    function staticFrame() {
      ctx!.clearRect(0, 0, w, h);
      ctx!.fillStyle = 'rgba(' + BASE_RGB.join(',') + ',' + BASE_ALPHA + ')';
      for (let i = 0; i < dots.length; i++) {
        const d = dots[i];
        ctx!.beginPath();
        ctx!.arc(d.x, d.y, DOT_R, 0, Math.PI * 2);
        ctx!.fill();
      }
    }
    function onMove(e: MouseEvent) {
      const rect = hero!.getBoundingClientRect();
      mouse.tx = e.clientX - rect.left;
      mouse.ty = e.clientY - rect.top;
      if (!alive) {
        mouse.x = mouse.tx;
        mouse.y = mouse.ty;
        alive = true;
      }
    }
    function start() {
      if (raf) cancelAnimationFrame(raf);
      raf = requestAnimationFrame(frame);
    }
    resize();
    if (reduced) {
      staticFrame();
      window.addEventListener('resize', () => {
        resize();
        staticFrame();
      });
      return;
    }
    const hasFinePointer = window.matchMedia('(pointer: fine)').matches;
    if (!hasFinePointer) {
      staticFrame();
      return;
    }
    window.addEventListener('mousemove', onMove, { passive: true });
    window.addEventListener('resize', resize);
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        cancelAnimationFrame(raf);
        raf = 0;
      } else if (!raf) {
        start();
      }
    });
    start();
  })();

  // ============================================================
  // Hero flow sequencer — sliding panes (left → right)
  // ============================================================
  (function () {
    const flow = document.getElementById('hero-flow');
    if (!flow) return;
    const track = flow.querySelector<HTMLElement>('.pane-track');
    if (!track) return;
    const panes = Array.from(track.querySelectorAll<HTMLElement>('.pane'));
    const dots = Array.from(flow.querySelectorAll<HTMLButtonElement>('.pane-dot'));
    if (panes.length === 0) return;

    const typingTargets = flow.querySelectorAll<HTMLElement>('[data-typing]');
    typingTargets.forEach((el) => {
      if (el.dataset.typingPrepared) return;
      el.dataset.typingPrepared = '1';
      const text = el.textContent || '';
      const baseDelay = Number(el.dataset.typingStart || 380);
      const perChar = Number(el.dataset.typingSpeed || 18);
      el.textContent = '';
      const chars = Array.from(text);
      chars.forEach((c, i) => {
        if (c === ' ') {
          el.appendChild(document.createTextNode(' '));
        } else {
          const span = document.createElement('span');
          span.className = 'tchar';
          span.textContent = c;
          span.style.animationDelay = baseDelay + i * perChar + 'ms';
          el.appendChild(span);
        }
      });
    });

    const dwellMs = [3800, 3600, 4200, 7000];
    let current = 0;
    let timer = 0;

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function activate(idx: number) {
      track!.style.transform = 'translateX(-' + idx * 100 + '%)';
      dots.forEach((d, i) => d.classList.toggle('is-active', i === idx));
      panes.forEach((p) => p.classList.remove('is-active'));
      void panes[idx].offsetWidth;
      panes[idx].classList.add('is-active');
    }

    function advance() {
      current = (current + 1) % panes.length;
      activate(current);
      timer = window.setTimeout(advance, dwellMs[current]);
    }

    dots.forEach((dot, idx) => {
      dot.addEventListener('click', () => {
        window.clearTimeout(timer);
        current = idx;
        activate(current);
        if (!reduced) {
          timer = window.setTimeout(advance, dwellMs[current]);
        }
      });
    });

    if (reduced) {
      panes[0].classList.add('is-active');
      return;
    }

    timer = window.setTimeout(advance, dwellMs[0]);
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        window.clearTimeout(timer);
      } else {
        timer = window.setTimeout(advance, 1200);
      }
    });
  })();

  // ============================================================
  // Scroll-triggered reveal
  // ============================================================
  (function () {
    const targets = document.querySelectorAll<HTMLElement>('.reveal');
    if (targets.length === 0) return;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) {
      targets.forEach((el) => el.classList.add('is-visible'));
      return;
    }
    if (typeof IntersectionObserver === 'undefined') {
      targets.forEach((el) => el.classList.add('is-visible'));
      return;
    }
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const delay = Number(el.dataset.revealDelay || 0);
            window.setTimeout(() => el.classList.add('is-visible'), delay);
            io.unobserve(el);
          }
        }
      },
      { rootMargin: '0px 0px -10% 0px', threshold: 0.12 }
    );
    targets.forEach((el) => io.observe(el));
  })();

  // ============================================================
  // Viz reveal — cascade content inside each viz when it enters viewport
  // ============================================================
  (function () {
    const vizs = document.querySelectorAll<HTMLElement>('.viz');
    if (vizs.length === 0) return;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced || typeof IntersectionObserver === 'undefined') {
      vizs.forEach((v) => v.classList.add('is-revealed'));
      return;
    }
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-revealed');
            io.unobserve(entry.target);
          }
        }
      },
      { rootMargin: '0px 0px -15% 0px', threshold: 0.25 }
    );
    vizs.forEach((v) => io.observe(v));
  })();

</script>
