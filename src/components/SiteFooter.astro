---
import type { Locale } from '../data/landingContent';

interface Props {
  locale: Locale;
  footer: {
    statement: string;
    brandLine: string;
    email: string;
    links: Array<{ label: string; href: string }>;
    apps: { title: string; rows: Array<{ label: string; appStore: string; playStore: string }> };
    credit: string;
  };
}

const { footer } = Astro.props;
---

<!-- Footer · Ft5 statement -->
<footer class="s-footer">
  <div class="s-wrap">
    <p class="s-footer__statement">{footer.statement}</p>
    <div class="s-footer__meta">
      <div class="s-footer__brand">
        <img src="/strivn-logo-full-white-web.png" alt="STRIVN" width="1130" height="369" />
        <p>{footer.brandLine}</p>
      </div>
      <ul class="s-footer__links">
        {footer.links.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
        <li><a href={`mailto:${footer.email}`}>{footer.email}</a></li>
      </ul>
      <div class="s-footer__apps">
        <p class="s-footer__apps-title">{footer.apps.title}</p>
        <ul class="s-footer__apps-list">
          {footer.apps.rows.map((app) => (
            <li>
              <span class="s-footer__apps-name">{app.label}</span>
              <a href={app.appStore} target="_blank" rel="noopener" aria-label={`${app.label} — App Store`}>
                <svg class="s-footer__store-ico" viewBox="0 0 384 512" width="14" height="14" aria-hidden="true" focusable="false">
                  <path fill="currentColor" d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"/>
                </svg>
                App Store
              </a>
              <a href={app.playStore} target="_blank" rel="noopener" aria-label={`${app.label} — Google Play`}>
                <svg class="s-footer__store-ico" viewBox="0 0 512 512" width="14" height="14" aria-hidden="true" focusable="false">
                  <path fill="#00d0ff" d="M48.6 26.9C42.7 33.2 39.3 42.9 39.3 55.6v400.8c0 12.7 3.4 22.4 9.5 28.5l1.3 1.2 224.5-224.5v-5.3L50.1 25.7z"/>
                  <path fill="#00e676" d="M349.1 336.3l-74.8-74.8v-5.3l74.9-74.9 1.7 1 88.7 50.4c25.3 14.3 25.3 37.9 0 52.4l-88.7 50.4z"/>
                  <path fill="#ff3d47" d="M350.9 335.3L274.3 258.7 48.6 484.6c8.3 8.8 22.1 9.9 37.7 1.1l264.6-150.4"/>
                  <path fill="#ffd500" d="M350.9 182.1L86.3 31.8C70.7 22.9 56.9 24.1 48.6 32.9l225.7 225.8z"/>
                </svg>
                Google Play
              </a>
            </li>
          ))}
        </ul>
      </div>
      <span class="s-footer__credit">{footer.credit}</span>
    </div>
  </div>
</footer>
