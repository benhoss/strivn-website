---
import type { Locale } from '../data/landingContent';

interface Props {
  locale: Locale;
  footer: {
    statement: string;
    brandLine: string;
    email: string;
    links: Array<{ label: string; href: string }>;
    apps: { title: string; rows: Array<{ label: string; appStore: string; playStore: string }> };
    credit: string;
  };
}

const { footer } = Astro.props;
---

<!-- Footer · Ft5 statement -->
<footer class="s-footer">
  <div class="s-wrap">
    <p class="s-footer__statement">{footer.statement}</p>
    <div class="s-footer__meta">
      <div class="s-footer__brand">
        <img src="/strivn-logo-full-white-web.png" alt="STRIVN" width="1130" height="369" />
        <p>{footer.brandLine}</p>
      </div>
      <ul class="s-footer__links">
        {footer.links.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
        <li><a href={`mailto:${footer.email}`}>{footer.email}</a></li>
      </ul>
      <div class="s-footer__apps">
        <p class="s-footer__apps-title">{footer.apps.title}</p>
        <ul class="s-footer__apps-list">
          {footer.apps.rows.map((app) => (
            <li>
              <span class="s-footer__apps-name">{app.label}</span>
              <a href={app.appStore} target="_blank" rel="noopener">App Store</a>
              <a href={app.playStore} target="_blank" rel="noopener">Google Play</a>
            </li>
          ))}
        </ul>
      </div>
      <span class="s-footer__credit">{footer.credit}</span>
    </div>
  </div>
</footer>
