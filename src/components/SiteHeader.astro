---
import { APP_URL, type Locale } from '../data/landingContent';

type NavLink =
  | { label: string; href: string }
  | { label: string; children: Array<{ label: string; href: string }> };

interface Props {
  locale: Locale;
  links: NavLink[];
  cta: string;
  /** Where the brand logo links to ('#s-main' on the homepage, locale root on subpages). */
  brandHref?: string;
  /** Language-switcher targets, so subpages can point to their own counterpart. */
  switchHrefs?: { en: string; fr: string; nl?: string; de?: string };
}

const {
  locale,
  links,
  cta,
  brandHref = '#s-main',
  switchHrefs = { en: '/en/', fr: '/fr/', nl: '/nl/', de: '/de/' },
} = Astro.props;

const navAria =
  locale === 'fr' ? 'Navigation principale' : locale === 'nl' ? 'Hoofdnavigatie' : locale === 'de' ? 'Hauptnavigation' : 'Primary navigation';
const langAria =
  locale === 'fr' ? 'Changer la langue' : locale === 'nl' ? 'Taal wisselen' : locale === 'de' ? 'Sprache wechseln' : 'Switch language';
const menuLabel = 'Menu';

/** Language switcher entries — a locale falls back to its homepage when a page has no counterpart. */
const langs = [
  { code: 'fr' as const, label: 'FR', href: switchHrefs.fr },
  { code: 'en' as const, label: 'EN', href: switchHrefs.en },
  { code: 'nl' as const, label: 'NL', href: switchHrefs.nl ?? '/nl/' },
  { code: 'de' as const, label: 'DE', href: switchHrefs.de ?? '/de/' },
];
---

<!-- Nav · N5 floating pill -->
<nav class="s-nav" aria-label={navAria}>
  <a href={brandHref} class="s-nav__brand" aria-label="STRIVN">
    <img src="/strivn-logo-full-white-web.png" alt="STRIVN" width="1130" height="369" />
  </a>

  <ul class="s-nav__links">
    {links.map((link) => (
      'children' in link ? (
        <li class="s-nav__group" data-nav-group>
          <button type="button" class="s-nav__link s-nav__trigger" aria-haspopup="true" aria-expanded="false">
            {link.label}
            <svg class="s-nav__caret" viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <ul class="s-nav__menu">
            {link.children.map((child) => (
              <li><a href={child.href} class="s-nav__menu-link">{child.label}</a></li>
            ))}
          </ul>
        </li>
      ) : (
        <li><a href={link.href} class="s-nav__link">{link.label}</a></li>
      )
    ))}
  </ul>

  <button
    type="button"
    class="s-nav__burger"
    aria-label={menuLabel}
    aria-haspopup="true"
    aria-expanded="false"
    aria-controls="s-nav-mobile"
    data-nav-burger
  >
    <svg class="s-nav__burger-icon s-nav__burger-icon--open" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
    <svg class="s-nav__burger-icon s-nav__burger-icon--close" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true"><path d="M6 6l12 12M18 6 6 18"/></svg>
  </button>

  <div class="s-nav__lang" role="group" aria-label={langAria}>
    {langs.map((l, i) => (
      <>
        {i > 0 && <span class="s-nav__lang-sep" aria-hidden="true">·</span>}
        <a href={l.href} aria-current={locale === l.code ? 'page' : undefined}>{l.label}</a>
      </>
    ))}
  </div>

  <a href={APP_URL} target="_blank" rel="noopener" class="s-nav__cta">{cta}</a>

  <!-- Mobile menu panel (≤60rem, where the inline links are hidden) -->
  <div class="s-nav__mobile" id="s-nav-mobile" hidden>
    <ul class="s-nav__mobile-list">
      {links.map((link) => (
        'children' in link ? (
          <li class="s-nav__mobile-group">
            <span class="s-nav__mobile-grouplabel">{link.label}</span>
            <ul>
              {link.children.map((child) => (
                <li><a href={child.href} class="s-nav__mobile-link">{child.label}</a></li>
              ))}
            </ul>
          </li>
        ) : (
          <li><a href={link.href} class="s-nav__mobile-link">{link.label}</a></li>
        )
      ))}
    </ul>
    <div class="s-nav__mobile-lang" role="group" aria-label={langAria}>
      {langs.map((l, i) => (
        <>
          {i > 0 && <span aria-hidden="true">·</span>}
          <a href={l.href} aria-current={locale === l.code ? 'page' : undefined}>{l.label}</a>
        </>
      ))}
    </div>
  </div>
</nav>

<style>
  /* ── Desktop dropdown group (links hidden ≤60rem) ──────────── */
  .s-nav__group {
    position: relative;
  }

  .s-nav__trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    background: none;
    border: none;
    cursor: pointer;
    font: inherit;
  }

  .s-nav__caret {
    transition: transform var(--dur-short) var(--ease-out);
  }

  .s-nav__group:hover .s-nav__caret,
  .s-nav__group:focus-within .s-nav__caret,
  .s-nav__group.is-open .s-nav__caret {
    transform: rotate(180deg);
  }

  .s-nav__menu {
    position: absolute;
    top: 100%;
    left: 50%;
    min-width: 13rem;
    margin: 0;
    padding: var(--space-xs);
    list-style: none;
    background: var(--nav-backdrop);
    backdrop-filter: blur(14px) saturate(120%);
    -webkit-backdrop-filter: blur(14px) saturate(120%);
    border: 1px solid var(--rule);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-chrome-lg);
    display: flex;
    flex-direction: column;
    gap: 2px;
    opacity: 0;
    visibility: hidden;
    transform: translateX(-50%) translateY(-0.375rem);
    transition:
      opacity var(--dur-short) var(--ease-out),
      transform var(--dur-short) var(--ease-out),
      visibility var(--dur-short);
  }

  .s-nav__group:hover .s-nav__menu,
  .s-nav__group:focus-within .s-nav__menu,
  .s-nav__group.is-open .s-nav__menu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0.375rem);
  }

  .s-nav__menu-link {
    display: block;
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius-sm);
    color: var(--ink-2);
    font-size: var(--text-sm);
    white-space: nowrap;
    text-decoration: none;
    transition:
      background-color var(--dur-micro) var(--ease-out),
      color var(--dur-micro) var(--ease-out);
  }

  .s-nav__menu-link:hover,
  .s-nav__menu-link:focus-visible {
    background: var(--navy-veil);
    color: var(--ink);
  }

  /* ── Hamburger (shown only ≤60rem) ─────────────────────────── */
  .s-nav__burger {
    display: none;
    align-items: center;
    justify-content: center;
    margin-left: auto;
    width: 2.25rem;
    height: 2.25rem;
    padding: 0;
    background: none;
    border: none;
    color: var(--ink);
    cursor: pointer;
  }

  .s-nav__burger-icon {
    position: absolute;
    transition: opacity var(--dur-short) var(--ease-out);
  }

  .s-nav__burger-icon--close {
    opacity: 0;
  }

  .s-nav__burger[aria-expanded='true'] .s-nav__burger-icon--open {
    opacity: 0;
  }

  .s-nav__burger[aria-expanded='true'] .s-nav__burger-icon--close {
    opacity: 1;
  }

  /* ── Mobile panel ──────────────────────────────────────────── */
  .s-nav__mobile {
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    min-width: 15rem;
    max-width: calc(100vw - 2 * var(--page-gutter));
    padding: var(--space-sm);
    /* Opaque so the larger panel reads cleanly over page content. */
    background: var(--surface-deep);
    border: 1px solid var(--rule-strong);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-chrome-lg);
  }

  .s-nav__mobile[hidden] {
    display: none;
  }

  .s-nav__mobile-list {
    list-style: none;
    margin: 0 0 var(--space-xs);
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .s-nav__mobile-list ul {
    list-style: none;
    margin: 0;
    padding: 0 0 0 var(--space-sm);
  }

  .s-nav__mobile-link {
    display: block;
    padding: 0.625rem 0.625rem;
    border-radius: var(--radius-sm);
    color: var(--ink-2);
    font-size: var(--text-body);
    text-decoration: none;
  }

  .s-nav__mobile-link:hover,
  .s-nav__mobile-link:focus-visible {
    background: var(--navy-veil);
    color: var(--ink);
  }

  .s-nav__mobile-grouplabel {
    display: block;
    padding: 0.5rem 0.625rem 0.125rem;
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-3);
  }

  .s-nav__mobile-lang {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-xs) 0.625rem 0;
    margin-top: var(--space-xs);
    border-top: 1px solid var(--rule);
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.06em;
  }

  .s-nav__mobile-lang a {
    color: var(--ink-3);
    text-decoration: none;
    padding: var(--space-2xs);
  }

  .s-nav__mobile-lang a[aria-current='page'] {
    color: var(--ink);
  }

  @media (max-width: 60rem) {
    .s-nav__burger {
      display: inline-flex;
      position: relative;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .s-nav__menu,
    .s-nav__caret,
    .s-nav__burger-icon {
      transition: none;
    }
  }
</style>

<script>
  // ── Desktop dropdown: CSS handles hover/focus; JS adds click, Escape,
  //    outside-click and aria-expanded sync. ──
  document.querySelectorAll('[data-nav-group]').forEach((group) => {
    const trigger = group.querySelector('.s-nav__trigger');
    if (!trigger) return;
    const setOpen = (open) => {
      group.classList.toggle('is-open', open);
      trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
    };
    trigger.addEventListener('click', (e) => {
      e.preventDefault();
      setOpen(!group.classList.contains('is-open'));
    });
    group.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') { setOpen(false); trigger.focus(); }
    });
    group.addEventListener('focusin', () => trigger.setAttribute('aria-expanded', 'true'));
    group.addEventListener('focusout', (e) => {
      if (!group.contains(e.relatedTarget)) setOpen(false);
    });
  });

  document.addEventListener('click', (e) => {
    document.querySelectorAll('[data-nav-group].is-open').forEach((group) => {
      if (!group.contains(e.target)) {
        group.classList.remove('is-open');
        group.querySelector('.s-nav__trigger')?.setAttribute('aria-expanded', 'false');
      }
    });
  });

  // ── Mobile menu: burger toggles the panel. ──
  document.querySelectorAll('[data-nav-burger]').forEach((burger) => {
    const panel = document.getElementById(burger.getAttribute('aria-controls'));
    if (!panel) return;
    const nav = burger.closest('.s-nav');
    const setOpen = (open) => {
      burger.setAttribute('aria-expanded', open ? 'true' : 'false');
      panel.hidden = !open;
    };
    burger.addEventListener('click', () => {
      setOpen(burger.getAttribute('aria-expanded') !== 'true');
    });
    panel.addEventListener('click', (e) => {
      if (e.target.closest('a')) setOpen(false);
    });
    document.addEventListener('click', (e) => {
      if (nav && !nav.contains(e.target)) setOpen(false);
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && burger.getAttribute('aria-expanded') === 'true') {
        setOpen(false);
        burger.focus();
      }
    });
  });
</script>
