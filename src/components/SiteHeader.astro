---
import { APP_URL, type Locale } from '../data/landingContent';

type NavLink =
  | { label: string; href: string }
  | { label: string; children: Array<{ label: string; href: string }> };

interface Props {
  locale: Locale;
  links: NavLink[];
  cta: string;
  /** Where the brand logo links to ('#s-main' on the homepage, locale root on subpages). */
  brandHref?: string;
  /** Language-switcher targets, so subpages can point to their own counterpart. */
  switchHrefs?: { en: string; fr: string };
}

const {
  locale,
  links,
  cta,
  brandHref = '#s-main',
  switchHrefs = { en: '/en/', fr: '/fr/' },
} = Astro.props;

const isFrench = locale === 'fr';
const navAria = isFrench ? 'Navigation principale' : 'Primary navigation';
const langAria = isFrench ? 'Changer la langue' : 'Switch language';
---

<!-- Nav · N5 floating pill -->
<nav class="s-nav" aria-label={navAria}>
  <a href={brandHref} class="s-nav__brand" aria-label="STRIVN">
    <img src="/strivn-logo-full-white-web.png" alt="STRIVN" width="180" height="120" />
  </a>
  <ul class="s-nav__links">
    {links.map((link) => (
      'children' in link ? (
        <li class="s-nav__group" data-nav-group>
          <button type="button" class="s-nav__link s-nav__trigger" aria-haspopup="true" aria-expanded="false">
            {link.label}
            <svg class="s-nav__caret" viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <ul class="s-nav__menu">
            {link.children.map((child) => (
              <li><a href={child.href} class="s-nav__menu-link">{child.label}</a></li>
            ))}
          </ul>
        </li>
      ) : (
        <li><a href={link.href} class="s-nav__link">{link.label}</a></li>
      )
    ))}
  </ul>
  <div class="s-nav__lang" role="group" aria-label={langAria}>
    <a href={switchHrefs.fr} aria-current={isFrench ? 'page' : undefined}>FR</a>
    <span class="s-nav__lang-sep" aria-hidden="true">·</span>
    <a href={switchHrefs.en} aria-current={!isFrench ? 'page' : undefined}>EN</a>
  </div>
  <a href={APP_URL} target="_blank" rel="noopener" class="s-nav__cta">{cta}</a>
</nav>

<style>
  /* Dropdown group (desktop only — the whole link list is hidden ≤60rem) */
  .s-nav__group {
    position: relative;
  }

  .s-nav__trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    background: none;
    border: none;
    cursor: pointer;
    font: inherit;
  }

  .s-nav__caret {
    transition: transform var(--dur-short) var(--ease-out);
  }

  .s-nav__group:hover .s-nav__caret,
  .s-nav__group:focus-within .s-nav__caret,
  .s-nav__group.is-open .s-nav__caret {
    transform: rotate(180deg);
  }

  .s-nav__menu {
    position: absolute;
    top: 100%;
    left: 50%;
    min-width: 13rem;
    margin: 0;
    padding: var(--space-xs);
    list-style: none;
    background: var(--nav-backdrop);
    backdrop-filter: blur(14px) saturate(120%);
    -webkit-backdrop-filter: blur(14px) saturate(120%);
    border: 1px solid var(--rule);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-chrome-lg);
    display: flex;
    flex-direction: column;
    gap: 2px;
    opacity: 0;
    visibility: hidden;
    transform: translateX(-50%) translateY(-0.375rem);
    transition:
      opacity var(--dur-short) var(--ease-out),
      transform var(--dur-short) var(--ease-out),
      visibility var(--dur-short);
  }

  .s-nav__group:hover .s-nav__menu,
  .s-nav__group:focus-within .s-nav__menu,
  .s-nav__group.is-open .s-nav__menu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0.375rem);
  }

  .s-nav__menu-link {
    display: block;
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius-sm);
    color: var(--ink-2);
    font-size: var(--text-sm);
    white-space: nowrap;
    text-decoration: none;
    transition:
      background-color var(--dur-micro) var(--ease-out),
      color var(--dur-micro) var(--ease-out);
  }

  .s-nav__menu-link:hover,
  .s-nav__menu-link:focus-visible {
    background: var(--navy-veil);
    color: var(--ink);
  }

  @media (prefers-reduced-motion: reduce) {
    .s-nav__menu,
    .s-nav__caret {
      transition: none;
    }
  }
</style>

<script>
  // Dropdown: CSS handles hover/focus reveal; JS adds click toggle,
  // Escape, outside-click and aria-expanded sync.
  document.querySelectorAll('[data-nav-group]').forEach((group) => {
    const trigger = group.querySelector('.s-nav__trigger');
    if (!trigger) return;

    const setOpen = (open) => {
      group.classList.toggle('is-open', open);
      trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
    };

    trigger.addEventListener('click', (e) => {
      e.preventDefault();
      setOpen(!group.classList.contains('is-open'));
    });

    group.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        setOpen(false);
        trigger.focus();
      }
    });

    // Keep aria in sync with keyboard focus (CSS reveals via :focus-within)
    group.addEventListener('focusin', () => trigger.setAttribute('aria-expanded', 'true'));
    group.addEventListener('focusout', (e) => {
      if (!group.contains(e.relatedTarget)) {
        setOpen(false);
      }
    });
  });

  document.addEventListener('click', (e) => {
    document.querySelectorAll('[data-nav-group].is-open').forEach((group) => {
      if (!group.contains(e.target)) {
        group.classList.remove('is-open');
        group.querySelector('.s-nav__trigger')?.setAttribute('aria-expanded', 'false');
      }
    });
  });
</script>
