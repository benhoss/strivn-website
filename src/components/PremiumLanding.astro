---
import BaseLayout from '../layouts/BaseLayout.astro';
import { landingContent, type Locale } from '../data/landingContent';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const content = landingContent[locale];
const isFrench = locale === 'fr';

const WA = `<path d="M16.6 14.2c-.3-.1-1.6-.8-1.9-.9-.2-.1-.4-.1-.6.1-.2.2-.7.8-.8.9-.1.1-.3.2-.5 0-.3-.1-1.1-.4-2.1-1.3-.8-.7-1.3-1.5-1.5-1.8-.1-.3 0-.4.1-.6l.4-.4.2-.3c0-.1.1-.2 0-.4 0-.1-.5-1.4-.8-1.8-.2-.5-.4-.4-.5-.4h-.5c-.2 0-.4.1-.7.3-.2.2-.9.9-.9 2.2 0 1.3.9 2.6 1.1 2.7.1.2 1.9 2.9 4.6 4 2.2.9 2.7.7 3.2.7.5-.1 1.6-.6 1.8-1.3.2-.6.2-1.2.2-1.3-.1-.1-.2-.2-.5-.3zM12 3a9 9 0 0 0-7.6 13.8L3 21l4.4-1.2A9 9 0 1 0 12 3z"/>`;

const chapters = [
  { id: 'platform', n: '01', label: isFrench ? 'La plateforme' : 'The platform' },
  { id: 'ai',       n: '02', label: isFrench ? "L'IA"         : 'The AI' },
  { id: 'loop',     n: '03', label: isFrench ? 'La semaine'   : 'The week' },
  { id: 'staff',    n: '04', label: isFrench ? 'Le staff'     : 'The staff' },
  { id: 'control',  n: '05', label: isFrench ? 'Le contrôle'  : 'Control' },
];
---

<BaseLayout
  lang={locale}
  title={content.meta.title}
  description={content.meta.description}
>
  <main class="v2" id="v2-top">
    <!-- Fixed ambient layers — never block content -->
    <div class="v2-ambient" aria-hidden="true">
      <canvas class="v2-paint" id="v2-paint"></canvas>
      <div class="v2-noise"></div>
      <div class="v2-bloom v2-bloom--a"></div>
      <div class="v2-bloom v2-bloom--b"></div>
      <div class="v2-cursor"></div>
    </div>

    <!-- Top bar — compact, the brand statement lives in the hero -->
    <header class="v2-topbar">
      <a href="#v2-top" class="v2-brand v2-brand--compact" aria-label="STRIVN">
        <img src="/strivn-logo-full-white-web.png" alt="STRIVN" width="120" height="80" />
      </a>
      <nav class="v2-nav" aria-label="Primary">
        {chapters.map((c) => (
          <a href={`#v2-${c.id}`} class="v2-nav__link">
            <span class="v2-nav__n">{c.n}</span>
            <span class="v2-nav__label">{c.label}</span>
          </a>
        ))}
      </nav>
      <div class="v2-topbar__end">
        <div class="v2-lang" role="group" aria-label={isFrench ? 'Changer la langue' : 'Switch language'}>
          <a href="/fr/" class:list={['v2-lang__opt', isFrench && 'is-active']} aria-current={isFrench ? 'page' : undefined}>FR</a>
          <span class="v2-lang__sep" aria-hidden="true">·</span>
          <a href="/en/" class:list={['v2-lang__opt', !isFrench && 'is-active']} aria-current={!isFrench ? 'page' : undefined}>EN</a>
        </div>
        <a href="https://app.strivn.net" target="_blank" rel="noopener" class="v2-cta-mini">{isFrench ? 'Commencer gratuitement' : 'Start free'}</a>
      </div>
    </header>

    <!-- ─────────────────────────────── HERO ─────────────────────────────── -->
    <section class="v2-hero">
      <a href="#v2-top" class="v2-hero__logo v2-reveal" data-reveal aria-label="STRIVN">
        <img src="/strivn-logo-full-white-web.png" alt="STRIVN" width="480" height="320" />
      </a>
      <h1 class="v2-hero__title v2-words" data-words>
        {content.hero.title}
      </h1>
      <h2 class="v2-hero__accent v2-words" data-words data-words-delay="600">
        {content.hero.titleAccent}
      </h2>
      <p class="v2-hero__lede v2-reveal" data-reveal data-delay="1200">
        {content.hero.body}
      </p>
      <div class="v2-hero__actions v2-reveal" data-reveal data-delay="1400">
        <a href="https://app.strivn.net" target="_blank" rel="noopener" class="v2-btn v2-btn--primary">{isFrench ? 'Commencer gratuitement' : 'Start free'}</a>
        <a href="#v2-loop" class="v2-btn v2-btn--ghost">{content.hero.secondaryCta}</a>
      </div>

      <!-- ───────── Hero device — 4-pane sequencer (library-free, timer-driven) ───────── -->
      <div class="v2-device" id="v2-device" aria-label="STRIVN demo">
        <div class="v2-device__chrome" aria-hidden="true">
          <span class="v2-device__dot"></span>
          <span class="v2-device__dot"></span>
          <span class="v2-device__dot"></span>
          <span class="v2-device__url">app.strivn.ai · {isFrench ? 'Saison 2025-26' : 'Season 2025-26'}</span>
        </div>
        <div class="v2-device__viewport">
          <div class="v2-device__track" id="v2-device-track">
            <!-- 01 · Voice dictation -->
            <article class="v2-pane is-active" data-pane-step="1">
              <header class="v2-pane__head">
                <span class="v2-pane__n">01</span>
                <span class="v2-pane__label">{content.hero.panel.stepVoiceLabel}</span>
              </header>
              <p class="v2-pane__quote" data-v2-typing data-v2-typing-start="320" data-v2-typing-speed="20">{content.hero.panel.stepVoiceQuote}</p>
              <p class="v2-pane__echo">{content.hero.panel.stepVoiceEcho}</p>
            </article>

            <!-- 02 · Week state -->
            <article class="v2-pane" data-pane-step="2">
              <header class="v2-pane__head">
                <span class="v2-pane__n">02</span>
                <span class="v2-pane__label">{content.hero.panel.stepStateLabel}</span>
              </header>
              <div class="v2-pills">
                <span class="v2-pill v2-pill--info">{content.hero.panel.stepStatePillAttendance}</span>
                <span class="v2-pill v2-pill--info">{content.hero.panel.stepStatePillRisk}</span>
                <span class="v2-pill">{content.hero.panel.stepStatePillRsvp}</span>
              </div>
              <p class="v2-pane__explain">{content.hero.panel.stepStateExplain}</p>
              <ul class="v2-pane__list">
                {content.hero.panel.stepStateInsights.map((insight, i) => (
                  <li style={`--v2-li: ${i};`}>{insight}</li>
                ))}
              </ul>
            </article>

            <!-- 03 · Proposal -->
            <article class="v2-pane" data-pane-step="3">
              <header class="v2-pane__head">
                <span class="v2-pane__n">03</span>
                <span class="v2-pane__label">{content.hero.panel.stepProposalLabel}</span>
                <span class="v2-pane__badge">{content.hero.panel.stepProposalBadge}</span>
              </header>
              <h3 class="v2-pane__title">{content.hero.panel.stepProposalTitle}</h3>
              <div class="v2-pane__metrics">
                {content.hero.panel.stepProposalMetrics.map((m, i) => (
                  <div class="v2-pane__metric" style={`--v2-li: ${i};`}>
                    <span class="v2-pane__metric-l">{m.label}</span>
                    <span class="v2-pane__metric-v">{m.value}</span>
                  </div>
                ))}
              </div>
              <div class="v2-pane__cta">
                <span class="v2-pane__btn v2-pane__btn--primary">{content.hero.panel.stepProposalApprove}</span>
                <span class="v2-pane__btn v2-pane__btn--ghost">{content.hero.panel.stepProposalReject}</span>
              </div>
            </article>

            <!-- 04 · WhatsApp side — team channel -->
            <article class="v2-pane v2-pane--player" data-pane-step="4">
              <header class="v2-pane__head">
                <span class="v2-pane__n">04</span>
                <span class="v2-pane__label">{content.hero.panel.player.label}</span>
              </header>
              <div class="v2-phone" aria-hidden="true">
                <div class="v2-phone__bar">
                  <span class="v2-phone__time">{content.hero.panel.player.phoneTime}</span>
                  <span class="v2-phone__dots"><span></span><span></span><span></span></span>
                </div>
                <div class="v2-phone__head">
                  <span class="v2-phone__avatar">{content.hero.panel.player.phoneAvatar}</span>
                  <div class="v2-phone__id">
                    <span class="v2-phone__name">{content.hero.panel.player.phoneName}</span>
                    <span class="v2-phone__sub">{content.hero.panel.player.phoneSub}</span>
                  </div>
                  <span class="v2-phone__wa" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="11" height="11" fill="currentColor" set:html={WA} />
                  </span>
                </div>
                <div class="v2-phone__chat">
                  {content.hero.panel.player.bubbles.map((b, i) => (
                    <div class={`v2-bubble v2-bubble--${b.direction}`} style={`--v2-bi: ${i};`}>
                      <p>{b.text}</p>
                      <span class="v2-bubble__time">{b.time}</span>
                    </div>
                  ))}
                  <div class="v2-wellness" style="--v2-bi: 4;">
                    <span class="v2-wellness__l">{content.hero.panel.player.wellness.label}</span>
                    <span class="v2-wellness__v">{content.hero.panel.player.wellness.value}</span>
                    <span class="v2-wellness__n">{content.hero.panel.player.wellness.note}</span>
                  </div>
                </div>
              </div>
            </article>
          </div>
        </div>

        <nav class="v2-device__dots" aria-label="Demo steps">
          {[0, 1, 2, 3].map((i) => (
            <button type="button" class={`v2-device__dot-btn${i === 0 ? ' is-active' : ''}`} data-pane-go={i} aria-label={`Step ${i + 1}`}></button>
          ))}
        </nav>
      </div>

      <div class="v2-scroll-cue v2-reveal" data-reveal data-delay="2000" aria-hidden="true">
        <span class="v2-scroll-cue__label">{isFrench ? 'Faire défiler' : 'Scroll'}</span>
        <span class="v2-scroll-cue__line"></span>
      </div>
    </section>

    <!-- ─────────────────── CHAPTER 01 · PLATFORM & CHANNEL ─────────────────── -->
    <section class="v2-chapter" id="v2-platform" data-accent="electric">
      <div class="v2-chapter__head">
        <span class="v2-chapter__n v2-reveal" data-reveal>01</span>
        <p class="v2-chapter__eyebrow v2-reveal" data-reveal data-delay="80">{content.platformChannel.eyebrow}</p>
        <h2 class="v2-chapter__title v2-words" data-words>{content.platformChannel.title}</h2>
        <p class="v2-chapter__body v2-reveal" data-reveal data-delay="600">{content.platformChannel.body}</p>
      </div>

      <div class="v2-split">
        <article class="v2-card v2-card--platform v2-reveal" data-reveal data-delay="100">
          <header class="v2-card__head">
            <p class="v2-card__eyebrow">{content.platformChannel.platformSide.eyebrow}</p>
            <span class="v2-where v2-where--platform">
              <span class="v2-where__dot"></span>
              <span>{isFrench ? 'Le staff travaille ici' : 'Where staff works'}</span>
            </span>
          </header>
          <div class="v2-dash">
            <div class="v2-dash__chrome">
              <span class="v2-dash__url">{content.platformChannel.platformSide.url}</span>
            </div>
            <div class="v2-dash__tabs">
              {content.platformChannel.platformSide.sections.map((s) => (
                <span class:list={['v2-dash__tab', s === content.platformChannel.platformSide.activeSection && 'is-active']}>{s}</span>
              ))}
            </div>
            <div class="v2-dash__context">
              <span class="v2-dash__live"></span>
              <span>{content.platformChannel.platformSide.contextLine}</span>
            </div>
            <div class="v2-dash__insight">
              <p class="v2-dash__insight-eyebrow">{isFrench ? 'Insight' : 'Insight'}</p>
              <h3 class="v2-dash__insight-title">{content.platformChannel.platformSide.insightTitle}</h3>
              <p class="v2-dash__insight-body">{content.platformChannel.platformSide.insightBody}</p>
              <ul class="v2-dash__roster">
                {content.platformChannel.platformSide.rosterRows.slice(0, 4).map((row) => (
                  <li class="v2-dash__row">
                    <span class="v2-dash__avatar"></span>
                    <span class="v2-dash__name">{row.name}</span>
                    <span class:list={['v2-pill', `v2-pill--${row.tone}`]}>{row.status}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
          <p class="v2-card__caption">{content.platformChannel.platformSide.caption}</p>
        </article>

        <div class="v2-bridge" aria-hidden="true">
          <span class="v2-bridge__line"></span>
          <span class="v2-bridge__arrow">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </span>
          <p class="v2-bridge__label">{content.platformChannel.bridge}</p>
        </div>

        <article class="v2-card v2-card--channel v2-reveal" data-reveal data-delay="200">
          <header class="v2-card__head">
            <p class="v2-card__eyebrow">
              <span class="v2-wa-mini"><svg viewBox="0 0 24 24" width="11" height="11" fill="currentColor" set:html={WA} /></span>
              {content.platformChannel.channelSide.eyebrow}
            </p>
            <span class="v2-where v2-where--channel">
              <span class="v2-where__dot v2-where__dot--green"></span>
              <span>{isFrench ? "L'équipe répond ici" : 'Where the team answers'}</span>
            </span>
          </header>
          <div class="v2-phone">
            <div class="v2-phone__bar">
              <span>{content.platformChannel.channelSide.phoneTime}</span>
              <span class="v2-phone__dots"><span></span><span></span><span></span></span>
            </div>
            <div class="v2-phone__app">
              <div class="v2-phone__header">
                <span class="v2-phone__av">{content.platformChannel.channelSide.phoneAvatar}</span>
                <div class="v2-phone__id">
                  <span class="v2-phone__name">{content.platformChannel.channelSide.phoneName}</span>
                  <span class="v2-phone__sub">{content.platformChannel.channelSide.phoneSub}</span>
                </div>
                <span class="v2-wa-mini v2-phone__wa"><svg viewBox="0 0 24 24" width="11" height="11" fill="currentColor" set:html={WA} /></span>
              </div>
              <div class="v2-phone__chat">
                {content.platformChannel.channelSide.thread.map((line) => (
                  <div class:list={['v2-bubble', line.from === 'player' ? 'v2-bubble--in' : 'v2-bubble--out']}>
                    <p>{line.text}</p>
                    <span class="v2-bubble__time">{line.time}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
          <p class="v2-card__caption">{content.platformChannel.channelSide.caption}</p>
        </article>
      </div>
    </section>

    <!-- ─────────────────── CHAPTER 02 · AI ─────────────────── -->
    <section class="v2-chapter" id="v2-ai" data-accent="violet">
      <div class="v2-chapter__head">
        <span class="v2-chapter__n v2-reveal" data-reveal>02</span>
        <p class="v2-chapter__eyebrow v2-reveal" data-reveal data-delay="80">{content.ai.eyebrow}</p>
        <h2 class="v2-chapter__title v2-words" data-words>{content.ai.title}</h2>
        <p class="v2-chapter__body v2-reveal" data-reveal data-delay="600">{content.ai.body}</p>
      </div>

      <ol class="v2-principles">
        {content.ai.principles.map((p, i) => (
          <li class="v2-principle v2-reveal" data-reveal data-delay={i * 100}>
            <span class="v2-principle__n">{String(i + 1).padStart(2, '0')}</span>
            <div class="v2-principle__copy">
              <span class="v2-principle__label">{p.label}</span>
              <h3 class="v2-principle__verb">{p.verb}</h3>
              <p class="v2-principle__body">{p.body}</p>
            </div>
          </li>
        ))}
      </ol>

      <aside class="v2-trace v2-reveal" data-reveal data-delay="200">
        <header class="v2-trace__head">
          <p class="v2-trace__eyebrow">{content.ai.trace.eyebrow}</p>
          <span class="v2-trace__badge">{content.ai.trace.badge}</span>
        </header>
        <h3 class="v2-trace__title">{content.ai.trace.title}</h3>
        <div class="v2-trace__block">
          <span class="v2-trace__label">{content.ai.trace.evidenceLabel}</span>
          <ul class="v2-trace__evidence">
            {content.ai.trace.evidence.map((line) => (
              <li><span class="v2-trace__dot"></span><span>{line}</span></li>
            ))}
          </ul>
        </div>
        <div class="v2-trace__block v2-trace__block--row">
          <span class="v2-trace__label">{content.ai.trace.confidenceLabel}</span>
          <div class="v2-trace__bars">
            {Array.from({ length: content.ai.trace.confidenceTotal }).map((_, i) => (
              <span class:list={['v2-trace__bar', i < content.ai.trace.confidenceSegments && 'is-filled']}></span>
            ))}
            <span class="v2-trace__conf">{content.ai.trace.confidenceLevel}</span>
          </div>
        </div>
        <footer class="v2-trace__actions">
          <span class="v2-btn v2-btn--primary v2-btn--small">{content.ai.trace.approve}</span>
          <span class="v2-btn v2-btn--ghost v2-btn--small">{content.ai.trace.adjust}</span>
        </footer>
      </aside>
    </section>

    <!-- ─────────────────── CHAPTER 03 · LOOP ─────────────────── -->
    <section class="v2-chapter" id="v2-loop" data-accent="performance">
      <div class="v2-chapter__head">
        <span class="v2-chapter__n v2-reveal" data-reveal>03</span>
        <p class="v2-chapter__eyebrow v2-reveal" data-reveal data-delay="80">{content.howItWorks.eyebrow}</p>
        <h2 class="v2-chapter__title v2-words" data-words>{content.howItWorks.title}</h2>
        <p class="v2-chapter__body v2-reveal" data-reveal data-delay="600">{content.howItWorks.body}</p>
      </div>

      <div class="v2-moments">
        {content.howItWorks.moments.map((m, i) => (
          <article class="v2-moment v2-reveal" data-reveal data-delay={i * 120}>
            <span class="v2-moment__n">0{i + 1}</span>
            <p class="v2-moment__phase">{m.phase}</p>
            <h3 class="v2-moment__title">{m.title}</h3>
            <p class="v2-moment__body">{m.body}</p>
            <ul class="v2-moment__bullets">
              {m.bullets.map((b) => <li>{b}</li>)}
            </ul>
          </article>
        ))}
      </div>

      <div class="v2-board v2-reveal" data-reveal data-delay="200">
        <header class="v2-board__head">
          <p class="v2-board__eyebrow">{content.howItWorks.board.eyebrow}</p>
          <h3 class="v2-board__title">{content.howItWorks.board.title}</h3>
          <span class="v2-board__stamp">{content.howItWorks.board.stamp}</span>
        </header>
        <div class="v2-board__grid">
          {content.howItWorks.board.items.map((item) => (
            <div class="v2-board__item">
              <span class="v2-board__label">{item.label}</span>
              <p>{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ─────────────────── CHAPTER 04 · STAFF ─────────────────── -->
    <section class="v2-chapter" id="v2-staff" data-accent="performance">
      <div class="v2-chapter__head">
        <span class="v2-chapter__n v2-reveal" data-reveal>04</span>
        <p class="v2-chapter__eyebrow v2-reveal" data-reveal data-delay="80">{content.forWhom.eyebrow}</p>
        <h2 class="v2-chapter__title v2-words" data-words>{content.forWhom.title}</h2>
        <p class="v2-chapter__body v2-reveal" data-reveal data-delay="600">{content.forWhom.body}</p>
      </div>

      <div class="v2-roster v2-reveal" data-reveal data-delay="100">
        <table class="v2-roster__table">
          <thead>
            <tr>
              <th>{content.forWhom.columns.role}</th>
              <th>{content.forWhom.columns.sees}</th>
              <th>{content.forWhom.columns.does}</th>
              <th>{content.forWhom.columns.surface}</th>
            </tr>
          </thead>
          <tbody>
            {content.forWhom.rows.map((row) => (
              <tr>
                <th scope="row">
                  <span class="v2-roster__avatar">{row.initials}</span>
                  <span>{row.role}</span>
                </th>
                <td>{row.sees}</td>
                <td>{row.does}</td>
                <td>
                  <span class:list={['v2-chip', row.surfaceKind === 'channel' && 'v2-chip--channel']}>
                    {row.surfaceKind === 'channel' ? (
                      <svg viewBox="0 0 24 24" width="11" height="11" fill="currentColor" set:html={WA} aria-hidden="true" />
                    ) : (
                      <span class="v2-chip__dot"></span>
                    )}
                    <span>{row.surface}</span>
                  </span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- ─────────────────── CHAPTER 05 · CONTROL ─────────────────── -->
    <section class="v2-chapter" id="v2-control" data-accent="warm">
      <div class="v2-chapter__head">
        <span class="v2-chapter__n v2-reveal" data-reveal>05</span>
        <p class="v2-chapter__eyebrow v2-reveal" data-reveal data-delay="80">{content.confidence.eyebrow}</p>
        <h2 class="v2-chapter__title v2-words" data-words>{content.confidence.title}</h2>
        <p class="v2-chapter__body v2-reveal" data-reveal data-delay="600">{content.confidence.body}</p>
      </div>

      <ul class="v2-controls">
        {content.confidence.points.map((point, i) => (
          <li class="v2-control v2-reveal" data-reveal data-delay={i * 120}>
            <span class="v2-control__n">·</span>
            <p>{point}</p>
          </li>
        ))}
      </ul>
    </section>

    <!-- ─────────────────── FAQ ─────────────────── -->
    <section class="v2-chapter v2-chapter--faq" id="v2-faq" data-accent="electric">
      <div class="v2-chapter__head">
        <p class="v2-chapter__eyebrow v2-reveal" data-reveal>{content.faq.eyebrow}</p>
        <h2 class="v2-chapter__title v2-words" data-words>{content.faq.title}</h2>
        <p class="v2-chapter__body v2-reveal" data-reveal data-delay="600">{content.faq.body}</p>
      </div>
      <div class="v2-faq">
        {content.faq.items.map((q, i) => (
          <details class="v2-faq__item v2-reveal" data-reveal data-delay={i * 80}>
            <summary>
              <span>{q.question}</span>
              <span class="v2-faq__plus" aria-hidden="true">+</span>
            </summary>
            <p>{q.answer}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- ─────────────────── CTA ─────────────────── -->
    <section class="v2-chapter v2-chapter--cta" id="v2-contact">
      <div class="v2-cta">
        <p class="v2-chapter__eyebrow v2-reveal" data-reveal>{content.contact.eyebrow}</p>
        <h2 class="v2-cta__title v2-words" data-words>{content.contact.title}</h2>
        <p class="v2-cta__body v2-reveal" data-reveal data-delay="500">{content.contact.body}</p>
        <div class="v2-cta__actions v2-reveal" data-reveal data-delay="700">
          <a href="https://app.strivn.net" target="_blank" rel="noopener" class="v2-btn v2-btn--primary v2-btn--large">{isFrench ? 'Commencer gratuitement' : 'Start free'}</a>
          <a href={content.contact.primaryHref} class="v2-btn v2-btn--ghost">{content.contact.primaryCta}</a>
        </div>
      </div>
    </section>

    <footer class="v2-footer">
      <div class="v2-footer__top">
        <div class="v2-footer__brand">
          <img src="/strivn-logo-full-white-web.png" alt="STRIVN" width="120" height="80" />
          <p>{content.footer.brandLine}</p>
          <a href="https://app.strivn.net" target="_blank" rel="noopener" class="v2-footer__cta">
            {isFrench ? 'Commencer gratuitement' : 'Start free'}
            <span class="v2-footer__cta-arrow" aria-hidden="true">→</span>
          </a>
        </div>

        <div class="v2-footer__col">
          <h4 class="v2-footer__h">{isFrench ? 'Produit' : 'Product'}</h4>
          <ul>
            <li><a href="#v2-platform">{isFrench ? 'La plateforme' : 'The platform'}</a></li>
            <li><a href="#v2-ai">{isFrench ? "L'IA" : 'The AI'}</a></li>
            <li><a href="#v2-loop">{isFrench ? 'La semaine' : 'The week'}</a></li>
            <li><a href="#v2-control">{isFrench ? 'Le contrôle' : 'Control'}</a></li>
          </ul>
        </div>

        <div class="v2-footer__col">
          <h4 class="v2-footer__h">{isFrench ? 'Pour qui' : 'For whom'}</h4>
          <ul>
            <li><a href="#v2-staff">{isFrench ? 'Head coach' : 'Head coach'}</a></li>
            <li><a href="#v2-staff">{isFrench ? 'Prépa physique' : 'S&C coach'}</a></li>
            <li><a href="#v2-staff">{isFrench ? 'Kiné' : 'Physio'}</a></li>
            <li><a href="#v2-staff">{isFrench ? 'Joueurs' : 'Players'}</a></li>
          </ul>
        </div>

        <div class="v2-footer__col">
          <h4 class="v2-footer__h">{isFrench ? 'Contact' : 'Contact'}</h4>
          <ul>
            <li><a href={`mailto:${content.footer.email}`}>{content.footer.email}</a></li>
            <li><a href={content.contact.primaryHref}>{isFrench ? 'Réserver une démo' : 'Book a demo'}</a></li>
            <li><a href="#v2-faq">FAQ</a></li>
          </ul>
        </div>
      </div>

      <div class="v2-footer__bottom">
        <p class="v2-footer__legal">© {new Date().getFullYear()} STRIVN · {isFrench ? 'Tous droits réservés' : 'All rights reserved'}</p>
        <p class="v2-footer__credit">{isFrench ? 'Fait avec soin pour les coaches multi-casquettes' : 'Crafted for multi-hat coaches'}</p>
        <div class="v2-footer__lang">
          <a href="/fr/" class={isFrench ? 'is-active' : ''}>FR</a>
          <span aria-hidden="true">·</span>
          <a href="/en/" class={!isFrench ? 'is-active' : ''}>EN</a>
        </div>
      </div>
    </footer>
  </main>
</BaseLayout>

<style is:global>
  /* ============================================================
     STRIVN · v2 Premium · scoped to .v2 root
     Calm + elite. Big type, hairline cards, generous space.
     ============================================================ */
  .v2 {
    --v2-void: #050610;
    --v2-void-2: #0a0c17;
    --v2-card: rgba(15, 22, 40, 0.72);
    --v2-card-2: rgba(20, 30, 52, 0.55);
    --v2-line: rgba(255, 255, 255, 0.08);
    --v2-line-2: rgba(255, 255, 255, 0.14);
    --v2-fg: #f4f7fb;
    --v2-muted: #b5c2d7;
    --v2-subtle: #8497bd;
    --v2-faint: #4f6488;
    --v2-electric: #4f94fb;
    --v2-electric-deep: #2d7ff9;
    --v2-performance: #4fe0b5;
    --v2-performance-deep: #27d7a1;
    --v2-violet: #9c7cff;
    --v2-violet-deep: #7c5cdc;
    --v2-warm: #ffb476;
    --v2-warm-deep: #ff8c42;
    --v2-risk: #ff5c5c;
    --v2-accent: var(--v2-electric);
    --v2-accent-deep: var(--v2-electric-deep);
    --v2-ease: cubic-bezier(0.22, 1, 0.36, 1);
    --v2-ease-out: cubic-bezier(0.16, 1, 0.3, 1);
    --v2-dur: 800ms;
    --v2-frame-w: min(82rem, calc(100vw - 96px));
    --v2-gutter: clamp(60px, 8vw, 140px);

    position: relative;
    background: var(--v2-void);
    color: var(--v2-fg);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 16px;
    line-height: 1.5;
    overflow-x: clip;
    min-height: 100vh;
  }
  html, body { overflow-x: clip; scroll-behavior: smooth; }

  /* ----- Ambient layers (fixed, never block content) ----- */
  .v2-ambient {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }
  .v2-paint {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.55;
    mix-blend-mode: screen;
    transition: opacity 800ms var(--v2-ease);
  }
  /* If WebGL fails, the canvas stays empty; the noise + blooms still carry the ambient look. */
  .v2-noise {
    position: absolute;
    inset: -50%;
    background-image:
      radial-gradient(circle at 30% 20%, rgba(45, 127, 249, 0.10), transparent 50%),
      radial-gradient(circle at 70% 80%, rgba(124, 92, 220, 0.08), transparent 50%);
    opacity: 0.9;
  }
  .v2-bloom {
    position: absolute;
    width: 90rem;
    height: 90rem;
    border-radius: 50%;
    filter: blur(100px);
    pointer-events: none;
    will-change: transform, background;
    transition: background 1200ms var(--v2-ease);
  }
  .v2-bloom--a {
    top: -30%;
    left: -25%;
    background: radial-gradient(circle, rgba(45, 127, 249, 0.30), transparent 60%);
  }
  .v2-bloom--b {
    bottom: -35%;
    right: -25%;
    background: radial-gradient(circle, rgba(39, 215, 161, 0.24), transparent 60%);
    opacity: 0.85;
  }
  .v2-cursor {
    position: absolute;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.06), transparent 60%);
    transform: translate(-50%, -50%);
    left: 50%;
    top: 50%;
    transition: transform 280ms var(--v2-ease);
    will-change: transform;
    mix-blend-mode: screen;
  }

  /* Section-driven accent — bloom hue follows the current chapter */
  .v2[data-active-accent="performance"] .v2-bloom--a {
    background: radial-gradient(circle, rgba(39, 215, 161, 0.30), transparent 60%);
  }
  .v2[data-active-accent="performance"] .v2-bloom--b {
    background: radial-gradient(circle, rgba(45, 127, 249, 0.24), transparent 60%);
  }
  .v2[data-active-accent="violet"] .v2-bloom--a {
    background: radial-gradient(circle, rgba(124, 92, 220, 0.30), transparent 60%);
  }
  .v2[data-active-accent="violet"] .v2-bloom--b {
    background: radial-gradient(circle, rgba(45, 127, 249, 0.20), transparent 60%);
  }
  .v2[data-active-accent="warm"] .v2-bloom--a {
    background: radial-gradient(circle, rgba(255, 176, 32, 0.22), transparent 60%);
  }
  .v2[data-active-accent="warm"] .v2-bloom--b {
    background: radial-gradient(circle, rgba(255, 92, 92, 0.18), transparent 60%);
  }

  /* ============================================================
     Topbar
     ============================================================ */
  .v2-topbar {
    position: sticky;
    top: 0;
    z-index: 50;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 14px clamp(20px, 3vw, 40px);
    background: rgba(5, 6, 16, 0.5);
    backdrop-filter: blur(20px) saturate(140%);
    -webkit-backdrop-filter: blur(20px) saturate(140%);
    border-bottom: 1px solid var(--v2-line);
    gap: 24px;
  }
  .v2-topbar > .v2-brand { justify-self: start; }
  .v2-topbar > .v2-nav { justify-self: center; }
  .v2-topbar > .v2-topbar__end { justify-self: end; }
  .v2-brand {
    display: inline-flex;
    align-items: center;
  }
  .v2-brand img {
    display: block;
    height: 72px;
    width: auto;
  }
