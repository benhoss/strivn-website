  .v2-dash__tab.is-active {
    color: var(--v2-fg);
    background: rgba(45, 127, 249, 0.1);
  }
  .v2-dash__context {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10.5px;
    color: var(--v2-subtle);
    border-bottom: 1px solid var(--v2-line);
  }
  .v2-dash__live {
    width: 5px; height: 5px; border-radius: 50%;
    background: var(--v2-performance);
  }
  .v2-dash__insight {
    padding: 18px 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .v2-dash__insight-eyebrow {
    margin: 0;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--v2-accent);
  }
  .v2-dash__insight-title {
    margin: 0;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }
  .v2-dash__insight-body {
    margin: 0;
    font-size: 12.5px;
    color: var(--v2-muted);
    line-height: 1.5;
  }
  .v2-dash__roster {
    list-style: none;
    margin: 8px 0 0;
    padding: 0;
    background: var(--v2-card);
    border: 1px solid var(--v2-line);
    border-radius: 10px;
    overflow: hidden;
  }
  .v2-dash__row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 12px;
    padding: 8px 12px;
    border-bottom: 1px solid var(--v2-line);
    font-size: 12.5px;
  }
  .v2-dash__row:last-child { border-bottom: 0; }
  .v2-dash__avatar {
    width: 22px; height: 22px; border-radius: 50%;
    background: linear-gradient(135deg, var(--v2-faint), var(--v2-subtle));
    border: 1px solid var(--v2-line);
  }
  .v2-dash__name { color: var(--v2-fg); font-weight: 500; }

  /* Bridge */
  .v2-bridge {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding-top: 80px;
  }
  .v2-bridge__line {
    width: 1px; height: 80px;
    background: linear-gradient(180deg, transparent, var(--v2-line-2) 50%, transparent);
  }
  .v2-bridge__arrow {
    width: 32px; height: 32px;
    border-radius: 50%;
    background: var(--v2-card);
    border: 1px solid var(--v2-line-2);
    display: grid;
    place-items: center;
    color: var(--v2-accent);
  }
  .v2-bridge__label {
    max-width: 14rem;
    margin: 8px 0 0;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10.5px;
    line-height: 1.5;
    color: var(--v2-subtle);
    text-align: center;
    letter-spacing: 0.02em;
  }

  /* Phone */
  .v2-phone {
    background: var(--v2-card-2);
    border: 1px solid var(--v2-line);
    border-radius: 16px;
    overflow: hidden;
    max-width: 320px;
    margin: 0 auto;
  }
  .v2-phone__bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 6px 14px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10px;
    color: var(--v2-subtle);
    background: rgba(255, 255, 255, 0.03);
    border-bottom: 1px solid var(--v2-line);
  }
  .v2-phone__dots {
    display: inline-flex;
    gap: 4px;
  }
  .v2-phone__dots span {
    width: 4px; height: 4px; border-radius: 50%;
    background: var(--v2-faint);
  }
  .v2-phone__app {
    background: var(--v2-void-2);
    display: flex;
    flex-direction: column;
  }
  .v2-phone__header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    border-bottom: 1px solid var(--v2-line);
  }
  .v2-phone__av {
    width: 28px; height: 28px; border-radius: 50%;
    background: linear-gradient(135deg, var(--v2-electric), var(--v2-performance));
    display: grid;
    place-items: center;
    color: white;
    font-size: 11px;
    font-weight: 600;
  }
  .v2-phone__id {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
    flex: 1;
  }
  .v2-phone__name { font-size: 12.5px; font-weight: 600; }
  .v2-phone__sub { font-size: 10px; color: var(--v2-performance); font-family: 'JetBrains Mono', ui-monospace, monospace; }
  .v2-phone__wa { margin-left: auto; }
  .v2-phone__chat {
    padding: 12px 14px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .v2-bubble {
    max-width: 82%;
    padding: 8px 12px;
    border-radius: 14px;
    font-size: 12px;
    line-height: 1.45;
  }
  .v2-bubble p { margin: 0; }
  .v2-bubble--in {
    align-self: flex-start;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--v2-line);
    border-bottom-left-radius: 4px;
  }
  .v2-bubble--out {
    align-self: flex-end;
    background: rgba(45, 127, 249, 0.18);
    border: 1px solid rgba(45, 127, 249, 0.28);
    border-bottom-right-radius: 4px;
  }
  .v2-bubble__time {
    display: block;
    margin-top: 4px;
    font-size: 10px;
    color: var(--v2-faint);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    text-align: right;
  }
  .v2-bubble--out .v2-bubble__time { color: var(--v2-electric); }

  /* Status pills */
  .v2-pill {
    display: inline-flex;
    align-items: center;
    padding: 3px 9px;
    border-radius: 999px;
    font-size: 10.5px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    letter-spacing: 0.04em;
    border: 1px solid var(--v2-line);
  }
  .v2-pill--positive { color: var(--v2-performance); background: rgba(39, 215, 161, 0.08); border-color: rgba(39, 215, 161, 0.24); }
  .v2-pill--warn     { color: #ffb020;            background: rgba(255, 176, 32, 0.08); border-color: rgba(255, 176, 32, 0.24); }
  .v2-pill--info     { color: var(--v2-electric); background: rgba(45, 127, 249, 0.08); border-color: rgba(45, 127, 249, 0.24); }

  @media (max-width: 960px) {
    .v2-split { grid-template-columns: 1fr; gap: 24px; }
    .v2-bridge {
      flex-direction: row;
      padding-top: 0;
    }
    .v2-bridge__line {
      width: 60px; height: 1px;
      background: linear-gradient(90deg, transparent, var(--v2-line-2), transparent);
    }
    .v2-bridge__arrow { transform: rotate(90deg); }
    .v2-bridge__label { text-align: left; max-width: 18rem; }
  }

  /* ============================================================
     Chapter 02 — Principles + Trace
     ============================================================ */
  .v2-principles {
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: 60rem;
    margin: 0 auto 48px;
  }
  .v2-principle {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: 32px;
    padding: 36px 0;
    border-top: 1px solid var(--v2-line);
  }
  .v2-principle:last-child { border-bottom: 1px solid var(--v2-line); }
  .v2-principle__n {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 13px;
    color: var(--v2-accent);
    letter-spacing: 0.08em;
    padding-top: 8px;
  }
  .v2-principle__copy {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .v2-principle__label {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--v2-subtle);
  }
  .v2-principle__verb {
    margin: 0;
    font-size: clamp(20px, 2.4vw, 28px);
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.2;
  }
  .v2-principle__body {
    margin: 0;
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--v2-muted);
    max-width: 42rem;
  }
  @media (max-width: 720px) {
    .v2-principle { grid-template-columns: 1fr; gap: 12px; padding: 28px 0; }
    .v2-principle__n { padding-top: 0; }
  }

  /* Trace card */
  .v2-trace {
    max-width: 36rem;
    margin: 0 auto;
    background: var(--v2-card);
    border: 1px solid var(--v2-line-2);
    border-radius: 18px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 0 60px -20px rgba(124, 92, 220, 0.3);
  }
  .v2-trace__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .v2-trace__eyebrow {
    margin: 0;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--v2-accent);
  }
  .v2-trace__badge {
    font-size: 10.5px;
    padding: 4px 10px;
    border-radius: 999px;
    color: var(--v2-accent);
    border: 1px solid currentColor;
    background: rgba(124, 92, 220, 0.08);
    letter-spacing: 0.04em;
  }
  .v2-trace__title {
    margin: 0;
    font-size: 20px;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.25;
  }
  .v2-trace__block {
    padding: 16px 0;
    border-top: 1px solid var(--v2-line);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .v2-trace__block--row {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }
  .v2-trace__label {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--v2-subtle);
  }
  .v2-trace__evidence {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 8px;
  }
  .v2-trace__evidence li {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 12px;
    font-size: 13.5px;
    color: var(--v2-fg);
  }
  .v2-trace__dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--v2-accent);
    box-shadow: 0 0 0 3px rgba(124, 92, 220, 0.18);
  }
  .v2-trace__bars {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .v2-trace__bar {
    width: 16px; height: 8px; border-radius: 2px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--v2-line);
  }
  .v2-trace__bar.is-filled {
    background: var(--v2-accent);
    border-color: var(--v2-accent);
  }
  .v2-trace__conf {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 12px;
    font-weight: 600;
    color: var(--v2-accent);
    margin-left: 6px;
  }
  .v2-trace__actions {
    display: flex;
    gap: 10px;
    padding-top: 16px;
    border-top: 1px solid var(--v2-line);
  }

  /* ============================================================
     Chapter 03 — Loop moments
     ============================================================ */
  .v2-moments {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    max-width: var(--v2-frame-w);
    margin: 0 auto 48px;
  }
  .v2-moment {
    background: var(--v2-card);
    border: 1px solid var(--v2-line);
    border-radius: 18px;
    padding: 28px;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    transition: transform 320ms var(--v2-ease), border-color 320ms var(--v2-ease);
  }
  .v2-moment:hover {
    transform: translateY(-2px);
    border-color: var(--v2-accent);
  }
  .v2-moment__n {
    display: inline-block;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 13px;
    color: var(--v2-accent);
    margin-bottom: 12px;
    letter-spacing: 0.08em;
  }
  .v2-moment__phase {
    margin: 0 0 8px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--v2-subtle);
  }
  .v2-moment__title {
    margin: 0 0 12px;
    font-size: 19px;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }
  .v2-moment__body {
    margin: 0 0 16px;
    font-size: 14px;
    line-height: 1.55;
    color: var(--v2-muted);
  }
  .v2-moment__bullets {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--v2-line);
    padding-top: 14px;
    display: grid;
    gap: 8px;
  }
  .v2-moment__bullets li {
    position: relative;
    padding-left: 16px;
    font-size: 13px;
    color: var(--v2-muted);
    line-height: 1.5;
  }
  .v2-moment__bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 9px;
    width: 6px; height: 1px;
    background: var(--v2-accent);
  }
  @media (max-width: 960px) {
    .v2-moments { grid-template-columns: 1fr; }
  }

  /* Board */
  .v2-board {
    max-width: var(--v2-frame-w);
    margin: 0 auto;
    background: var(--v2-card);
    border: 1px solid var(--v2-line);
    border-radius: 20px;
    padding: 36px;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }
  .v2-board__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--v2-line);
    margin-bottom: 24px;
    flex-wrap: wrap;
  }
  .v2-board__eyebrow {
    margin: 0;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--v2-accent);
  }
  .v2-board__title {
    margin: 6px 0 0;
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .v2-board__stamp {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10.5px;
    letter-spacing: 0.06em;
    color: var(--v2-faint);
    padding: 4px 12px;
    border: 1px solid var(--v2-line);
    border-radius: 999px;
  }
  .v2-board__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .v2-board__item {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .v2-board__label {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--v2-accent);
  }
  .v2-board__item p {
    margin: 0;
    font-size: 13px;
    line-height: 1.55;
    color: var(--v2-muted);
  }
  @media (max-width: 960px) {
    .v2-board__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .v2-board__grid { grid-template-columns: 1fr; }
    .v2-board { padding: 24px; }
  }

  /* ============================================================
     Chapter 04 — Roster table
     ============================================================ */
  .v2-roster {
    background: var(--v2-card);
    border: 1px solid var(--v2-line);
    border-radius: 20px;
    overflow: hidden;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }
  .v2-roster__table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }
  .v2-roster__table thead th {
    text-align: left;
    padding: 18px 24px;
    background: rgba(255, 255, 255, 0.02);
    border-bottom: 1px solid var(--v2-line-2);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--v2-subtle);
    font-weight: 600;
    white-space: nowrap;
  }
  .v2-roster__table tbody tr {
    border-bottom: 1px solid var(--v2-line);
    transition: background 200ms var(--v2-ease);
  }
  .v2-roster__table tbody tr:hover {
    background: rgba(255, 255, 255, 0.014);
  }
  .v2-roster__table tbody tr:last-child { border-bottom: 0; }
  .v2-roster__table th,
  .v2-roster__table td {
    padding: 20px 24px;
    vertical-align: top;
    text-align: left;
    color: var(--v2-muted);
    line-height: 1.5;
  }
  .v2-roster__table tbody th {
    display: flex;
    align-items: center;
    gap: 12px;
    font-weight: 600;
    color: var(--v2-fg);
    font-size: 15px;
    white-space: nowrap;
  }
  .v2-roster__avatar {
    width: 32px; height: 32px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--v2-faint), var(--v2-subtle));
    border: 1px solid var(--v2-line-2);
    display: grid;
    place-items: center;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    color: var(--v2-fg);
  }
  .v2-roster__table tbody tr:last-child .v2-roster__avatar {
    background: linear-gradient(135deg, var(--v2-faint), rgba(39, 215, 161, 0.5));
    border-color: rgba(39, 215, 161, 0.32);
  }
  .v2-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    border-radius: 999px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10.5px;
    color: var(--v2-electric);
    background: rgba(45, 127, 249, 0.08);
    border: 1px solid rgba(45, 127, 249, 0.22);
    white-space: nowrap;
  }
  .v2-chip--channel {
    color: var(--v2-performance);
    background: rgba(39, 215, 161, 0.08);
    border-color: rgba(39, 215, 161, 0.22);
  }
  .v2-chip__dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: currentColor;
  }
  @media (max-width: 720px) {
    .v2-roster__table thead { display: none; }
    .v2-roster__table tr {
      display: block;
      padding: 18px 20px;
      border-bottom: 1px solid var(--v2-line);
    }
    .v2-roster__table th,
    .v2-roster__table td {
      display: block;
      padding: 6px 0;
    }
    .v2-roster__table tbody th {
      padding-bottom: 12px;
      margin-bottom: 8px;
      border-bottom: 1px solid var(--v2-line);
    }
    .v2-roster__table td::before {
      content: attr(data-label);
    }
  }

  /* ============================================================
     Chapter 05 — Control points
     ============================================================ */
  .v2-controls {
    list-style: none;
    margin: 0 auto;
    padding: 0;
    max-width: 56rem;
    display: grid;
    gap: 24px;
  }
  .v2-control {
    display: grid;
    grid-template-columns: 36px 1fr;
    align-items: start;
    gap: 16px;
    padding: 24px 0;
    border-bottom: 1px solid var(--v2-line);
  }
  .v2-control:last-child { border-bottom: 0; }
  .v2-control__n {
    font-size: 32px;
    color: var(--v2-accent);
    line-height: 1;
    margin-top: -8px;
  }
  .v2-control p {
    margin: 0;
    font-size: clamp(16px, 1.4vw, 19px);
    line-height: 1.5;
    color: var(--v2-fg);
    font-weight: 500;
  }

  /* ============================================================
     FAQ
     ============================================================ */
  .v2-faq {
    max-width: 50rem;
    margin: 0 auto;
  }
  .v2-faq__item {
    border-bottom: 1px solid var(--v2-line);
  }
  .v2-faq__item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 24px 0;
    list-style: none;
    cursor: pointer;
    font-size: 16px;
    font-weight: 500;
    color: var(--v2-fg);
  }
  .v2-faq__item summary::-webkit-details-marker { display: none; }
  .v2-faq__plus {
    font-size: 22px;
    color: var(--v2-accent);
    font-weight: 300;
    transition: transform 300ms var(--v2-ease);
  }
  .v2-faq__item[open] .v2-faq__plus {
    transform: rotate(45deg);
  }
  .v2-faq__item p {
    margin: 0 0 24px;
    font-size: 14.5px;
    line-height: 1.65;
    color: var(--v2-muted);
    max-width: 44rem;
  }

  /* ============================================================
     CTA + Footer
     ============================================================ */
  .v2-chapter--cta {
    padding-bottom: 80px;
  }
  .v2-cta {
    max-width: 56rem;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    padding: clamp(48px, 8vw, 96px);
    background: var(--v2-card);
    border: 1px solid var(--v2-line-2);
    border-radius: 28px;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    position: relative;
    overflow: hidden;
