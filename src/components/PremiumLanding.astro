  .v2-nav {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .v2-nav__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border-radius: 999px;
    color: var(--v2-muted);
