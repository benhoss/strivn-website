    const wordContainers = document.querySelectorAll<HTMLElement>('[data-words]');
    wordContainers.forEach((el) => {
      const baseDelay = Number(el.dataset.wordsDelay || 0);
      el.style.setProperty('--v2-base', baseDelay + 'ms');
      const text = el.textContent || '';
      el.textContent = '';
      const parts = text.split(/(\s+)/);
      let wi = 0;
      parts.forEach((part) => {
        if (/^\s+$/.test(part)) {
          el.appendChild(document.createTextNode(' '));
        } else if (part.length > 0) {
          const span = document.createElement('span');
          span.className = 'v2-word';
          span.style.setProperty('--v2-wi', String(wi));
          span.textContent = part;
          el.appendChild(span);
          wi += 1;
        }
      });
    });

    // ───── Set delay on .v2-reveal[data-delay] ─────
    document.querySelectorAll<HTMLElement>('.v2-reveal[data-delay]').forEach((el) => {
      el.style.setProperty('--v2-rd', el.dataset.delay + 'ms');
    });

    // If reduced motion, mark everything in immediately and stop
    if (reduced) {
      document.querySelectorAll('.v2-reveal, .v2-words').forEach((el) => el.classList.add('is-in'));
      return;
    }

    // ───── Reveal observer ─────
    const targets = document.querySelectorAll<HTMLElement>('.v2-reveal, .v2-words');
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-in');
            io.unobserve(entry.target);
          }
        });
      },
      { rootMargin: '0px 0px -8% 0px', threshold: 0.08 }
    );
    targets.forEach((el) => io.observe(el));

    // ───── First-paint pass: anything already in viewport at load shows immediately.
    // This is the critical bug fix from v9 — without this, IO sometimes doesn't fire
    // for above-the-fold elements before the user notices "nothing is here". ─────
    function showInView() {
      targets.forEach((el) => {
        if (el.classList.contains('is-in')) return;
        const rect = el.getBoundingClientRect();
        if (rect.top < window.innerHeight * 0.95 && rect.bottom > 0) {
          el.classList.add('is-in');
          io.unobserve(el);
        }
      });
    }
    requestAnimationFrame(() => requestAnimationFrame(showInView));

    // ───── Cursor follow on .v2-cursor ─────
    const cursor = document.querySelector<HTMLElement>('.v2-cursor');
    if (cursor && window.matchMedia('(pointer: fine)').matches) {
      let mx = window.innerWidth / 2;
      let my = window.innerHeight / 2;
      let tx = mx, ty = my;
      let raf = 0;
      function tick() {
        mx += (tx - mx) * 0.12;
        my += (ty - my) * 0.12;
        cursor!.style.transform = `translate(${mx - window.innerWidth / 2}px, ${my - window.innerHeight / 2}px)`;
        raf = requestAnimationFrame(tick);
      }
      window.addEventListener('mousemove', (e) => {
        tx = e.clientX;
        ty = e.clientY;
        if (!raf) raf = requestAnimationFrame(tick);
      }, { passive: true });
    }

    // ───── Chapter accent — drive bloom hue from the currently-most-visible chapter ─────
    const chapters = document.querySelectorAll<HTMLElement>('.v2-chapter[data-accent]');
    if (chapters.length) {
      const chapterIO = new IntersectionObserver(
        (entries) => {
          // Pick the entry with the largest intersection ratio that's intersecting
          let best: IntersectionObserverEntry | null = null;
          for (const e of entries) {
            if (e.isIntersecting && (!best || e.intersectionRatio > best.intersectionRatio)) {
              best = e;
            }
          }
          if (best) {
            const accent = (best.target as HTMLElement).dataset.accent || 'electric';
            root!.dataset.activeAccent = accent;
          }
        },
        { threshold: [0.25, 0.5, 0.75], rootMargin: '-20% 0% -20% 0%' }
      );
      chapters.forEach((c) => chapterIO.observe(c));
    }

    // ============================================================
    // Hero device — pane sequencer (timer-based, no library deps)
    // ============================================================
    (function paneSequencer() {
      const device = document.getElementById('v2-device');
      if (!device) return;
      const track = document.getElementById('v2-device-track') as HTMLElement | null;
      if (!track) return;
      const panes = Array.from(device.querySelectorAll<HTMLElement>('.v2-pane'));
      const dots = Array.from(device.querySelectorAll<HTMLButtonElement>('.v2-device__dot-btn'));
      if (panes.length === 0) return;

      // Typing cascade for the voice quote
      device.querySelectorAll<HTMLElement>('[data-v2-typing]').forEach((el) => {
        if (el.dataset.v2TypingPrepared) return;
        el.dataset.v2TypingPrepared = '1';
        const text = el.textContent || '';
        const start = Number(el.dataset.v2TypingStart || 320);
        const speed = Number(el.dataset.v2TypingSpeed || 20);
        el.textContent = '';
        Array.from(text).forEach((c, i) => {
          if (c === ' ') {
            el.appendChild(document.createTextNode(' '));
          } else {
            const span = document.createElement('span');
            span.className = 'v2-tchar';
            span.textContent = c;
            span.style.animationDelay = start + i * speed + 'ms';
            el.appendChild(span);
          }
        });
      });

      let cur = -1;
      let timer = 0;
      const dwellMs = [4200, 3800, 4400, 6500];

      function activate(idx: number) {
        if (idx === cur) return;
        cur = idx;
        track!.style.transform = 'translateX(-' + idx * 25 + '%)';
        panes.forEach((p) => p.classList.remove('is-active'));
        void panes[idx].offsetWidth; // reflow so transition-delays re-fire
        panes[idx].classList.add('is-active');
        dots.forEach((d, i) => d.classList.toggle('is-active', i === idx));
      }
      function advance() {
        const next = (cur + 1) % panes.length;
        activate(next);
        timer = window.setTimeout(advance, dwellMs[next]);
      }
      function pause() { if (timer) { clearTimeout(timer); timer = 0; } }

      dots.forEach((dot, idx) => {
        dot.addEventListener('click', () => {
          pause();
          activate(idx);
          timer = window.setTimeout(advance, dwellMs[idx]);
        });
      });

      // Pause when off-screen to save cycles
      const sequencerIO = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting && cur === -1) {
            activate(0);
            timer = window.setTimeout(advance, dwellMs[0]);
          } else if (!e.isIntersecting) {
            pause();
          }
        }
      }, { threshold: 0.15 });
      sequencerIO.observe(device);

      if (reduced) {
        // Reduced motion: just show pane 0, no auto-advance
        activate(0);
      }
    })();

    // ============================================================
    // Three.js painted-texture background — additive ambient
    // Fails silently if WebGL is unavailable; ambient .v2-noise + .v2-bloom still work.
    // ============================================================
    (async function paintedBg() {
      if (reduced) return;
      const canvas = document.getElementById('v2-paint') as HTMLCanvasElement | null;
      if (!canvas) return;
      if (!window.matchMedia('(pointer: fine)').matches && window.innerWidth < 768) return; // skip on mobile
      let THREE: typeof import('three');
      try {
        THREE = await import('three');
      } catch (err) {
        return; // graceful fail
      }
      let renderer: import('three').WebGLRenderer;
      try {
        renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: false, powerPreference: 'high-performance' });
      } catch (err) {
        return;
      }
      const dpr = Math.min(window.devicePixelRatio || 1, 1.5);
      renderer.setPixelRatio(dpr);
      renderer.setSize(window.innerWidth, window.innerHeight, false);

      const scene = new THREE.Scene();
      const camera = new THREE.OrthographicCamera(-1, 1, 1, -1, 0, 1);

      // Accent palette — matches the chapter accents the user already sees on blooms
      const palettes: Record<string, [THREE.Vector3, THREE.Vector3]> = {
        electric: [new THREE.Vector3(0.18, 0.50, 1.00), new THREE.Vector3(0.50, 0.30, 1.00)],
        performance: [new THREE.Vector3(0.15, 0.85, 0.70), new THREE.Vector3(0.20, 0.55, 1.00)],
        violet: [new THREE.Vector3(0.55, 0.40, 1.00), new THREE.Vector3(0.30, 0.45, 1.00)],
        warm: [new THREE.Vector3(1.00, 0.65, 0.30), new THREE.Vector3(1.00, 0.45, 0.45)],
      };

      const uniforms = {
        uTime: { value: 0 },
        uMouse: { value: new THREE.Vector2(0.5, 0.5) },
        uRes: { value: new THREE.Vector2(window.innerWidth, window.innerHeight) },
        uColorA: { value: palettes.electric[0].clone() },
        uColorB: { value: palettes.electric[1].clone() },
        uColorATarget: { value: palettes.electric[0].clone() },
        uColorBTarget: { value: palettes.electric[1].clone() },
        uIntensity: { value: 1.0 },
      };

      const material = new THREE.ShaderMaterial({
        uniforms,
        transparent: true,
        vertexShader: `
          varying vec2 vUv;
          void main() {
            vUv = uv;
            gl_Position = vec4(position, 1.0);
          }
        `,
        fragmentShader: `
          precision highp float;
          varying vec2 vUv;
          uniform float uTime;
          uniform vec2 uMouse;
          uniform vec2 uRes;
          uniform vec3 uColorA;
          uniform vec3 uColorB;
          uniform float uIntensity;

          // Simplex-ish noise
          vec3 mod289(vec3 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
          vec2 mod289(vec2 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
          vec3 permute(vec3 x) { return mod289(((x*34.0)+1.0)*x); }
          float snoise(vec2 v) {
            const vec4 C = vec4(0.211324865405187, 0.366025403784439, -0.577350269189626, 0.024390243902439);
            vec2 i  = floor(v + dot(v, C.yy) );
            vec2 x0 = v -   i + dot(i, C.xx);
            vec2 i1; i1 = (x0.x > x0.y) ? vec2(1.0, 0.0) : vec2(0.0, 1.0);
            vec4 x12 = x0.xyxy + C.xxzz; x12.xy -= i1;
            i = mod289(i);
            vec3 p = permute( permute( i.y + vec3(0.0, i1.y, 1.0 ))
                  + i.x + vec3(0.0, i1.x, 1.0 ));
            vec3 m = max(0.5 - vec3(dot(x0,x0), dot(x12.xy,x12.xy), dot(x12.zw,x12.zw)), 0.0);
            m = m*m; m = m*m;
            vec3 x = 2.0 * fract(p * C.www) - 1.0;
            vec3 h = abs(x) - 0.5;
            vec3 ox = floor(x + 0.5);
            vec3 a0 = x - ox;
            m *= 1.79284291400159 - 0.85373472095314 * ( a0*a0 + h*h );
            vec3 g;
            g.x  = a0.x  * x0.x  + h.x  * x0.y;
            g.yz = a0.yz * x12.xz + h.yz * x12.yw;
            return 130.0 * dot(m, g);
          }
          // Fractal Brownian motion
          float fbm(vec2 p) {
            float v = 0.0;
            float a = 0.5;
            for (int i = 0; i < 4; i++) {
              v += a * snoise(p);
              p *= 2.0;
              a *= 0.5;
            }
            return v;
          }

          void main() {
            vec2 st = vUv;
            vec2 aspect = vec2(uRes.x / uRes.y, 1.0);
            vec2 p = (st - 0.5) * aspect;
            vec2 m = (uMouse - 0.5) * aspect;

            float t = uTime * 0.06;
            // Painted flow — slow, layered
            float n1 = fbm(p * 1.4 + vec2(t, t * 0.7));
            float n2 = fbm(p * 2.6 - vec2(t * 0.5, t));
            float flow = n1 * 0.6 + n2 * 0.4;

            // Cursor influence — soft warm pull
            float d = length(p - m);
            float pull = smoothstep(0.8, 0.0, d) * 0.45;

            // Color mix
            vec3 col = mix(uColorA, uColorB, flow * 0.5 + 0.5);
            col += pull * uColorB * 0.35;

            // Vignette inward — keep center subtle, fade to nothing at edges
            float vign = smoothstep(1.1, 0.2, length(p));
            float alpha = vign * (0.25 + flow * 0.18 + pull * 0.3) * uIntensity;
            alpha = clamp(alpha, 0.0, 0.55);

            gl_FragColor = vec4(col, alpha);
          }
        `,
      });

      const mesh = new THREE.Mesh(new THREE.PlaneGeometry(2, 2), material);
      scene.add(mesh);

      // Cursor smoothing
      let mouseX = 0.5, mouseY = 0.5;
      let targetX = 0.5, targetY = 0.5;
      window.addEventListener('mousemove', (e) => {
        targetX = e.clientX / window.innerWidth;
        targetY = 1.0 - (e.clientY / window.innerHeight);
      }, { passive: true });

      // Smooth palette swap when chapter changes (driven by root[data-active-accent])
      function syncPalette() {
        const accent = root!.dataset.activeAccent || 'electric';
        const pair = palettes[accent] || palettes.electric;
        uniforms.uColorATarget.value.copy(pair[0]);
        uniforms.uColorBTarget.value.copy(pair[1]);
      }
      const accentObs = new MutationObserver(syncPalette);
      accentObs.observe(root!, { attributes: true, attributeFilter: ['data-active-accent'] });
      syncPalette();

      function onResize() {
        renderer.setSize(window.innerWidth, window.innerHeight, false);
        uniforms.uRes.value.set(window.innerWidth, window.innerHeight);
      }
      window.addEventListener('resize', onResize, { passive: true });

      const start = performance.now();
      let rafId = 0;
      let running = true;
      function loop(now: number) {
        if (!running) return;
        uniforms.uTime.value = (now - start) / 1000;
        mouseX += (targetX - mouseX) * 0.05;
        mouseY += (targetY - mouseY) * 0.05;
        uniforms.uMouse.value.set(mouseX, mouseY);
        // Ease palette toward target
        uniforms.uColorA.value.lerp(uniforms.uColorATarget.value, 0.04);
        uniforms.uColorB.value.lerp(uniforms.uColorBTarget.value, 0.04);
        renderer.render(scene, camera);
        rafId = requestAnimationFrame(loop);
      }
      rafId = requestAnimationFrame(loop);

      // Pause when tab hidden
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) {
          running = false;
          cancelAnimationFrame(rafId);
        } else if (!running) {
          running = true;
          rafId = requestAnimationFrame(loop);
        }
      });
    })();

    // ============================================================
    // Lenis smooth scroll — additive. If init fails, native scroll still works.
    // ============================================================
    let lenisInstance: any = null;
    (async function smoothScroll() {
      if (reduced) return;
      // Skip on coarse-pointer (touch) devices — native scrolling is best there
      if (!window.matchMedia('(pointer: fine)').matches) return;
      try {
        const { default: Lenis } = await import('lenis');
        lenisInstance = new Lenis({
          duration: 1.1,
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          smoothWheel: true,
          wheelMultiplier: 1.0,
          touchMultiplier: 1.0,
        });
        function raf(time: number) {
          lenisInstance.raf(time);
          requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);
      } catch (err) {
        // graceful fail — native scroll still works
      }
    })();

    // ============================================================
    // GSAP ScrollTrigger — cinematic accent ONLY. Never touches content opacity.
    // Drives the painted-bg intensity + chapter numeral parallax.
    // ============================================================
    (async function cinematicAccents() {
      if (reduced) return;
      let gsap: any, ScrollTrigger: any;
      try {
        const gsapMod = await import('gsap');
        const stMod = await import('gsap/ScrollTrigger');
        gsap = gsapMod.gsap || gsapMod.default;
        ScrollTrigger = stMod.ScrollTrigger || stMod.default;
        gsap.registerPlugin(ScrollTrigger);
      } catch (err) {
        return; // graceful fail — IO reveals + CSS already do the job
      }

      // Sync Lenis with ScrollTrigger if available
      if (lenisInstance) {
        lenisInstance.on('scroll', ScrollTrigger.update);
      }

      // Subtle parallax on chapter numerals — they drift slightly slower than the section
      document.querySelectorAll<HTMLElement>('.v2-chapter__n').forEach((el) => {
        gsap.to(el, {
          y: -40,
          ease: 'none',
          scrollTrigger: {
            trigger: el.closest('.v2-chapter'),
            start: 'top bottom',
            end: 'bottom top',
            scrub: 1.2,
          },
        });
      });

      // Light parallax on chapter headers — feels cinematic, never hides them
      document.querySelectorAll<HTMLElement>('.v2-chapter__head').forEach((el) => {
        gsap.to(el, {
          y: -24,
          ease: 'none',
          scrollTrigger: {
            trigger: el.closest('.v2-chapter'),
            start: 'top 80%',
            end: 'bottom 20%',
            scrub: 1.5,
          },
        });
      });

      // Note: no GSAP scroll on .v2-device — the sequencer owns its own transform
      // (track translateX for pane switching). Chapter numeral + head parallax above
      // is enough cinematic flair without fighting other transforms.
    })();
  })();
</script>
