    text-decoration: none;
    transition: color 200ms var(--v2-ease), background 200ms var(--v2-ease);
  }
  .v2-nav__link:hover { color: var(--v2-fg); background: rgba(255, 255, 255, 0.04); }
  .v2-nav__n {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10px;
    color: var(--v2-faint);
    letter-spacing: 0.06em;
  }
  .v2-cta-mini {
    display: inline-flex;
    align-items: center;
    padding: 10px 18px;
    border-radius: 999px;
    background: var(--v2-fg);
    color: var(--v2-void);
    font-size: 13.5px;
    font-weight: 500;
    text-decoration: none;
    transition: transform 200ms var(--v2-ease), opacity 200ms var(--v2-ease);
  }
  .v2-cta-mini:hover { transform: translateY(-1px); opacity: 0.92; }
  .v2-topbar__end {
    display: inline-flex;
    align-items: center;
    gap: 14px;
  }
  .v2-lang {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 6px 10px;
    border-radius: 999px;
    border: 1px solid var(--v2-line);
    background: rgba(255, 255, 255, 0.02);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11.5px;
    letter-spacing: 0.08em;
  }
  .v2-lang__opt {
    color: var(--v2-faint);
    text-decoration: none;
    padding: 2px 6px;
    border-radius: 999px;
    transition: color 180ms var(--v2-ease), background 180ms var(--v2-ease);
  }
  .v2-lang__opt:hover { color: var(--v2-muted); }
  .v2-lang__opt.is-active {
    color: var(--v2-fg);
    background: rgba(255, 255, 255, 0.08);
  }
  .v2-lang__sep {
    color: var(--v2-line-2);
    user-select: none;
  }

  @media (max-width: 880px) {
    .v2-nav { display: none; }
    .v2-topbar { padding: 12px 20px; gap: 12px; }
    .v2-brand--compact img { height: 34px; }
    .v2-topbar__end { gap: 10px; }
  }
  @media (max-width: 480px) {
    .v2-cta-mini { padding: 9px 14px; font-size: 12.5px; }
    .v2-brand--compact img { height: 30px; }
    .v2-lang { padding: 5px 8px; font-size: 11px; }
    .v2-lang__opt { padding: 2px 4px; }
  }

  /* ============================================================
     Hero
     ============================================================ */
  .v2-hero {
    position: relative;
    z-index: 1;
    max-width: var(--v2-frame-w);
    margin: 0 auto;
    padding: clamp(56px, 9vh, 120px) 24px clamp(120px, 18vh, 200px);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }
  .v2-hero__logo {
    display: inline-flex;
    margin-bottom: clamp(8px, 2vh, 20px);
  }
  .v2-hero__logo img {
    display: block;
    height: clamp(96px, 14vw, 160px);
    width: auto;
    filter: drop-shadow(0 8px 32px rgba(45, 127, 249, 0.18));
  }
  @media (max-width: 720px) {
    .v2-hero__logo img { height: 88px; }
  }
  @media (max-width: 414px) {
    .v2-hero__logo img { height: 76px; }
  }
  .v2-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--v2-subtle);
    padding: 6px 14px;
    border: 1px solid var(--v2-line-2);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.02);
  }
  .v2-eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--v2-performance);
    box-shadow: 0 0 0 3px rgba(79, 224, 181, 0.18);
  }
  .v2-hero__title {
    font-size: clamp(48px, 8vw, 112px);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 0.98;
    color: var(--v2-fg);
    max-width: 18ch;
    margin: 12px 0 0;
    overflow-wrap: anywhere;
    min-width: 0;
  }
  .v2-hero__accent {
    font-size: clamp(28px, 4vw, 56px);
    font-weight: 500;
    letter-spacing: -0.022em;
    line-height: 1.08;
    color: var(--v2-muted);
    margin: 0;
    max-width: 22ch;
    background: linear-gradient(180deg, var(--v2-muted) 0%, var(--v2-subtle) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .v2-hero__lede {
    font-size: clamp(15px, 1.4vw, 18px);
    line-height: 1.6;
    color: var(--v2-muted);
    max-width: 46rem;
    margin: 8px 0 0;
  }
  .v2-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    margin-top: 16px;
  }
  .v2-scroll-cue {
    position: relative;
    margin-top: 48px;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--v2-faint);
  }
  .v2-scroll-cue__line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--v2-faint), transparent);
    position: relative;
    overflow: hidden;
  }
  .v2-scroll-cue__line::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent, var(--v2-electric));
    transform: translateY(-100%);
    animation: v2-cue-fall 2.4s var(--v2-ease) infinite;
  }
  @keyframes v2-cue-fall {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(100%); }
  }

  /* ============================================================
     Buttons
     ============================================================ */
  .v2-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 22px;
    border-radius: 999px;
    font-family: inherit;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    border: 1px solid transparent;
    cursor: pointer;
    transition: transform 200ms var(--v2-ease), background 200ms var(--v2-ease),
      border-color 200ms var(--v2-ease), opacity 200ms var(--v2-ease);
  }
  .v2-btn--primary {
    background: var(--v2-fg);
    color: var(--v2-void);
  }
  .v2-btn--primary:hover {
    transform: translateY(-1px);
    opacity: 0.92;
  }
  .v2-btn--ghost {
    background: transparent;
    color: var(--v2-fg);
    border-color: var(--v2-line-2);
  }
  .v2-btn--ghost:hover {
    border-color: rgba(255, 255, 255, 0.3);
    background: rgba(255, 255, 255, 0.03);
  }
  .v2-btn--small {
    padding: 10px 16px;
    font-size: 13px;
  }
  .v2-btn--large {
    padding: 18px 30px;
    font-size: 15px;
  }

  /* ============================================================
     Chapter — shared shell for every section
     ============================================================ */
  .v2-chapter {
    position: relative;
    z-index: 1;
    max-width: var(--v2-frame-w);
    margin: 0 auto;
    padding: clamp(80px, 14vh, 180px) 24px;
  }
  .v2-chapter__head {
    max-width: 56rem;
    margin: 0 auto clamp(48px, 6vw, 96px);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .v2-chapter__n {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 13px;
    letter-spacing: 0.16em;
    color: var(--v2-accent);
    padding: 4px 12px;
    border: 1px solid currentColor;
    border-radius: 999px;
    opacity: 0.75;
  }
  .v2-chapter__eyebrow {
    margin: 0;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--v2-subtle);
  }
  .v2-chapter__title {
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.06;
    color: var(--v2-fg);
    margin: 0;
    max-width: 26ch;
    overflow-wrap: anywhere;
  }
  .v2-chapter__body {
    font-size: clamp(15px, 1.3vw, 17px);
    line-height: 1.6;
    color: var(--v2-muted);
    max-width: 44rem;
    margin: 0;
  }

  /* Chapter accent — drives bloom hue + numeral pill color */
  .v2-chapter[data-accent="performance"] { --v2-accent: var(--v2-performance); --v2-accent-deep: var(--v2-performance-deep); }
  .v2-chapter[data-accent="violet"]      { --v2-accent: var(--v2-violet);      --v2-accent-deep: var(--v2-violet-deep); }
  .v2-chapter[data-accent="warm"]        { --v2-accent: var(--v2-warm);        --v2-accent-deep: var(--v2-warm-deep); }

  /* ============================================================
     Chapter 01 — Platform & Channel split
     ============================================================ */
  .v2-split {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 32px;
    align-items: stretch;
  }
  .v2-card {
    display: flex;
    flex-direction: column;
    gap: 16px;
    background: var(--v2-card);
    border: 1px solid var(--v2-line);
    border-radius: 20px;
    padding: 28px;
    backdrop-filter: blur(20px) saturate(140%);
    -webkit-backdrop-filter: blur(20px) saturate(140%);
    min-width: 0;
  }
  .v2-card__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  .v2-card__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin: 0;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--v2-accent);
  }
  .v2-where {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 12px;
    border: 1px solid var(--v2-line);
    border-radius: 999px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10.5px;
    color: var(--v2-subtle);
  }
  .v2-where__dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--v2-electric);
    box-shadow: 0 0 0 3px rgba(45, 127, 249, 0.18);
  }
  .v2-where__dot--green {
    background: var(--v2-performance);
    box-shadow: 0 0 0 3px rgba(39, 215, 161, 0.18);
  }
  .v2-card__caption {
    margin: 0;
    padding-top: 16px;
    border-top: 1px solid var(--v2-line);
    font-size: 13px;
    line-height: 1.55;
    color: var(--v2-muted);
  }
  .v2-wa-mini {
    display: inline-flex;
    color: var(--v2-performance);
  }

  /* Dash mock */
  .v2-dash {
    background: var(--v2-card-2);
    border: 1px solid var(--v2-line);
    border-radius: 14px;
    overflow: hidden;
  }
  .v2-dash__chrome {
    padding: 10px 16px;
