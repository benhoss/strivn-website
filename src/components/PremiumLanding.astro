        { threshold: [0.25, 0.5, 0.75], rootMargin: '-20% 0% -20% 0%' }
      );
      chapterEls.forEach((c) => chapterIO.observe(c));
    }

    // ============================================================
    // Hero holistic proof — Three.js living hub with static fallback
    // ============================================================
    (function holisticHero() {
      const host = document.getElementById('v2-holistic') as HTMLElement | null;
      const canvas = document.getElementById('v2-holistic-canvas') as HTMLCanvasElement | null;
      if (!host) return;
      const moduleEls = Array.from(host.querySelectorAll<HTMLElement>('[data-holistic-module]'));
      moduleEls[0]?.classList.add('is-active');
      if (!canvas || reduced || window.innerWidth < 721) return;

      let started = false;
      let setVisible: ((visible: boolean) => void) | null = null;

      const startScene = async () => {
        if (started) return;
        started = true;
        let THREE: typeof import('three');
        try { THREE = await import('three'); } catch (err) { canvas.style.display = 'none'; return; }

        let renderer: import('three').WebGLRenderer;
