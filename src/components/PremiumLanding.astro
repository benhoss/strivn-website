---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from './SiteHeader.astro';
import SiteFooter from './SiteFooter.astro';
import { landingContent, APP_URL, type Locale } from '../data/landingContent';

interface Props {
  locale: Locale;
  /** Canonical path (e.g. '/fr/') forwarded to BaseLayout. */
  canonicalPath?: string;
  /** Hreflang alternates forwarded to BaseLayout. */
  alternates?: Array<{ hreflang: string; href: string }>;
}

const { locale, canonicalPath, alternates } = Astro.props;
const c = landingContent[locale];

/**
 * Scattered start positions for the six chaos fragments, in stage
 * coordinates. Order matches both c.hero.stage.fragments and the panel
 * rows — fragment i converges into row i.
 */
const fragPositions = [
  { x: '-2%', y: '-3%', r: '-5deg' },
  { x: '56%', y: '2%', r: '3deg' },
  { x: '52%', y: '88%', r: '4deg' },
  { x: '0%', y: '92%', r: '-3deg' },
  { x: '-7%', y: '44%', r: '2deg' },
  { x: '62%', y: '40%', r: '-4deg' },
];

const skipLabel =
  locale === 'fr' ? 'Aller au contenu' : locale === 'nl' ? 'Naar de inhoud' : locale === 'de' ? 'Zum Inhalt springen' : 'Skip to content';
---

<BaseLayout
  lang={locale}
  title={c.meta.title}
  description={c.meta.description}
  canonicalPath={canonicalPath}
  alternates={alternates}
>
  <a href="#s-main" class="s-skip">{skipLabel}</a>

  <SiteHeader locale={locale} links={c.nav.links} cta={c.nav.cta} />

  <main id="s-main">
    <!-- ───────────── Hero · H2 split diptych + convergence ───────────── -->
    <section class="s-hero">
      <div class="s-wrap s-hero__grid">
        <div>
          <p class="s-hero__claim">{c.hero.claim}</p>
          <h1 class="s-display s-hero__title">
            <span class="s-hero__title-muted">{c.hero.title}</span>
            <span class="s-hero__title-main">{c.hero.titleAccent}</span>
          </h1>
          <p class="s-lede s-hero__lede">{c.hero.lede}</p>
          <div class="s-hero__actions">
            <a href={APP_URL} target="_blank" rel="noopener" class="s-btn s-btn--primary">{c.hero.primaryCta}</a>
            <a href="#platform" class="s-btn s-btn--ghost">{c.hero.secondaryCta}</a>
          </div>
          <span class="s-label s-hero__reassurance">{c.hero.reassurance}</span>
        </div>

        <div class="s-stage" id="s-stage" data-stage-label={c.hero.stage.ariaLabel}>
          {c.hero.stage.fragments.map((frag, i) => (
            <div
              class={`s-frag s-frag--${frag.kind}`}
              data-frag
              aria-hidden="true"
              style={`--fx: ${fragPositions[i].x}; --fy: ${fragPositions[i].y}; --fr: ${fragPositions[i].r}; --fi: ${i};`}
            >
              <span class="s-frag__inner">
                <span class="s-frag__source">{frag.source}</span>
                <span class="s-frag__text">{frag.text}</span>
              </span>
            </div>
          ))}

          <div class="s-panel">
            <div class="s-panel__head">
              <span class="s-panel__title">{c.hero.stage.panel.header}</span>
              <span class="s-panel__status" data-status>{c.hero.stage.panel.status}</span>
            </div>
            <ul class="s-panel__rows">
              {c.hero.stage.panel.rows.map((row) => (
                <li class="s-panel__row" data-row>
                  <span class="s-panel__row-label">{row.label}</span>
                  <span class="s-panel__row-value">{row.value}</span>
                  <span class={`s-panel__dot s-panel__dot--${row.tone}`} aria-hidden="true"></span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ───────────── Product overview · self-hosted video ───────────── -->
    <section class="s-overview" id="overview">
      <div class="s-wrap s-overview__inner" data-reveal>
        <p class="s-label s-overview__eyebrow">{c.overview.eyebrow}</p>
        <h2 class="s-headline s-overview__title">{c.overview.title}</h2>
        <p class="s-lede s-overview__sub">{c.overview.sub}</p>

        <figure class="s-overview__frame" data-reveal style="--d: 120ms;">
          <video
            class="s-overview__video"
            data-overview-video
            preload="none"
            playsinline
            poster={c.overview.poster}
            aria-label={c.overview.ariaLabel}
          >
            <source src={c.overview.srcMp4} type="video/mp4" />
          </video>
          <button class="s-overview__play" type="button" data-overview-play aria-label={c.overview.playLabel}>
            <span class="s-overview__play-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M8 5.5v13l11-6.5L8 5.5Z" fill="currentColor" />
              </svg>
            </span>
            <span class="s-overview__play-meta">
              <span class="s-overview__play-label">{c.overview.playLabel}</span>
              <span class="s-overview__play-time">{c.overview.duration}</span>
            </span>
          </button>
        </figure>
      </div>
    </section>

    <!-- ───────────── The reality ───────────── -->
    <section class="s-reality">
      <div class="s-wrap s-reality__grid">
        <div data-reveal>
          <h2 class="s-headline">{c.reality.title}</h2>
          <p class="s-lede s-reality__body">{c.reality.body}</p>
        </div>
        <div data-reveal style="--d: 120ms;">
          <ul class="s-reality__chips">
            {c.reality.scattered.map((item) => (
              <li class="s-reality__chip">{item}</li>
            ))}
          </ul>
          <p class="s-reality__resolve">{c.reality.resolve}</p>
        </div>
      </div>
    </section>

    <!-- ───────────── Platform · Split Studio diptychs ───────────── -->
    <div class="s-platform" id="platform">
      <div class="s-wrap">
        <!-- Communication -->
        <section class="s-diptych">
          <div class="s-diptych__text" data-reveal>
            <h2 class="s-headline">{c.communication.title}</h2>
            <p class="s-lede s-diptych__body">{c.communication.body}</p>
            <ul class="s-points">
              {c.communication.points.map((point) => <li>{point}</li>)}
            </ul>
          </div>
          <div class="s-diptych__proof" data-reveal style="--d: 120ms;">
            <div class="s-proof">
              <span class="s-label s-proof__label">{c.communication.proof.messageLabel}</span>
              <p class="s-flow__msg">
                {c.communication.proof.message}
                <span class="s-flow__link">{c.communication.proof.link}</span>
              </p>
              <ul class="s-flow__replies" aria-label={c.communication.proof.repliesLabel}>
                {c.communication.proof.replies.map((reply) => (
                  <li class="s-flow__reply">
                    <span class="s-flow__name">{reply.name}</span>
                    <span class={`s-flow__answer ${reply.tone === 'watch' ? 's-flow__answer--watch' : ''}`}>{reply.answer}</span>
                  </li>
                ))}
              </ul>
              <p class="s-flow__tally">{c.communication.proof.tally}</p>
            </div>
          </div>
        </section>

        <!-- Medical -->
        <section class="s-diptych s-diptych--flip">
          <div class="s-diptych__text" data-reveal>
            <h2 class="s-headline">{c.medical.title}</h2>
            <p class="s-lede s-diptych__body">{c.medical.body}</p>
            <ul class="s-points">
              {c.medical.points.map((point) => <li>{point}</li>)}
            </ul>
          </div>
          <div class="s-diptych__proof" data-reveal style="--d: 120ms;">
            <div class="s-proof">
              <div class="s-record__head">
                <p>
                  <span class="s-record__player">{c.medical.record.player}</span>
                  <span class="s-record__injury">{c.medical.record.injury}</span>
                </p>
                <span class="s-record__since">{c.medical.record.since}</span>
              </div>
              <ul class="s-record__stages">
                {c.medical.record.stages.map((stage) => (
                  <li class={`s-record__stage s-record__stage--${stage.state}`}>
                    <span class="s-record__stage-bar" aria-hidden="true"></span>
                    <span class="s-record__stage-label">{stage.label}</span>
                  </li>
                ))}
              </ul>
              <ul class="s-record__notes">
                {c.medical.record.notes.map((note) => (
                  <li class="s-record__note">
                    <span class="s-record__note-author">{note.author}</span>
                    <span class="s-record__note-role">{note.role}</span>
                    <span class="s-record__note-text">{note.text}</span>
                  </li>
                ))}
              </ul>
              <p class="s-record__return">
                <span class="s-label">{c.medical.record.returnLabel}</span>
                <span class="s-record__return-value">{c.medical.record.returnValue}</span>
              </p>
            </div>
          </div>
        </section>

        <!-- Load -->
        <section class="s-diptych">
          <div class="s-diptych__text" data-reveal>
            <h2 class="s-headline">{c.load.title}</h2>
            <p class="s-lede s-diptych__body">{c.load.body}</p>
            <ul class="s-points">
              {c.load.points.map((point) => <li>{point}</li>)}
            </ul>
          </div>
          <div class="s-diptych__proof" data-reveal style="--d: 120ms;">
            <div class="s-proof">
              <table class="s-table">
                <caption>
                  <span class="s-label">{c.load.table.title} · {c.load.table.week}</span>
                </caption>
                <thead>
                  <tr>
                    <th scope="col">{c.load.table.colPlayer}</th>
                    <th scope="col" data-num>{c.load.table.colMon}</th>
                    <th scope="col" data-num>{c.load.table.colWed}</th>
                    <th scope="col" data-num>{c.load.table.colFri}</th>
                    <th scope="col" data-num>{c.load.table.colAcwr}</th>
                    <th scope="col">{c.load.table.colState}</th>
                  </tr>
                </thead>
                <tbody>
                  {c.load.table.players.map((player) => (
                    <tr>
                      <td>{player.name}</td>
                      <td data-num>{player.mon}</td>
                      <td data-num>{player.wed}</td>
                      <td data-num>{player.fri}</td>
                      <td data-num>{player.acwr}</td>
                      <td>
                        <span class={`s-zone s-zone--${player.zone}`}>
                          {player.zone === 'green' ? c.load.table.pillOk : player.zone === 'amber' ? c.load.table.pillWatch : c.load.table.pillRisk}
                        </span>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
              <p class="s-table__tip">
                <strong>{c.load.table.tipLabel}</strong>
                {c.load.table.tip}
              </p>
            </div>
          </div>
        </section>

        <!-- Sessions -->
        <section class="s-diptych s-diptych--flip">
          <div class="s-diptych__text" data-reveal>
            <h2 class="s-headline">{c.sessions.title}</h2>
            <p class="s-lede s-diptych__body">{c.sessions.body}</p>
            <ul class="s-points">
              {c.sessions.points.map((point) => <li>{point}</li>)}
            </ul>
          </div>
          <div class="s-diptych__proof" data-reveal style="--d: 120ms;">
            <div class="s-proof">
              <div class="s-board__head">
                <p>
                  <span class="s-board__title">{c.sessions.board.title}</span>
                  <span class="s-board__meta">{c.sessions.board.meta}</span>
                </p>
                <span class="s-board__stamp">{c.sessions.board.stamp}</span>
              </div>
              <ol class="s-board__phases">
                {c.sessions.board.phases.map((phase) => (
                  <li class="s-board__phase">
                    <p>
                      <span class="s-board__phase-label">{phase.label}</span>
                      <span class="s-board__phase-detail">{phase.detail}</span>
                    </p>
                  </li>
                ))}
              </ol>
            </div>
          </div>
        </section>
      </div>
    </div>

    <!-- ───────────── Capabilities index ───────────── -->
    <section class="s-capabilities">
      <div class="s-wrap">
        <div class="s-capabilities__head" data-reveal>
          <h2 class="s-headline">{c.capabilities.title}</h2>
          <p class="s-lede s-capabilities__body">{c.capabilities.body}</p>
        </div>
        <ul class="s-capabilities__grid">
          {c.capabilities.items.map((item) => (
            <li class="s-capabilities__item">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ───────────── Player app ───────────── -->
    <section class="s-player">
      <div class="s-wrap s-player__grid">
        <div data-reveal>
          <h2 class="s-headline">{c.playerApp.title}</h2>
          <p class="s-lede s-player__body">{c.playerApp.body}</p>
          <span class="s-label">{c.playerApp.stores}</span>
        </div>
        <figure class="s-player__figure" data-reveal style="--d: 120ms;">
          <img
            src="/screenshots/player-app-agenda.png"
            alt={c.playerApp.imageAlt}
            width="500"
            height="932"
            loading="lazy"
            decoding="async"
          />
        </figure>
      </div>
    </section>

    <!-- ───────────── Time saved ───────────── -->
    <section class="s-time">
      <div class="s-wrap s-time__grid">
        <div data-reveal>
          <h2 class="s-headline">{c.timeSaved.title}</h2>
          <p class="s-lede s-time__body">{c.timeSaved.body}</p>
        </div>
        <ul class="s-time__rows" data-reveal style="--d: 120ms;">
          {c.timeSaved.rows.map((row) => (
            <li class="s-time__row">
              <span>{row.task}</span>
              <span class="s-time__outcome">{row.outcome}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ───────────── Pricing ───────────── -->
    <section class="s-pricing" id="pricing">
      <div class="s-wrap">
        <div class="s-pricing__head" data-reveal>
          <h2 class="s-headline">{c.pricing.title}</h2>
          <p class="s-lede s-pricing__body">{c.pricing.body}</p>
        </div>
        <div class="s-pricing__grid">
          {c.pricing.plans.map((plan) => (
            <article class={`s-plan ${plan.featured ? 's-plan--featured' : ''}`}>
              <div class="s-plan__top">
                <h3 class="s-plan__name">{plan.name}</h3>
                <span class="s-plan__availability">{plan.availability}</span>
              </div>
              <p class="s-plan__description">{plan.description}</p>
              <p class="s-plan__price">
                {plan.price}
                {plan.period && <span class="s-plan__period">{plan.period}</span>}
              </p>
              <ul class="s-plan__features">
                {plan.features.map((feature) => <li>{feature}</li>)}
              </ul>
              {plan.featured ? (
                <a href={APP_URL} target="_blank" rel="noopener" class="s-btn s-btn--primary">{plan.cta}</a>
              ) : (
                <a href={`mailto:${c.footer.email}?subject=${encodeURIComponent(`STRIVN ${plan.name}`)}`} class="s-btn s-btn--ghost">{plan.cta}</a>
              )}
            </article>
          ))}
        </div>
        <p class="s-pricing__note">{c.pricing.note}</p>
      </div>
    </section>

    <!-- ───────────── FAQ ───────────── -->
    <section class="s-faq" id="faq">
      <div class="s-wrap s-faq__grid">
        <div data-reveal>
          <h2 class="s-headline">{c.faq.title}</h2>
          <p class="s-lede s-faq__body">{c.faq.body}</p>
        </div>
        <div data-reveal style="--d: 120ms;">
          {c.faq.items.map((item) => (
            <details class="s-faq__item">
              <summary class="s-faq__q">{item.question}</summary>
              <p class="s-faq__a">{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ───────────── Final CTA ───────────── -->
    <section class="s-final">
      <div class="s-wrap s-final__inner" data-reveal>
        <h2 class="s-headline">{c.finalCta.title}</h2>
        <p class="s-lede s-final__body">{c.finalCta.body}</p>
        <div class="s-final__actions">
          <a href={APP_URL} target="_blank" rel="noopener" class="s-btn s-btn--primary">{c.finalCta.primaryCta}</a>
          <a href={c.finalCta.secondaryHref} class="s-final__secondary">{c.finalCta.secondaryCta}</a>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter locale={locale} footer={c.footer} />

  <script is:inline>
    // Before first paint: flag JS availability and arm the convergence
    // stage so fragments start scattered instead of flashing the settled
    // panel. Reduced-motion users keep the settled state.
    (function () {
      document.documentElement.classList.add('js-anim');
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      var stage = document.getElementById('s-stage');
      if (stage) {
        stage.classList.add('is-armed');
        stage.setAttribute('role', 'img');
        stage.setAttribute('aria-label', stage.getAttribute('data-stage-label') || '');
      }
    })();
  </script>

  <script>
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ── Hero convergence — the signature one-shot sequence ──
    const stage = document.getElementById('s-stage');
    if (stage && stage.classList.contains('is-armed') && !reduceMotion) {
      const frags = Array.from(stage.querySelectorAll<HTMLElement>('[data-frag]'));
      const rows = Array.from(stage.querySelectorAll<HTMLElement>('[data-row]'));
      const status = stage.querySelector<HTMLElement>('[data-status]');

      const run = () => {
        const stepMs = 190;
        frags.forEach((frag, i) => {
          const row = rows[i];
          if (!row) return;
          const fragRect = frag.getBoundingClientRect();
          const rowRect = row.getBoundingClientRect();
          frag.style.setProperty('--tx', `${rowRect.left + rowRect.width / 2 - (fragRect.left + fragRect.width / 2)}px`);
          frag.style.setProperty('--ty', `${rowRect.top + rowRect.height / 2 - (fragRect.top + fragRect.height / 2)}px`);
          setTimeout(() => {
            frag.classList.add('is-absorbed');
            setTimeout(() => row.classList.add('is-on'), 460);
          }, i * stepMs);
        });
        const total = frags.length * stepMs + 700;
        setTimeout(() => status?.classList.add('is-on'), total);
        setTimeout(() => stage.classList.add('is-settled'), total + 700);
      };

      const arm = () => {
        const io = new IntersectionObserver(
          (entries) => {
            if (entries.some((entry) => entry.isIntersecting)) {
              io.disconnect();
              setTimeout(run, 1100);
            }
          },
          { threshold: 0.35 },
        );
        io.observe(stage);
      };

      // Wait for web fonts so fragment/row geometry is final before
      // measuring convergence deltas.
      if (document.fonts?.ready) {
        document.fonts.ready.then(arm);
      } else {
        arm();
      }
    }

    // ── Reveal-once cross-fade (Split Studio) ──
    const revealTargets = document.querySelectorAll('[data-reveal]');
    if (reduceMotion || !('IntersectionObserver' in window)) {
      revealTargets.forEach((el) => el.classList.add('is-in'));
    } else {
      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-in');
              revealObserver.unobserve(entry.target);
            }
          });
        },
        { rootMargin: '0px 0px -8% 0px' },
      );
      revealTargets.forEach((el) => revealObserver.observe(el));
    }

    // ── Product overview · click-to-play facade ──
    // preload="none" keeps the ~5 MB MP4 off the critical path; the poster
    // button only triggers the network fetch on intent.
    const overviewVideo = document.querySelector<HTMLVideoElement>('[data-overview-video]');
    const overviewPlay = document.querySelector<HTMLButtonElement>('[data-overview-play]');
    if (overviewVideo && overviewPlay) {
      overviewPlay.addEventListener('click', () => {
        overviewVideo.controls = true;
        overviewVideo.play();
      });
      // Hide the facade once playback begins, keep native controls available.
      overviewVideo.addEventListener('play', () => {
        overviewVideo.controls = true;
        overviewPlay.setAttribute('hidden', '');
      });
    }
  </script>
</BaseLayout>
