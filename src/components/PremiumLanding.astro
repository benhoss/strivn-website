---
import BaseLayout from '../layouts/BaseLayout.astro';
import { landingContent, type Locale } from '../data/landingContent';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const c = landingContent[locale];
const isFrench = locale === 'fr';
const APP_URL = 'https://app.strivn.net';

const WA = `<path d="M16.6 14.2c-.3-.1-1.6-.8-1.9-.9-.2-.1-.4-.1-.6.1-.2.2-.7.8-.8.9-.1.1-.3.2-.5 0-.3-.1-1.1-.4-2.1-1.3-.8-.7-1.3-1.5-1.5-1.8-.1-.3 0-.4.1-.6l.4-.4.2-.3c0-.1.1-.2 0-.4 0-.1-.5-1.4-.8-1.8-.2-.5-.4-.4-.5-.4h-.5c-.2 0-.4.1-.7.3-.2.2-.9.9-.9 2.2 0 1.3.9 2.6 1.1 2.7.1.2 1.9 2.9 4.6 4 2.2.9 2.7.7 3.2.7.5-.1 1.6-.6 1.8-1.3.2-.6.2-1.2.2-1.3-.1-.1-.2-.2-.5-.3zM12 3a9 9 0 0 0-7.6 13.8L3 21l4.4-1.2A9 9 0 1 0 12 3z"/>`;

const pillarAccents = ['electric', 'performance', 'violet', 'warm'];

const chapters = [
  { id: 'reality',  n: '01', label: c.nav.reality },
  { id: 'staff',    n: '02', label: c.nav.staff },
  { id: 'whatsapp', n: '03', label: c.nav.whatsapp },
  { id: 'medical',  n: '04', label: c.nav.medical },
  { id: 'sessions', n: '05', label: c.nav.sessions },
  { id: 'pricing',  n: '06', label: c.nav.pricing },
];
---

<BaseLayout lang={locale} title={c.meta.title} description={c.meta.description}>
  <main class="v2" id="v2-top">
    <!-- Fixed ambient layers — never block content -->
    <div class="v2-ambient" aria-hidden="true">
      <canvas class="v2-paint" id="v2-paint"></canvas>
      <div class="v2-noise"></div>
      <div class="v2-bloom v2-bloom--a"></div>
      <div class="v2-bloom v2-bloom--b"></div>
      <div class="v2-cursor"></div>
    </div>

    <!-- Top bar -->
    <header class="v2-topbar">
      <a href="#v2-top" class="v2-brand v2-brand--compact" aria-label="STRIVN">
        <img src="/strivn-logo-full-white-web.png" alt="STRIVN" width="120" height="80" />
      </a>
      <nav class="v2-nav" aria-label="Primary">
        {chapters.map((ch) => (
          <a href={`#v2-${ch.id}`} class="v2-nav__link">
            <span class="v2-nav__n">{ch.n}</span>
            <span class="v2-nav__label">{ch.label}</span>
          </a>
        ))}
      </nav>
      <div class="v2-topbar__end">
        <div class="v2-lang" role="group" aria-label={isFrench ? 'Changer la langue' : 'Switch language'}>
          <a href="/fr/" class:list={['v2-lang__opt', isFrench && 'is-active']} aria-current={isFrench ? 'page' : undefined}>FR</a>
          <span class="v2-lang__sep" aria-hidden="true">·</span>
          <a href="/en/" class:list={['v2-lang__opt', !isFrench && 'is-active']} aria-current={!isFrench ? 'page' : undefined}>EN</a>
        </div>
        <a href={APP_URL} target="_blank" rel="noopener" class="v2-cta-mini">{c.ctaMini}</a>
      </div>
    </header>

    <!-- ─────────────────────────────── HERO ─────────────────────────────── -->
    <section class="v2-hero">
      <a href="#v2-top" class="v2-hero__logo v2-reveal" data-reveal aria-label="STRIVN">
        <img src="/strivn-logo-full-white-web.png" alt="STRIVN" width="480" height="320" />
      </a>
      <h1 class="v2-hero__title">
        <span class="v2-hero__title-1 v2-words" data-words>{c.hero.title}</span>
        <span class="v2-hero__title-2 v2-words" data-words data-words-delay="450">{c.hero.titleAccent}</span>
      </h1>
      <p class="v2-hero__lede v2-reveal" data-reveal data-delay="1000">{c.hero.body}</p>
      <div class="v2-hero__actions v2-reveal" data-reveal data-delay="1200">
        <a href={APP_URL} target="_blank" rel="noopener" class="v2-btn v2-btn--primary">{c.hero.primaryCta}</a>
        <a href="#v2-reality" class="v2-btn v2-btn--ghost">{c.hero.secondaryCta}</a>
      </div>

      <!-- Hero device — 4-pane sequencer (delegate → prepare → approve → players answer) -->
      <div class="v2-device" id="v2-device" aria-label="STRIVN demo">
        <div class="v2-device__chrome" aria-hidden="true">
          <span class="v2-device__dot"></span>
          <span class="v2-device__dot"></span>
          <span class="v2-device__dot"></span>
          <span class="v2-device__url">{c.hero.device.url}</span>
        </div>
        <div class="v2-device__viewport">
          <div class="v2-device__track" id="v2-device-track">
            <!-- 01 · delegate -->
            <article class="v2-pane is-active" data-pane-step="1">
              <header class="v2-pane__head">
                <span class="v2-pane__n">01</span>
                <span class="v2-pane__label">{c.hero.device.step1.label}</span>
              </header>
              <p class="v2-pane__quote" data-v2-typing data-v2-typing-start="320" data-v2-typing-speed="20">{c.hero.device.step1.quote}</p>
              <p class="v2-pane__echo">{c.hero.device.step1.echo}</p>
            </article>

            <!-- 02 · prepare -->
            <article class="v2-pane" data-pane-step="2">
              <header class="v2-pane__head">
                <span class="v2-pane__n">02</span>
                <span class="v2-pane__label">{c.hero.device.step2.label}</span>
              </header>
              <div class="v2-pills">
                {c.hero.device.step2.pills.map((p) => <span class="v2-pill v2-pill--info">{p}</span>)}
              </div>
              <p class="v2-pane__explain">{c.hero.device.step2.explain}</p>
              <ul class="v2-pane__list">
                {c.hero.device.step2.list.map((line, i) => <li style={`--v2-li: ${i};`}>{line}</li>)}
              </ul>
            </article>

            <!-- 03 · approve -->
            <article class="v2-pane" data-pane-step="3">
              <header class="v2-pane__head">
                <span class="v2-pane__n">03</span>
                <span class="v2-pane__label">{c.hero.device.step3.label}</span>
                <span class="v2-pane__badge">{c.hero.device.step3.badge}</span>
              </header>
              <h3 class="v2-pane__title">{c.hero.device.step3.title}</h3>
              <div class="v2-pane__metrics">
                {c.hero.device.step3.metrics.map((m, i) => (
                  <div class="v2-pane__metric" style={`--v2-li: ${i};`}>
                    <span class="v2-pane__metric-l">{m.label}</span>
                    <span class="v2-pane__metric-v">{m.value}</span>
                  </div>
                ))}
              </div>
              <div class="v2-pane__cta">
                <span class="v2-pane__btn v2-pane__btn--primary">{c.hero.device.step3.approve}</span>
                <span class="v2-pane__btn v2-pane__btn--ghost">{c.hero.device.step3.reject}</span>
              </div>
            </article>

            <!-- 04 · players answer -->
            <article class="v2-pane v2-pane--player" data-pane-step="4">
              <header class="v2-pane__head">
                <span class="v2-pane__n">04</span>
                <span class="v2-pane__label">{c.hero.device.step4.label}</span>
              </header>
              <div class="v2-phone v2-phone--wa" aria-hidden="true">
                <div class="v2-phone__bar">
                  <span class="v2-phone__time">{c.hero.device.step4.phoneTime}</span>
                  <span class="v2-phone__dots"><span></span><span></span><span></span></span>
                </div>
                <div class="v2-phone__head">
                  <span class="v2-phone__avatar">{c.hero.device.step4.phoneAvatar}</span>
                  <div class="v2-phone__id">
                    <span class="v2-phone__name">{c.hero.device.step4.phoneName}</span>
                    <span class="v2-phone__sub">{c.hero.device.step4.phoneSub}</span>
                  </div>
                  <span class="v2-phone__wa"><svg viewBox="0 0 24 24" width="11" height="11" fill="currentColor" set:html={WA} /></span>
                </div>
                <div class="v2-phone__chat">
                  {c.hero.device.step4.bubbles.map((b, i) => (
                    <div class={`v2-bubble v2-bubble--${b.direction}`} style={`--v2-bi: ${i};`}>
                      <p>{b.text}</p>
                      <span class="v2-bubble__time">{b.time}</span>
                    </div>
                  ))}
                  <div class="v2-wellness" style="--v2-bi: 4;">
                    <span class="v2-wellness__l">{c.hero.device.step4.wellness.label}</span>
                    <span class="v2-wellness__v">{c.hero.device.step4.wellness.value}</span>
                    <span class="v2-wellness__n">{c.hero.device.step4.wellness.note}</span>
                  </div>
                </div>
              </div>
            </article>
          </div>
        </div>

        <nav class="v2-device__dots" aria-label="Demo steps">
          {[0, 1, 2, 3].map((i) => (
            <button type="button" class={`v2-device__dot-btn${i === 0 ? ' is-active' : ''}`} data-pane-go={i} aria-label={`Step ${i + 1}`}></button>
          ))}
        </nav>
      </div>

      <div class="v2-scroll-cue v2-reveal" data-reveal data-delay="1800" aria-hidden="true">
        <span class="v2-scroll-cue__label">{isFrench ? 'Faire défiler' : 'Scroll'}</span>
        <span class="v2-scroll-cue__line"></span>
      </div>
    </section>

    <!-- ─────────────────── 01 · LA RÉALITÉ ─────────────────── -->
    <section class="v2-chapter" id="v2-reality" data-accent="warm">
      <div class="v2-chapter__head">
        <span class="v2-chapter__n v2-reveal" data-reveal>01</span>
        <p class="v2-chapter__eyebrow v2-reveal" data-reveal data-delay="80">{c.reality.eyebrow}</p>
        <h2 class="v2-chapter__title v2-words" data-words>{c.reality.title}</h2>
        <p class="v2-chapter__body v2-reveal" data-reveal data-delay="600">{c.reality.body}</p>
      </div>

      <div class="v2-reality">
        <ul class="v2-tasks v2-reveal" data-reveal data-delay="100">
          {c.reality.tasks.map((t, i) => (
            <li class="v2-task" style={`--v2-li: ${i};`}>
              <span class="v2-task__tick" aria-hidden="true"></span>
              <span>{t}</span>
            </li>
          ))}
        </ul>

        <div class="v2-phone v2-phone--chaos v2-reveal" data-reveal data-delay="200">
          <div class="v2-phone__bar">
            <span class="v2-phone__time">{c.reality.phone.time}</span>
            <span class="v2-phone__dots"><span></span><span></span><span></span></span>
          </div>
          <div class="v2-phone__head">
            <span class="v2-phone__avatar v2-phone__avatar--group" aria-hidden="true"></span>
            <div class="v2-phone__id">
              <span class="v2-phone__name">{c.reality.phone.name}</span>
              <span class="v2-phone__sub v2-phone__sub--muted">{c.reality.phone.sub}</span>
            </div>
            <span class="v2-phone__wa"><svg viewBox="0 0 24 24" width="11" height="11" fill="currentColor" set:html={WA} /></span>
          </div>
          <div class="v2-phone__chat">
            {c.reality.phone.bubbles.map((b, i) => (
              <div class={`v2-bubble v2-bubble--in${b.unread ? ' is-unread' : ''}`} style={`--v2-bi: ${i};`}>
                <p>{b.text}</p>
                <span class="v2-bubble__time">{b.time}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <div class="v2-resolve v2-reveal" data-reveal data-delay="150">
        <span class="v2-resolve__mark" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </span>
        <p><strong>{c.reality.resolve.lead}</strong> {c.reality.resolve.line}</p>
      </div>
    </section>

    <!-- ─────────────────── 02 · LE STAFF VIRTUEL ─────────────────── -->
    <section class="v2-chapter" id="v2-staff" data-accent="electric">
      <div class="v2-chapter__head">
        <span class="v2-chapter__n v2-reveal" data-reveal>02</span>
        <p class="v2-chapter__eyebrow v2-reveal" data-reveal data-delay="80">{c.staff.eyebrow}</p>
        <h2 class="v2-chapter__title v2-words" data-words>{c.staff.title}</h2>
        <p class="v2-chapter__body v2-reveal" data-reveal data-delay="600">{c.staff.body}</p>
      </div>

      <div class="v2-pillars">
        {c.staff.pillars.map((p, i) => (
          <article class="v2-pillar v2-reveal" data-reveal data-delay={i * 90} data-accent={pillarAccents[i]}>
            <header class="v2-pillar__head">
              <span class="v2-pillar__dot" aria-hidden="true"></span>
              <span class="v2-pillar__tag">{p.tag}</span>
            </header>
            <h3 class="v2-pillar__name">{p.name}</h3>
            <p class="v2-pillar__role">{p.role}</p>
            <ul class="v2-pillar__does">
              {p.does.map((d) => <li>{d}</li>)}
            </ul>
          </article>
        ))}
      </div>

      <div class="v2-ba v2-reveal" data-reveal data-delay="150">
        <div class="v2-ba__head">
          <span class="v2-ba__eyebrow">{c.staff.beforeAfter.eyebrow}</span>
          <div class="v2-ba__labels">
            <span class="v2-ba__label v2-ba__label--before">{c.staff.beforeAfter.beforeLabel}</span>
            <span class="v2-ba__label v2-ba__label--after">{c.staff.beforeAfter.afterLabel}</span>
          </div>
        </div>
        <ul class="v2-ba__rows">
          {c.staff.beforeAfter.rows.map((row) => (
            <li class="v2-ba__row">
              <span class="v2-ba__task">{row.task}</span>
              <span class="v2-ba__before">{row.before}</span>
              <span class="v2-ba__after">
                <span class="v2-ba__arrow" aria-hidden="true">→</span>
                {row.after}
              </span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ─────────────────── 03 · WHATSAPP ─────────────────── -->
    <section class="v2-chapter" id="v2-whatsapp" data-accent="performance">
      <div class="v2-chapter__head">
        <span class="v2-chapter__n v2-reveal" data-reveal>03</span>
        <p class="v2-chapter__eyebrow v2-reveal" data-reveal data-delay="80">{c.whatsapp.eyebrow}</p>
        <h2 class="v2-chapter__title v2-words" data-words>{c.whatsapp.title}</h2>
        <p class="v2-chapter__body v2-reveal" data-reveal data-delay="600">{c.whatsapp.body}</p>
      </div>

      <div class="v2-wa-layout">
        <div class="v2-wa-steps v2-reveal" data-reveal data-delay="100">
          <ol>
            {c.whatsapp.steps.map((s, i) => (
              <li class="v2-wa-step" style={`--v2-li: ${i};`}>
                <span class="v2-wa-step__n">{s.n}</span>
                <span class="v2-wa-step__text">{s.text}</span>
              </li>
            ))}
          </ol>
          <div class="v2-noapp">
            {c.whatsapp.noapp.map((n) => (
              <span class="v2-noapp__chip">
                <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><line x1="5" y1="5" x2="19" y2="19"/><line x1="19" y1="5" x2="5" y2="19"/></svg>
                {n}
              </span>
            ))}
          </div>
          <p class="v2-wa-caption">{c.whatsapp.caption}</p>
        </div>

        <div class="v2-phone v2-phone--wa v2-phone--lg v2-reveal" data-reveal data-delay="200">
          <div class="v2-phone__bar">
            <span class="v2-phone__time">{c.whatsapp.phone.time}</span>
            <span class="v2-phone__dots"><span></span><span></span><span></span></span>
          </div>
          <div class="v2-phone__head">
            <span class="v2-phone__avatar">S</span>
            <div class="v2-phone__id">
              <span class="v2-phone__name">{c.whatsapp.phone.name}</span>
              <span class="v2-phone__sub">{c.whatsapp.phone.sub}</span>
            </div>
            <span class="v2-phone__wa"><svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor" set:html={WA} /></span>
          </div>
          <div class="v2-phone__chat">
            {c.whatsapp.phone.bubbles.map((b, i) => (
              <div class={`v2-bubble v2-bubble--${b.direction}`} style={`--v2-bi: ${i};`}>
                <p>{b.text}</p>
                <span class="v2-bubble__time">{b.time}</span>
              </div>
            ))}
            <div class="v2-wellness" style="--v2-bi: 4;">
              <span class="v2-wellness__l">{c.whatsapp.phone.wellness.label}</span>
              <span class="v2-wellness__v">{c.whatsapp.phone.wellness.value}</span>
              <span class="v2-wellness__n">{c.whatsapp.phone.wellness.note}</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─────────────────── 04 · LE MÉDICAL ─────────────────── -->
    <section class="v2-chapter" id="v2-medical" data-accent="violet">
      <div class="v2-chapter__head">
        <span class="v2-chapter__n v2-reveal" data-reveal>04</span>
        <p class="v2-chapter__eyebrow v2-reveal" data-reveal data-delay="80">{c.medical.eyebrow}</p>
        <h2 class="v2-chapter__title v2-words" data-words>{c.medical.title}</h2>
        <p class="v2-chapter__body v2-reveal" data-reveal data-delay="600">{c.medical.body}</p>
      </div>

      <div class="v2-med">
        <ul class="v2-med__features v2-reveal" data-reveal data-delay="100">
          {c.medical.features.map((f, i) => (
            <li style={`--v2-li: ${i};`}>{f}</li>
          ))}
        </ul>

        <article class="v2-record v2-reveal" data-reveal data-delay="200">
          <header class="v2-record__head">
            <div class="v2-record__id">
              <span class="v2-record__avatar">{c.medical.record.player.split(' ').pop()?.[0]}</span>
              <div>
                <h3 class="v2-record__player">{c.medical.record.player}</h3>
                <p class="v2-record__injury">{c.medical.record.injury}</p>
              </div>
            </div>
            <span class="v2-record__since">{c.medical.record.since}</span>
          </header>

          <div class="v2-record__track" role="list">
            {c.medical.record.stages.map((s) => (
              <div class={`v2-stage is-${s.state}`} role="listitem">
                <span class="v2-stage__dot" aria-hidden="true"></span>
                <span class="v2-stage__label">{s.label}</span>
              </div>
            ))}
          </div>

          <div class="v2-record__notes">
            {c.medical.record.notes.map((note) => (
              <div class="v2-note">
                <div class="v2-note__meta">
                  <span class="v2-note__author">{note.author}</span>
                  <span class="v2-note__role">{note.role}</span>
                </div>
                <p class="v2-note__text">{note.text}</p>
              </div>
            ))}
          </div>

          <footer class="v2-record__foot">
            <span class="v2-record__foot-l">{c.medical.record.returnLabel}</span>
            <span class="v2-record__foot-v">{c.medical.record.returnValue}</span>
          </footer>
        </article>
      </div>
    </section>

    <!-- ─────────────────── 05 · LES SÉANCES ─────────────────── -->
    <section class="v2-chapter" id="v2-sessions" data-accent="electric">
      <div class="v2-chapter__head">
        <span class="v2-chapter__n v2-reveal" data-reveal>05</span>
        <p class="v2-chapter__eyebrow v2-reveal" data-reveal data-delay="80">{c.sessions.eyebrow}</p>
        <h2 class="v2-chapter__title v2-words" data-words>{c.sessions.title}</h2>
        <p class="v2-chapter__body v2-reveal" data-reveal data-delay="600">{c.sessions.body}</p>
      </div>

      <div class="v2-sessions">
        <ul class="v2-sessions__features v2-reveal" data-reveal data-delay="100">
          {c.sessions.features.map((f, i) => (
            <li style={`--v2-li: ${i};`}>
              <span class="v2-sessions__bullet" aria-hidden="true"></span>
              <span>{f}</span>
            </li>
          ))}
        </ul>

        <article class="v2-board v2-reveal" data-reveal data-delay="200">
          <div class="v2-board__pitch" aria-hidden="true">
            <svg viewBox="0 0 320 200" preserveAspectRatio="none">
              <rect x="1" y="1" width="318" height="198" rx="6" fill="none" stroke="currentColor" stroke-width="1" opacity="0.4"/>
              <line x1="160" y1="1" x2="160" y2="199" stroke="currentColor" stroke-width="1" opacity="0.3"/>
              <circle cx="160" cy="100" r="30" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3"/>
              <rect x="1" y="60" width="46" height="80" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3"/>
              <rect x="273" y="60" width="46" height="80" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3"/>
              <circle cx="90" cy="70" r="4" class="v2-board__token v2-board__token--a"/>
              <circle cx="110" cy="130" r="4" class="v2-board__token v2-board__token--a"/>
              <circle cx="70" cy="100" r="4" class="v2-board__token v2-board__token--a"/>
              <circle cx="200" cy="100" r="4" class="v2-board__token v2-board__token--b"/>
              <path d="M90 70 L150 95" stroke="currentColor" stroke-width="1.2" stroke-dasharray="3 3" class="v2-board__pass"/>
              <path d="M110 130 L150 105" stroke="currentColor" stroke-width="1.2" stroke-dasharray="3 3" class="v2-board__pass"/>
            </svg>
          </div>
          <header class="v2-board__head">
            <div>
              <p class="v2-board__eyebrow">{c.sessions.board.eyebrow}</p>
              <h3 class="v2-board__title">{c.sessions.board.title}</h3>
            </div>
            <span class="v2-board__stamp">{c.sessions.board.stamp}</span>
          </header>
          <ol class="v2-board__phases">
            {c.sessions.board.phases.map((ph, i) => (
              <li class="v2-board__phase" style={`--v2-li: ${i};`}>
                <span class="v2-board__phase-l">{ph.label}</span>
                <span class="v2-board__phase-d">{ph.detail}</span>
              </li>
            ))}
          </ol>
        </article>
      </div>
    </section>

    <!-- ─────────────────── LE TEMPS GAGNÉ ─────────────────── -->
    <section class="v2-chapter v2-chapter--time" data-accent="performance">
      <div class="v2-time">
        <div class="v2-time__lead">
          <p class="v2-chapter__eyebrow v2-reveal" data-reveal>{c.timeSaved.eyebrow}</p>
          <h2 class="v2-time__title v2-words" data-words>{c.timeSaved.title}</h2>
          <p class="v2-time__body v2-reveal" data-reveal data-delay="500">{c.timeSaved.body}</p>
          <div class="v2-time__stat v2-reveal" data-reveal data-delay="650">
            <span class="v2-time__stat-v">{c.timeSaved.stat}</span>
            <span class="v2-time__stat-l">{c.timeSaved.statLabel}</span>
          </div>
        </div>

        <div class="v2-time__breakdown v2-reveal" data-reveal data-delay="200">
          <ul>
            {c.timeSaved.breakdown.map((b, i) => (
              <li class="v2-time__row" style={`--v2-li: ${i};`}>
                <span class="v2-time__task">{b.task}</span>
                <span class="v2-time__hours">{b.hours}</span>
              </li>
            ))}
          </ul>
          <p class="v2-time__footer">{c.timeSaved.footer}</p>
        </div>
      </div>
    </section>

    <!-- ─────────────────── 06 · TARIFS ─────────────────── -->
    <section class="v2-chapter" id="v2-pricing" data-accent="electric">
      <div class="v2-chapter__head">
        <span class="v2-chapter__n v2-reveal" data-reveal>06</span>
        <p class="v2-chapter__eyebrow v2-reveal" data-reveal data-delay="80">{c.pricing.eyebrow}</p>
        <h2 class="v2-chapter__title v2-words" data-words>{c.pricing.title}</h2>
        <p class="v2-chapter__body v2-reveal" data-reveal data-delay="600">{c.pricing.body}</p>
      </div>

      <div class="v2-pricing v2-reveal" data-reveal data-delay="100">
        <div class="v2-plans" aria-label={c.pricing.eyebrow}>
          {c.pricing.plans.map((plan, i) => (
            <article class:list={['v2-plan', plan.badge && 'v2-plan--featured']} style={`--v2-li: ${i};`}>
              <div class="v2-plan__head">
                <div>
                  <h3 class="v2-plan__name">{plan.name}</h3>
                  <p class="v2-plan__description">{plan.description}</p>
                </div>
                {plan.badge && <span class="v2-plan__badge">{plan.badge}</span>}
              </div>
              <p class="v2-plan__price">
                <span>{plan.price}</span>
                <small>{plan.period}</small>
              </p>
              <p class="v2-plan__messages">{plan.messages}</p>
              <ul class="v2-plan__features">
                {plan.features.map((feature) => (
                  <li>
                    <span class="v2-plan__check" aria-hidden="true">
                      <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    </span>
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
        <div class="v2-addons">
          <p class="v2-addons__title">{c.pricing.addonsTitle}</p>
          <div class="v2-addons__list">
            {c.pricing.addons.map((addon) => (
              <div class="v2-addon">
                <span class="v2-addon__name">{addon.name}</span>
                <span class="v2-addon__messages">{addon.messages}</span>
                <span class="v2-addon__price">{addon.price}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="v2-pricing__footer">
          <a href={c.pricing.href} target="_blank" rel="noopener" class="v2-btn v2-btn--primary v2-btn--large v2-pricing__cta">{c.pricing.cta}</a>
          <p class="v2-pricing__note">{c.pricing.note}</p>
        </div>
      </div>
    </section>

    <!-- ─────────────────── FAQ ─────────────────── -->
    <section class="v2-chapter v2-chapter--faq" id="v2-faq" data-accent="electric">
      <div class="v2-chapter__head">
        <p class="v2-chapter__eyebrow v2-reveal" data-reveal>{c.faq.eyebrow}</p>
        <h2 class="v2-chapter__title v2-words" data-words>{c.faq.title}</h2>
        <p class="v2-chapter__body v2-reveal" data-reveal data-delay="600">{c.faq.body}</p>
      </div>
      <div class="v2-faq">
        {c.faq.items.map((q, i) => (
          <details class="v2-faq__item v2-reveal" data-reveal data-delay={i * 80}>
            <summary>
              <span>{q.question}</span>
              <span class="v2-faq__plus" aria-hidden="true">+</span>
            </summary>
            <p>{q.answer}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- ─────────────────── CTA ─────────────────── -->
    <section class="v2-chapter v2-chapter--cta" id="v2-contact" data-accent="electric">
      <div class="v2-cta">
        <p class="v2-chapter__eyebrow v2-reveal" data-reveal>{c.finalCta.eyebrow}</p>
        <h2 class="v2-cta__title v2-words" data-words>{c.finalCta.title}</h2>
        <p class="v2-cta__body v2-reveal" data-reveal data-delay="500">{c.finalCta.body}</p>
        <div class="v2-cta__actions v2-reveal" data-reveal data-delay="700">
          <a href={APP_URL} target="_blank" rel="noopener" class="v2-btn v2-btn--primary v2-btn--large">{c.finalCta.primaryCta}</a>
          <a href={c.finalCta.secondaryHref} class="v2-btn v2-btn--ghost">{c.finalCta.secondaryCta}</a>
        </div>
      </div>
    </section>

    <footer class="v2-footer">
      <div class="v2-footer__top">
        <div class="v2-footer__brand">
          <img src="/strivn-logo-full-white-web.png" alt="STRIVN" width="120" height="80" />
          <p>{c.footer.brandLine}</p>
          <a href={APP_URL} target="_blank" rel="noopener" class="v2-footer__cta">
            {c.ctaMini}
            <span class="v2-footer__cta-arrow" aria-hidden="true">→</span>
          </a>
        </div>

        <div class="v2-footer__col">
          <h4 class="v2-footer__h">{c.footer.productLabel}</h4>
          <ul>
            {c.footer.product.map((p) => <li><a href={p.href}>{p.label}</a></li>)}
          </ul>
        </div>

        <div class="v2-footer__col">
          <h4 class="v2-footer__h">{c.footer.staffLabel}</h4>
          <ul>
            {c.footer.staff.map((s) => <li><a href="#v2-staff">{s}</a></li>)}
          </ul>
        </div>

        <div class="v2-footer__col">
          <h4 class="v2-footer__h">{c.footer.contactLabel}</h4>
          <ul>
            <li><a href={`mailto:${c.footer.email}`}>{c.footer.email}</a></li>
            <li><a href={c.finalCta.secondaryHref}>{c.finalCta.secondaryCta}</a></li>
            <li><a href="#v2-faq">FAQ</a></li>
          </ul>
        </div>
      </div>

      <div class="v2-footer__bottom">
        <p class="v2-footer__legal">© {new Date().getFullYear()} STRIVN · {isFrench ? 'Tous droits réservés' : 'All rights reserved'}</p>
        <p class="v2-footer__credit">{c.footer.credit}</p>
        <div class="v2-footer__lang">
          <a href="/fr/" class={isFrench ? 'is-active' : ''}>FR</a>
          <span aria-hidden="true">·</span>
          <a href="/en/" class={!isFrench ? 'is-active' : ''}>EN</a>
        </div>
      </div>
    </footer>
  </main>
</BaseLayout>

<style is:global>
  /* ============================================================
     STRIVN · v2 — "Le staff virtuel"
     Calm, elite, dark. Sells relief, not features.
     ============================================================ */
  .v2 {
    --v2-void: #050610;
    --v2-void-2: #0a0c17;
    --v2-card: rgba(15, 22, 40, 0.72);
    --v2-card-2: rgba(20, 30, 52, 0.55);
    --v2-line: rgba(255, 255, 255, 0.08);
    --v2-line-2: rgba(255, 255, 255, 0.14);
    --v2-fg: #f4f7fb;
    --v2-muted: #b5c2d7;
    --v2-subtle: #8497bd;
    --v2-faint: #4f6488;
    --v2-electric: #4f94fb;
    --v2-electric-deep: #2d7ff9;
    --v2-performance: #4fe0b5;
    --v2-performance-deep: #27d7a1;
    --v2-violet: #9c7cff;
    --v2-violet-deep: #7c5cdc;
    --v2-warm: #ffb476;
    --v2-warm-deep: #ff8c42;
    --v2-risk: #ff5c5c;
    --v2-accent: var(--v2-electric);
    --v2-accent-deep: var(--v2-electric-deep);
    --v2-ease: cubic-bezier(0.22, 1, 0.36, 1);
    --v2-ease-out: cubic-bezier(0.16, 1, 0.3, 1);
    --v2-frame-w: min(82rem, calc(100vw - 48px));

    position: relative;
    background: var(--v2-void);
    color: var(--v2-fg);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 16px;
    line-height: 1.5;
    overflow-x: clip;
    min-height: 100vh;
  }
  html, body { overflow-x: clip; scroll-behavior: smooth; }

  /* ----- Ambient layers ----- */
  .v2-ambient { position: fixed; inset: 0; pointer-events: none; z-index: 0; overflow: hidden; }
  .v2-paint {
    position: absolute; inset: 0; width: 100%; height: 100%;
    opacity: 0.55; mix-blend-mode: screen;
    transition: opacity 800ms var(--v2-ease);
  }
  .v2-noise {
    position: absolute; inset: -50%;
    background-image:
      radial-gradient(circle at 30% 20%, rgba(45, 127, 249, 0.10), transparent 50%),
      radial-gradient(circle at 70% 80%, rgba(124, 92, 220, 0.08), transparent 50%);
    opacity: 0.9;
  }
  .v2-bloom {
    position: absolute; width: 90rem; height: 90rem; border-radius: 50%;
    filter: blur(100px); pointer-events: none;
    will-change: transform, background;
    transition: background 1200ms var(--v2-ease);
  }
  .v2-bloom--a { top: -30%; left: -25%; background: radial-gradient(circle, rgba(45, 127, 249, 0.30), transparent 60%); }
  .v2-bloom--b { bottom: -35%; right: -25%; background: radial-gradient(circle, rgba(39, 215, 161, 0.24), transparent 60%); opacity: 0.85; }
  .v2-cursor {
    position: absolute; width: 600px; height: 600px; border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.06), transparent 60%);
    transform: translate(-50%, -50%); left: 50%; top: 50%;
    transition: transform 280ms var(--v2-ease); will-change: transform; mix-blend-mode: screen;
  }
  .v2[data-active-accent="performance"] .v2-bloom--a { background: radial-gradient(circle, rgba(39, 215, 161, 0.30), transparent 60%); }
  .v2[data-active-accent="performance"] .v2-bloom--b { background: radial-gradient(circle, rgba(45, 127, 249, 0.24), transparent 60%); }
  .v2[data-active-accent="violet"] .v2-bloom--a { background: radial-gradient(circle, rgba(124, 92, 220, 0.30), transparent 60%); }
  .v2[data-active-accent="violet"] .v2-bloom--b { background: radial-gradient(circle, rgba(45, 127, 249, 0.20), transparent 60%); }
  .v2[data-active-accent="warm"] .v2-bloom--a { background: radial-gradient(circle, rgba(255, 176, 32, 0.22), transparent 60%); }
  .v2[data-active-accent="warm"] .v2-bloom--b { background: radial-gradient(circle, rgba(255, 92, 92, 0.18), transparent 60%); }

  /* ============================================================ Topbar ============================================================ */
  .v2-topbar {
    position: sticky; top: 0; z-index: 50;
    display: grid; grid-template-columns: 1fr auto 1fr; align-items: center;
    padding: 14px clamp(20px, 3vw, 40px);
    background: rgba(5, 6, 16, 0.5);
    backdrop-filter: blur(20px) saturate(140%); -webkit-backdrop-filter: blur(20px) saturate(140%);
    border-bottom: 1px solid var(--v2-line); gap: 24px;
  }
  .v2-topbar > .v2-brand { justify-self: start; }
  .v2-topbar > .v2-nav { justify-self: center; }
  .v2-topbar > .v2-topbar__end { justify-self: end; }
  .v2-brand { display: inline-flex; align-items: center; }
  .v2-brand img { display: block; height: 72px; width: auto; }
  .v2-brand--compact img { height: 40px; }
  .v2-nav { display: inline-flex; align-items: center; gap: 4px; }
  .v2-nav__link {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 8px 14px; border-radius: 999px;
    color: var(--v2-muted); font-size: 13.5px; text-decoration: none;
    transition: color 200ms var(--v2-ease), background 200ms var(--v2-ease);
  }
  .v2-nav__link:hover { color: var(--v2-fg); background: rgba(255, 255, 255, 0.04); }
  .v2-nav__n { font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 10px; color: var(--v2-faint); letter-spacing: 0.06em; }
  .v2-cta-mini {
    display: inline-flex; align-items: center; padding: 10px 18px; border-radius: 999px;
    background: var(--v2-fg); color: var(--v2-void); font-size: 13.5px; font-weight: 500; text-decoration: none;
    transition: transform 200ms var(--v2-ease), opacity 200ms var(--v2-ease);
  }
  .v2-cta-mini:hover { transform: translateY(-1px); opacity: 0.92; }
  .v2-topbar__end { display: inline-flex; align-items: center; gap: 14px; }
  .v2-lang {
    display: inline-flex; align-items: center; gap: 4px; padding: 6px 10px; border-radius: 999px;
    border: 1px solid var(--v2-line); background: rgba(255, 255, 255, 0.02);
    font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 11.5px; letter-spacing: 0.08em;
  }
  .v2-lang__opt { color: var(--v2-faint); text-decoration: none; padding: 2px 6px; border-radius: 999px; transition: color 180ms var(--v2-ease), background 180ms var(--v2-ease); }
  .v2-lang__opt:hover { color: var(--v2-muted); }
  .v2-lang__opt.is-active { color: var(--v2-fg); background: rgba(255, 255, 255, 0.08); }
  .v2-lang__sep { color: var(--v2-line-2); user-select: none; }

  @media (max-width: 1040px) { .v2-nav { display: none; } }
  @media (max-width: 880px) {
    .v2-topbar { padding: 12px 20px; gap: 12px; }
    .v2-brand--compact img { height: 34px; }
    .v2-topbar__end { gap: 10px; }
  }
  @media (max-width: 600px) {
    .v2-topbar > .v2-topbar__end .v2-lang { display: none; }
  }
  @media (max-width: 480px) {
    .v2-cta-mini { padding: 9px 13px; font-size: 12px; }
    .v2-brand--compact img { height: 28px; }
    .v2-topbar { gap: 10px; padding: 11px 16px; }
  }

  /* ============================================================ Hero ============================================================ */
  .v2-hero {
    position: relative; z-index: 1; max-width: var(--v2-frame-w); margin: 0 auto;
    padding: clamp(48px, 8vh, 96px) 24px clamp(110px, 16vh, 180px);
    text-align: center; display: flex; flex-direction: column; align-items: center; gap: 24px;
  }
  .v2-hero__logo { display: inline-flex; margin-bottom: clamp(8px, 2vh, 20px); }
  .v2-hero__logo img { display: block; height: clamp(96px, 14vw, 160px); width: auto; filter: drop-shadow(0 8px 32px rgba(45, 127, 249, 0.18)); }
  @media (max-width: 720px) { .v2-hero__logo img { height: 88px; } }
  @media (max-width: 414px) { .v2-hero__logo img { height: 76px; } }
  .v2-hero__title {
    font-size: clamp(40px, 8vw, 104px); font-weight: 600; letter-spacing: -0.035em; line-height: 1.0;
    margin: 12px 0 0; max-width: 14ch; width: 100%; display: block;
    overflow-wrap: break-word; text-wrap: balance; min-width: 0;
  }
  .v2-hero__title-1, .v2-hero__title-2 { display: block; }
  .v2-hero__title-1 { color: var(--v2-subtle); }
  .v2-hero__title-2 { color: var(--v2-fg); }
  @media (max-width: 560px) { .v2-hero__title { font-size: 38px; line-height: 1.04; max-width: 100%; letter-spacing: -0.02em; } }
  @media (max-width: 400px) { .v2-hero__title { font-size: 31px; } }
  .v2-hero__lede { font-size: clamp(15px, 1.4vw, 18px); line-height: 1.6; color: var(--v2-muted); max-width: 46rem; margin: 8px 0 0; }
  .v2-hero__actions { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; margin-top: 16px; }
  .v2-scroll-cue {
    position: relative; margin-top: 48px; display: inline-flex; flex-direction: column; align-items: center; gap: 12px;
    font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 10.5px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--v2-faint);
  }
  .v2-scroll-cue__line { width: 1px; height: 40px; background: linear-gradient(to bottom, var(--v2-faint), transparent); position: relative; overflow: hidden; }
  .v2-scroll-cue__line::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(to bottom, transparent, var(--v2-electric));
    transform: translateY(-100%); animation: v2-cue-fall 2.4s var(--v2-ease) infinite;
  }
  @keyframes v2-cue-fall { 0% { transform: translateY(-100%); } 100% { transform: translateY(100%); } }

  /* ============================================================ Buttons ============================================================ */
  .v2-btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    padding: 14px 22px; border-radius: 999px; font-family: inherit; font-size: 14px; font-weight: 500;
    text-decoration: none; border: 1px solid transparent; cursor: pointer;
    transition: transform 200ms var(--v2-ease), background 200ms var(--v2-ease), border-color 200ms var(--v2-ease), opacity 200ms var(--v2-ease);
  }
  .v2-btn--primary { background: var(--v2-fg); color: var(--v2-void); }
  .v2-btn--primary:hover { transform: translateY(-1px); opacity: 0.92; }
  .v2-btn--ghost { background: transparent; color: var(--v2-fg); border-color: var(--v2-line-2); }
  .v2-btn--ghost:hover { border-color: rgba(255, 255, 255, 0.3); background: rgba(255, 255, 255, 0.03); }
  .v2-btn--large { padding: 18px 30px; font-size: 15px; }

  /* ============================================================ Chapter shell ============================================================ */
  .v2-chapter { position: relative; z-index: 1; max-width: var(--v2-frame-w); margin: 0 auto; padding: clamp(80px, 14vh, 180px) 24px; }
  .v2-chapter__head { max-width: 56rem; margin: 0 auto clamp(48px, 6vw, 88px); text-align: center; display: flex; flex-direction: column; align-items: center; gap: 16px; }
  .v2-chapter__n {
    font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 13px; letter-spacing: 0.16em;
    color: var(--v2-accent); padding: 4px 12px; border: 1px solid currentColor; border-radius: 999px; opacity: 0.75;
  }
  .v2-chapter__eyebrow { margin: 0; font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 11.5px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--v2-subtle); }
  .v2-chapter__title { font-size: clamp(34px, 5vw, 60px); font-weight: 600; letter-spacing: -0.025em; line-height: 1.06; color: var(--v2-fg); margin: 0; max-width: 22ch; overflow-wrap: anywhere; }
  .v2-chapter__body { font-size: clamp(15px, 1.3vw, 17px); line-height: 1.65; color: var(--v2-muted); max-width: 44rem; margin: 0; }
  .v2-chapter[data-accent="performance"] { --v2-accent: var(--v2-performance); --v2-accent-deep: var(--v2-performance-deep); }
  .v2-chapter[data-accent="violet"]      { --v2-accent: var(--v2-violet);      --v2-accent-deep: var(--v2-violet-deep); }
  .v2-chapter[data-accent="warm"]        { --v2-accent: var(--v2-warm);        --v2-accent-deep: var(--v2-warm-deep); }

  /* ============================================================ 01 · Reality ============================================================ */
  .v2-reality { display: grid; grid-template-columns: 1fr 340px; gap: clamp(28px, 5vw, 64px); align-items: start; }
  .v2-tasks { list-style: none; margin: 0; padding: 0; display: grid; gap: 2px; }
  .v2-task {
    display: flex; align-items: center; gap: 16px; padding: 18px 4px;
    border-bottom: 1px solid var(--v2-line); font-size: clamp(16px, 1.8vw, 21px); color: var(--v2-muted); font-weight: 500;
  }
  .v2-task:last-child { border-bottom: 0; }
  .v2-task__tick {
    flex: none; width: 18px; height: 18px; border-radius: 5px; border: 1.5px solid var(--v2-line-2);
    position: relative;
  }
  .v2-task__tick::after {
    content: ''; position: absolute; inset: 0; display: block; margin: auto;
    width: 6px; height: 6px; border-radius: 1px; background: var(--v2-warm); opacity: 0.55;
  }

  /* ============================================================ Phone (shared) ============================================================ */
  .v2-phone {
    width: 100%; max-width: 320px; margin: 0 auto;
    border: 1px solid var(--v2-line-2); border-radius: 22px; overflow: hidden;
    background: linear-gradient(180deg, #0d1a14 0%, #07120c 100%);
    box-shadow: 0 30px 60px -25px rgba(0,0,0,0.7);
  }
  .v2-phone--chaos { background: linear-gradient(180deg, #14110b 0%, #0c0a07 100%); }
  .v2-phone__bar {
    display: flex; align-items: center; justify-content: space-between; padding: 8px 16px;
    font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 10px; color: rgba(255,255,255,0.55);
  }
  .v2-phone__dots { display: flex; gap: 3px; }
  .v2-phone__dots span { width: 3px; height: 3px; border-radius: 50%; background: rgba(255,255,255,0.4); }
  .v2-phone__head { display: flex; align-items: center; gap: 10px; padding: 10px 16px; background: rgba(255,255,255,0.04); border-bottom: 1px solid rgba(255,255,255,0.05); }
  .v2-phone__avatar { width: 28px; height: 28px; border-radius: 50%; background: var(--v2-electric); color: var(--v2-void); display: grid; place-items: center; font-weight: 600; font-size: 12px; }
  .v2-phone__avatar--group { background: linear-gradient(135deg, var(--v2-warm), var(--v2-warm-deep)); }
  .v2-phone__id { display: flex; flex-direction: column; line-height: 1.2; }
  .v2-phone__name { font-size: 12.5px; color: var(--v2-fg); font-weight: 500; }
  .v2-phone__sub { font-size: 10px; color: var(--v2-performance); }
  .v2-phone__sub--muted { color: var(--v2-faint); }
  .v2-phone__wa { margin-left: auto; color: rgba(39, 215, 161, 0.85); display: inline-flex; }
  .v2-phone__chat { padding: 14px 14px 18px; display: flex; flex-direction: column; gap: 6px; }
  .v2-bubble {
    max-width: 80%; padding: 8px 11px; font-size: 12.5px; line-height: 1.4; border-radius: 13px;
    opacity: 0; transform: translateY(6px);
    transition: opacity 360ms var(--v2-ease), transform 360ms var(--v2-ease);
    transition-delay: calc(120ms + var(--v2-bi, 0) * 220ms);
  }
  .is-in .v2-bubble, .v2-pane.is-active .v2-bubble { opacity: 1; transform: translateY(0); }
  .v2-bubble p { margin: 0; color: var(--v2-fg); }
  .v2-bubble__time { display: block; font-size: 9.5px; color: rgba(255,255,255,0.45); margin-top: 2px; text-align: right; }
  .v2-bubble--in { align-self: flex-start; background: rgba(255,255,255,0.07); border-bottom-left-radius: 3px; }
  .v2-bubble--in.is-unread { background: rgba(255, 176, 32, 0.1); border: 1px solid rgba(255, 176, 32, 0.22); }
  .v2-bubble--out { align-self: flex-end; background: rgba(39, 215, 161, 0.16); border: 1px solid rgba(39, 215, 161, 0.25); border-bottom-right-radius: 3px; }
  .v2-wellness {
    align-self: flex-start; margin-top: 4px; padding: 8px 11px;
    border: 1px solid rgba(79, 148, 251, 0.28); background: rgba(79, 148, 251, 0.08); border-radius: 11px;
    display: grid; grid-template-columns: 1fr auto; grid-template-rows: auto auto; column-gap: 8px;
    opacity: 0; transform: translateY(6px);
    transition: opacity 360ms var(--v2-ease), transform 360ms var(--v2-ease);
    transition-delay: calc(120ms + var(--v2-bi, 4) * 220ms);
  }
  .is-in .v2-wellness, .v2-pane.is-active .v2-wellness { opacity: 1; transform: translateY(0); }
  .v2-wellness__l { font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 10px; letter-spacing: 0.08em; color: var(--v2-electric); text-transform: uppercase; }
  .v2-wellness__v { grid-row: span 2; align-self: center; font-size: 16px; font-weight: 600; color: var(--v2-fg); }
  .v2-wellness__n { font-size: 11px; color: var(--v2-muted); }

  /* Resolve banner */
  .v2-resolve {
    display: flex; align-items: flex-start; gap: 16px; margin: clamp(40px, 6vw, 72px) auto 0; max-width: 50rem;
    padding: 22px 26px; border: 1px solid var(--v2-line-2); border-radius: 16px;
    background: rgba(39, 215, 161, 0.05);
  }
  .v2-resolve__mark { flex: none; width: 30px; height: 30px; border-radius: 50%; display: grid; place-items: center; color: var(--v2-performance); background: rgba(39, 215, 161, 0.12); border: 1px solid rgba(39, 215, 161, 0.3); }
  .v2-resolve p { margin: 0; font-size: clamp(15px, 1.4vw, 18px); line-height: 1.6; color: var(--v2-muted); }
  .v2-resolve strong { color: var(--v2-fg); font-weight: 600; }
  @media (max-width: 860px) {
    .v2-reality { grid-template-columns: 1fr; gap: 32px; }
    .v2-phone--chaos { max-width: 340px; }
  }

  /* ============================================================ 02 · Staff pillars ============================================================ */
  .v2-pillars { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; max-width: var(--v2-frame-w); margin: 0 auto; }
  .v2-pillar {
    --v2-accent: var(--v2-electric);
    display: flex; flex-direction: column; gap: 12px;
    padding: 28px; border: 1px solid var(--v2-line); border-radius: 18px;
    background: var(--v2-card); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
    transition: transform 320ms var(--v2-ease), border-color 320ms var(--v2-ease);
  }
  .v2-pillar[data-accent="performance"] { --v2-accent: var(--v2-performance); }
  .v2-pillar[data-accent="violet"] { --v2-accent: var(--v2-violet); }
  .v2-pillar[data-accent="warm"] { --v2-accent: var(--v2-warm); }
  .v2-pillar:hover { transform: translateY(-3px); border-color: color-mix(in oklab, var(--v2-accent) 40%, transparent); }
  .v2-pillar__head { display: flex; align-items: center; gap: 10px; }
  .v2-pillar__dot { width: 8px; height: 8px; border-radius: 50%; background: var(--v2-accent); box-shadow: 0 0 0 4px color-mix(in oklab, var(--v2-accent) 18%, transparent); }
  .v2-pillar__tag { font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--v2-accent); }
  .v2-pillar__name { margin: 4px 0 0; font-size: clamp(20px, 2.2vw, 26px); font-weight: 600; letter-spacing: -0.015em; line-height: 1.2; color: var(--v2-fg); }
  .v2-pillar__role { margin: 0; font-size: 14px; color: var(--v2-subtle); }
  .v2-pillar__does { list-style: none; margin: 8px 0 0; padding: 14px 0 0; border-top: 1px solid var(--v2-line); display: grid; gap: 10px; }
  .v2-pillar__does li { position: relative; padding-left: 18px; font-size: 14px; line-height: 1.5; color: var(--v2-muted); }
  .v2-pillar__does li::before { content: ''; position: absolute; left: 0; top: 8px; width: 8px; height: 8px; border-radius: 50%; border: 1.5px solid var(--v2-accent); }
  @media (max-width: 720px) { .v2-pillars { grid-template-columns: 1fr; } }

  /* Before / After */
  .v2-ba { max-width: var(--v2-frame-w); margin: clamp(40px, 6vw, 72px) auto 0; border: 1px solid var(--v2-line); border-radius: 20px; overflow: hidden; background: var(--v2-card); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); }
  .v2-ba__head { display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 18px 24px; border-bottom: 1px solid var(--v2-line-2); background: rgba(255,255,255,0.02); flex-wrap: wrap; }
  .v2-ba__eyebrow { font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--v2-subtle); }
  .v2-ba__labels { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; flex: 1; max-width: 60%; }
  .v2-ba__label { font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; }
  .v2-ba__label--before { color: var(--v2-faint); }
  .v2-ba__label--after { color: var(--v2-performance); }
  .v2-ba__rows { list-style: none; margin: 0; padding: 0; }
  .v2-ba__row {
    display: grid; grid-template-columns: 1fr 1fr 1fr; align-items: center; gap: 24px;
    padding: 18px 24px; border-bottom: 1px solid var(--v2-line);
  }
  .v2-ba__row:last-child { border-bottom: 0; }
  .v2-ba__task { font-weight: 600; color: var(--v2-fg); font-size: 14.5px; }
  .v2-ba__before { color: var(--v2-faint); font-size: 14px; text-decoration: line-through; text-decoration-color: rgba(255,255,255,0.18); }
  .v2-ba__after { color: var(--v2-fg); font-size: 14px; display: inline-flex; align-items: baseline; gap: 8px; }
  .v2-ba__arrow { color: var(--v2-performance); font-weight: 600; }
  @media (max-width: 720px) {
    .v2-ba__head { display: none; }
    .v2-ba__row { grid-template-columns: 1fr; gap: 8px; padding: 18px 20px; }
    .v2-ba__before::before { content: '✕ '; color: var(--v2-faint); }
  }

  /* ============================================================ 03 · WhatsApp ============================================================ */
  .v2-wa-layout { display: grid; grid-template-columns: 1fr 320px; gap: clamp(32px, 6vw, 80px); align-items: center; max-width: 68rem; margin: 0 auto; }
  .v2-wa-steps ol { list-style: none; margin: 0; padding: 0; display: grid; gap: 0; }
  .v2-wa-step { display: flex; align-items: center; gap: 18px; padding: 20px 0; border-bottom: 1px solid var(--v2-line); }
  .v2-wa-step:last-of-type { border-bottom: 0; }
  .v2-wa-step__n { font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 13px; color: var(--v2-performance); flex: none; }
  .v2-wa-step__text { font-size: clamp(16px, 1.7vw, 20px); color: var(--v2-fg); font-weight: 500; }
  .v2-noapp { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 28px; }
  .v2-noapp__chip {
    display: inline-flex; align-items: center; gap: 7px; padding: 7px 14px; border-radius: 999px;
    border: 1px solid var(--v2-line-2); font-size: 13px; color: var(--v2-muted);
    font-family: 'JetBrains Mono', ui-monospace, monospace; letter-spacing: 0.02em;
  }
  .v2-noapp__chip svg { color: var(--v2-faint); }
  .v2-wa-caption { margin: 24px 0 0; font-size: 14px; line-height: 1.6; color: var(--v2-subtle); max-width: 36rem; }
  @media (max-width: 860px) {
    .v2-wa-layout { grid-template-columns: 1fr; gap: 40px; }
    .v2-phone--lg { max-width: 320px; }
  }

  /* ============================================================ 04 · Medical record ============================================================ */
  .v2-med { display: grid; grid-template-columns: 280px 1fr; gap: clamp(28px, 5vw, 64px); align-items: start; max-width: var(--v2-frame-w); margin: 0 auto; }
  .v2-med__features { list-style: none; margin: 0; padding: 0; display: grid; gap: 2px; }
  .v2-med__features li {
    padding: 16px 4px; border-bottom: 1px solid var(--v2-line); font-size: clamp(15px, 1.5vw, 18px); color: var(--v2-muted); font-weight: 500;
    position: relative; padding-left: 22px;
  }
  .v2-med__features li:last-child { border-bottom: 0; }
  .v2-med__features li::before { content: ''; position: absolute; left: 0; top: 22px; width: 10px; height: 1px; background: var(--v2-violet); }
  .v2-record { border: 1px solid var(--v2-line-2); border-radius: 20px; background: var(--v2-card); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); overflow: hidden; box-shadow: 0 0 60px -28px rgba(124, 92, 220, 0.4); }
  .v2-record__head { display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 22px 24px; border-bottom: 1px solid var(--v2-line); flex-wrap: wrap; }
  .v2-record__id { display: flex; align-items: center; gap: 14px; }
  .v2-record__avatar { width: 44px; height: 44px; border-radius: 50%; display: grid; place-items: center; font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 15px; color: var(--v2-fg); background: linear-gradient(135deg, var(--v2-faint), var(--v2-violet)); border: 1px solid var(--v2-line-2); }
  .v2-record__player { margin: 0; font-size: 18px; font-weight: 600; color: var(--v2-fg); }
  .v2-record__injury { margin: 2px 0 0; font-size: 13px; color: var(--v2-risk); }
  .v2-record__since { font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 11px; color: var(--v2-faint); }
  .v2-record__track { display: flex; align-items: flex-start; gap: 0; padding: 26px 24px; border-bottom: 1px solid var(--v2-line); position: relative; }
  .v2-stage { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 10px; position: relative; text-align: center; }
  .v2-stage::before { content: ''; position: absolute; top: 7px; left: -50%; width: 100%; height: 2px; background: var(--v2-line); z-index: 0; }
  .v2-stage:first-child::before { display: none; }
  .v2-stage__dot { position: relative; z-index: 1; width: 16px; height: 16px; border-radius: 50%; background: var(--v2-void-2); border: 2px solid var(--v2-faint); }
  .v2-stage__label { font-size: 11px; color: var(--v2-faint); line-height: 1.3; max-width: 9ch; }
  .v2-stage.is-done .v2-stage__dot { background: var(--v2-performance); border-color: var(--v2-performance); }
  .v2-stage.is-done::before { background: var(--v2-performance); }
  .v2-stage.is-done .v2-stage__label { color: var(--v2-muted); }
  .v2-stage.is-active .v2-stage__dot { background: var(--v2-electric); border-color: var(--v2-electric); box-shadow: 0 0 0 5px rgba(79, 148, 251, 0.18); }
  .v2-stage.is-active::before { background: linear-gradient(90deg, var(--v2-performance), var(--v2-electric)); }
  .v2-stage.is-active .v2-stage__label { color: var(--v2-fg); font-weight: 600; }
  .v2-record__notes { padding: 8px 24px; }
  .v2-note { padding: 16px 0; border-bottom: 1px solid var(--v2-line); }
  .v2-note:last-child { border-bottom: 0; }
  .v2-note__meta { display: flex; align-items: baseline; gap: 10px; margin-bottom: 6px; }
  .v2-note__author { font-size: 13.5px; font-weight: 600; color: var(--v2-fg); }
  .v2-note__role { font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--v2-violet); }
  .v2-note__text { margin: 0; font-size: 13.5px; line-height: 1.55; color: var(--v2-muted); }
  .v2-record__foot { display: flex; align-items: center; justify-content: space-between; padding: 18px 24px; background: rgba(124, 92, 220, 0.06); border-top: 1px solid var(--v2-line); }
  .v2-record__foot-l { font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--v2-subtle); }
  .v2-record__foot-v { font-size: 16px; font-weight: 600; color: var(--v2-fg); }
  @media (max-width: 860px) { .v2-med { grid-template-columns: 1fr; gap: 32px; } }
  @media (max-width: 520px) {
    .v2-record__track { overflow-x: auto; }
    .v2-stage { min-width: 78px; }
  }

  /* ============================================================ 05 · Sessions board ============================================================ */
  .v2-sessions { display: grid; grid-template-columns: 280px 1fr; gap: clamp(28px, 5vw, 64px); align-items: start; max-width: var(--v2-frame-w); margin: 0 auto; }
  .v2-sessions__features { list-style: none; margin: 0; padding: 0; display: grid; gap: 2px; }
  .v2-sessions__features li { display: flex; align-items: center; gap: 14px; padding: 16px 4px; border-bottom: 1px solid var(--v2-line); font-size: clamp(15px, 1.5vw, 18px); color: var(--v2-muted); font-weight: 500; }
  .v2-sessions__features li:last-child { border-bottom: 0; }
  .v2-sessions__bullet { flex: none; width: 9px; height: 9px; border-radius: 2px; background: var(--v2-electric); }
  .v2-board { position: relative; border: 1px solid var(--v2-line-2); border-radius: 20px; background: var(--v2-card); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); overflow: hidden; }
  .v2-board__pitch { position: absolute; inset: 0; color: var(--v2-electric); opacity: 0.16; pointer-events: none; }
  .v2-board__pitch svg { width: 100%; height: 100%; }
  .v2-board__token { fill: var(--v2-electric); }
  .v2-board__token--b { fill: var(--v2-warm); }
  .v2-board__pass { stroke: var(--v2-electric); }
  .v2-board__head { position: relative; display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; padding: 24px 26px; border-bottom: 1px solid var(--v2-line); flex-wrap: wrap; }
  .v2-board__eyebrow { margin: 0; font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--v2-electric); }
  .v2-board__title { margin: 6px 0 0; font-size: 20px; font-weight: 600; letter-spacing: -0.01em; color: var(--v2-fg); }
  .v2-board__stamp { font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 10.5px; letter-spacing: 0.06em; color: var(--v2-faint); padding: 5px 12px; border: 1px solid var(--v2-line); border-radius: 999px; white-space: nowrap; }
  .v2-board__phases { position: relative; list-style: none; margin: 0; padding: 8px 26px 24px; }
  .v2-board__phase { display: flex; align-items: baseline; justify-content: space-between; gap: 20px; padding: 16px 0; border-bottom: 1px solid var(--v2-line); }
  .v2-board__phase:last-child { border-bottom: 0; }
  .v2-board__phase-l { font-size: 14.5px; font-weight: 600; color: var(--v2-fg); flex: none; min-width: 9rem; }
  .v2-board__phase-d { font-size: 13.5px; color: var(--v2-muted); line-height: 1.5; text-align: right; }
  @media (max-width: 860px) { .v2-sessions { grid-template-columns: 1fr; gap: 32px; } }
  @media (max-width: 520px) {
    .v2-board__phase { flex-direction: column; gap: 4px; }
    .v2-board__phase-d { text-align: left; }
  }

  /* ============================================================ Time saved ============================================================ */
  .v2-time { display: grid; grid-template-columns: 1.1fr 1fr; gap: clamp(32px, 6vw, 80px); align-items: center; max-width: var(--v2-frame-w); margin: 0 auto; }
  .v2-time__lead { display: flex; flex-direction: column; gap: 16px; align-items: flex-start; text-align: left; }
  .v2-time__title { font-size: clamp(34px, 5vw, 60px); font-weight: 600; letter-spacing: -0.025em; line-height: 1.05; color: var(--v2-fg); margin: 0; max-width: 14ch; }
  .v2-time__body { font-size: clamp(15px, 1.4vw, 18px); line-height: 1.65; color: var(--v2-muted); max-width: 38rem; margin: 0; }
  .v2-time__stat { margin-top: 12px; display: flex; flex-direction: column; gap: 4px; }
  .v2-time__stat-v { font-size: clamp(48px, 7vw, 88px); font-weight: 600; letter-spacing: -0.04em; line-height: 1; color: var(--v2-performance); }
  .v2-time__stat-l { font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 11.5px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--v2-subtle); }
  .v2-time__breakdown { border: 1px solid var(--v2-line-2); border-radius: 20px; background: var(--v2-card); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); padding: 12px 26px 20px; }
  .v2-time__breakdown ul { list-style: none; margin: 0; padding: 0; }
  .v2-time__row { display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 16px 0; border-bottom: 1px solid var(--v2-line); }
  .v2-time__task { font-size: 14.5px; color: var(--v2-muted); }
  .v2-time__hours { font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 14px; color: var(--v2-fg); font-weight: 500; }
  .v2-time__footer { margin: 16px 0 0; font-size: 14px; line-height: 1.55; color: var(--v2-performance); font-weight: 500; }
  @media (max-width: 860px) { .v2-time { grid-template-columns: 1fr; gap: 36px; } }

  /* ============================================================ 06 · Pricing ============================================================ */
  .v2-pricing { max-width: 58rem; margin: 0 auto; display: flex; flex-direction: column; gap: 22px; }
  .v2-plans { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; align-items: stretch; }
  .v2-plan {
    position: relative; min-width: 0; display: flex; flex-direction: column; gap: 18px;
    padding: 24px; border: 1px solid var(--v2-line-2); border-radius: 20px;
    background: rgba(255, 255, 255, 0.025); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 24px 70px -48px rgba(0,0,0,0.75);
  }
  .v2-plan--featured { background: linear-gradient(180deg, rgba(45,127,249,0.10), var(--v2-card)); box-shadow: 0 0 70px -38px rgba(45, 127, 249, 0.75); }
  .v2-plan__head { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; min-height: 96px; }
  .v2-plan__name { margin: 0; font-size: 18px; line-height: 1.2; font-weight: 600; letter-spacing: -0.01em; color: var(--v2-fg); }
  .v2-plan__description { margin: 8px 0 0; font-size: 13.5px; line-height: 1.55; color: var(--v2-muted); }
  .v2-plan__badge {
    flex: none; padding: 4px 8px; border: 1px solid rgba(79, 148, 251, 0.34); border-radius: 999px;
    font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--v2-electric); background: rgba(79, 148, 251, 0.08);
  }
  .v2-plan__price { margin: 0; display: flex; align-items: baseline; gap: 6px; color: var(--v2-fg); }
  .v2-plan__price span { font-size: clamp(36px, 4vw, 52px); line-height: 0.95; letter-spacing: -0.035em; font-weight: 600; }
  .v2-plan__price small { font-size: 13px; line-height: 1; color: var(--v2-faint); }
  .v2-plan__messages {
    margin: -6px 0 0; padding: 10px 12px; border: 1px solid rgba(39, 215, 161, 0.22); border-radius: 10px;
    font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 11.5px; line-height: 1.45; color: var(--v2-performance); background: rgba(39, 215, 161, 0.055);
  }
  .v2-plan__features { list-style: none; margin: 0; padding: 0; display: grid; gap: 10px; }
