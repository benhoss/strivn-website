    border-radius: 999px;
    border: 1px solid var(--v2-line);
  }
  .v2-dash__tabs {
    display: flex;
    gap: 2px;
    padding: 10px 16px;
    border-bottom: 1px solid var(--v2-line);
    flex-wrap: wrap;
  }
  .v2-dash__tab {
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 11.5px;
    color: var(--v2-subtle);
