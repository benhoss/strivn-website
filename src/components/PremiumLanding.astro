        const scene = new THREE.Scene();
        const camera = new THREE.OrthographicCamera(0, 1, 1, 0, -100, 100);
        const lineGroup = new THREE.Group();
        const nodeGroup = new THREE.Group();
        const pulseGroup = new THREE.Group();
        const impactGroup = new THREE.Group();
        scene.add(lineGroup, nodeGroup, pulseGroup, impactGroup);

        const electric = new THREE.Color('#4f94fb');
        const performanceSignal = new THREE.Color('#27d7a1');
        const muted = new THREE.Color('#8497bd');
        const paths: import('three').QuadraticBezierCurve3[] = [];
        const lines: import('three').Line[] = [];
        const nodes: import('three').Mesh[] = [];
        const nodeBases: import('three').Vector3[] = [];
        const pulses: import('three').Mesh[] = [];
        const impactRings: import('three').Mesh[] = [];
        const hub = new THREE.Mesh(
          new THREE.RingGeometry(30, 34, 72),
          new THREE.MeshBasicMaterial({ color: performanceSignal, transparent: true, opacity: 0.36 })
        );
        scene.add(hub);

        const easeOutExpo = (t: number) => t >= 1 ? 1 : 1 - Math.pow(2, -10 * t);
        const easeOutCubic = (t: number) => 1 - Math.pow(1 - t, 3);
        const clamp01 = (v: number) => Math.max(0, Math.min(1, v));

        function clearGroup(group: import('three').Group) {
          while (group.children.length) {
            const child = group.children.pop();
            if (!child) continue;
            const mesh = child as import('three').Mesh;
            mesh.geometry?.dispose?.();
            const mat = mesh.material as import('three').Material | import('three').Material[] | undefined;
            if (Array.isArray(mat)) mat.forEach((m) => m.dispose());
            else mat?.dispose?.();
          }
        }

        function resize() {
          const rect = host.getBoundingClientRect();
          const width = Math.max(1, Math.round(rect.width));
          const height = Math.max(1, Math.round(rect.height));
          renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 1.5));
          renderer.setSize(width, height, false);
          camera.left = 0; camera.right = width; camera.top = 0; camera.bottom = height; camera.updateProjectionMatrix();

          clearGroup(lineGroup);
          clearGroup(nodeGroup);
          clearGroup(pulseGroup);
          clearGroup(impactGroup);
          paths.length = 0; lines.length = 0; nodes.length = 0; nodeBases.length = 0; pulses.length = 0; impactRings.length = 0;

          const center = new THREE.Vector3(width * 0.5, height * 0.5, 0);
          hub.position.copy(center);
          const radiusX = width * 0.33;
          const radiusY = height * 0.36;
          const nodeGeo = new THREE.CircleGeometry(8, 28);
          const pulseGeo = new THREE.CircleGeometry(5, 24);

          for (let i = 0; i < moduleEls.length; i += 1) {
            const angle = -Math.PI / 2 + i * (Math.PI * 2 / moduleEls.length);
            const start = new THREE.Vector3(center.x + Math.cos(angle) * radiusX, center.y + Math.sin(angle) * radiusY, 0);
            const mid = new THREE.Vector3((start.x + center.x) / 2, (start.y + center.y) / 2, 0);
            const bend = i % 2 === 0 ? 28 : -28;
            mid.x += Math.cos(angle + Math.PI / 2) * bend;
            mid.y += Math.sin(angle + Math.PI / 2) * bend;

            const curve = new THREE.QuadraticBezierCurve3(start, mid, center);
            paths.push(curve);
            const line = new THREE.Line(
              new THREE.BufferGeometry().setFromPoints(curve.getPoints(42)),
              new THREE.LineBasicMaterial({ color: muted, transparent: true, opacity: 0.16 })
            );
            lineGroup.add(line);
            lines.push(line);

            const node = new THREE.Mesh(nodeGeo.clone(), new THREE.MeshBasicMaterial({ color: electric, transparent: true, opacity: 0.30 }));
            node.position.copy(start);
            nodeGroup.add(node);
            nodes.push(node);
            nodeBases.push(start.clone());

            const pulse = new THREE.Mesh(pulseGeo.clone(), new THREE.MeshBasicMaterial({ color: performanceSignal, transparent: true, opacity: 0 }));
            pulseGroup.add(pulse);
            pulses.push(pulse);
          }

          [72, 112, 154].forEach((radius) => {
            const ring = new THREE.Mesh(
              new THREE.RingGeometry(radius, radius + 2, 96),
              new THREE.MeshBasicMaterial({ color: performanceSignal, transparent: true, opacity: 0 })
            );
            ring.position.copy(center);
            impactGroup.add(ring);
            impactRings.push(ring);
          });
        }

        resize();
        window.addEventListener('resize', resize, { passive: true });

        let active = 0;
        let running = false;
        let rafId = 0;
        const startedAt = performance.now();
        const cycleMs = 3200;
        const pullStartMs = 220;
        const signalDelayMs = 90;
        const signalTravelMs = 1180;
        const lockStartMs = pullStartMs + signalDelayMs * 5 + signalTravelMs - 120;
        const lockMs = 520;

        function loop(now: number) {
          if (!running) return;
          const elapsed = now - startedAt;
          const cycle = elapsed % cycleMs;
          const lockProgress = clamp01((cycle - lockStartMs) / lockMs);
          const isLocking = lockProgress > 0 && lockProgress < 1;
          host.classList.toggle('is-locking', isLocking);

          nodes.forEach((node, i) => {
            const mat = node.material as import('three').MeshBasicMaterial;
            const start = nodeBases[i];
            const signalStart = pullStartMs + i * signalDelayMs;
            const signalProgress = clamp01((cycle - signalStart) / signalTravelMs);
            const isPulling = signalProgress > 0 && signalProgress < 1;
            const isStaged = signalProgress > 0 && signalProgress < 0.24;
            const unsettled = Math.max(0, 1 - signalProgress);
            const driftX = Math.sin(elapsed * 0.0022 + i * 1.7) * 5 * unsettled;
            const driftY = Math.cos(elapsed * 0.0018 + i * 1.2) * 4 * unsettled;
            node.position.set(start.x + driftX, start.y + driftY, 0);
            mat.opacity = isStaged || isLocking ? 0.78 : 0.34 + Math.sin(elapsed * 0.002 + i) * 0.08;
            node.scale.setScalar(isStaged ? 1.34 : 1 + Math.sin(elapsed * 0.0025 + i) * 0.08);
          });

          pulses.forEach((pulse, i) => {
            const mat = pulse.material as import('three').MeshBasicMaterial;
            const signalStart = pullStartMs + i * signalDelayMs;
            const signalProgress = clamp01((cycle - signalStart) / signalTravelMs);
            const isPulling = signalProgress > 0 && signalProgress < 1;
            const line = lines[i];
            if (line) {
              const lineMat = line.material as import('three').LineBasicMaterial;
              lineMat.opacity = isPulling ? 0.42 + Math.sin(signalProgress * Math.PI) * 0.18 : isLocking ? 0.28 : 0.12;
              lineMat.color.copy(isPulling || isLocking ? electric : muted);
            }
            if (isPulling && paths[i]) {
              const t = easeOutExpo(signalProgress);
              pulse.position.copy(paths[i].getPoint(Math.min(0.992, t)));
              mat.opacity = Math.sin(signalProgress * Math.PI) * 0.9;
              pulse.scale.setScalar(0.9 + easeOutCubic(signalProgress) * 1.25);
            } else {
              mat.opacity = 0;
            }
          });

          const activeNow = pulses
            .map((_, i) => ({ i, p: clamp01((cycle - (pullStartMs + i * signalDelayMs)) / signalTravelMs) }))
            .filter((item) => item.p > 0 && item.p < 0.24)
            .map((item) => item.i);
          if (activeNow[0] !== active) active = activeNow[0] ?? active;
          moduleEls.forEach((el, i) => {
            const pulling = activeNow.includes(i);
            el.classList.toggle('is-pulling', pulling);
            el.classList.toggle('is-active', pulling || (isLocking && i === active));
          });

          const lockWave = Math.sin(lockProgress * Math.PI);
          const hubPulse = 1 + lockWave * 0.18 + Math.sin(cycle * 0.006) * 0.025;
          hub.scale.setScalar(hubPulse);
          (hub.material as import('three').MeshBasicMaterial).opacity = 0.30 + lockWave * 0.34;
          impactRings.forEach((ring, i) => {
            const mat = ring.material as import('three').MeshBasicMaterial;
            const p = clamp01((cycle - lockStartMs - i * 90) / 520);
            const wave = Math.sin(p * Math.PI);
            mat.opacity = wave * 0.34;
            ring.scale.setScalar(0.62 + easeOutCubic(p) * 0.58);
          });
          lineGroup.rotation.z = Math.sin(elapsed * 0.00034) * 0.018;
          renderer.render(scene, camera);
          rafId = requestAnimationFrame(loop);
        }

        const pause = () => { running = false; cancelAnimationFrame(rafId); };
        const play = () => { if (!running) { running = true; rafId = requestAnimationFrame(loop); } };
        setVisible = (visible: boolean) => visible && !document.hidden ? play() : pause();
        setVisible(true);
        document.addEventListener('visibilitychange', () => setVisible?.(!document.hidden));
      };

      const heroIO = new IntersectionObserver((entries) => {
        const visible = entries.some((entry) => entry.isIntersecting);
        if (visible) void startScene();
        setVisible?.(visible);
      }, { threshold: 0.18, rootMargin: '120px' });
      heroIO.observe(host);
    })();

    // ============================================================
    // Three.js painted-texture background — fails silently.
    // Lazy-loaded: only kicks in after idle (or intersection on touch),
    // and only on devices that pass the capability check below.
    // ============================================================
    const paintCanvas = document.getElementById('v2-paint') as HTMLCanvasElement | null;
    const paintEligible =
      !!paintCanvas &&
      !reduced &&
      (window.matchMedia('(pointer: fine)').matches || window.innerWidth >= 768);

    if (paintEligible && paintCanvas) {
      const paintedBg = async (canvas: HTMLCanvasElement) => {
        if (!window.matchMedia('(pointer: fine)').matches && window.innerWidth < 768) return;
        let THREE: typeof import('three');
        try { THREE = await import('three'); } catch (err) { return; }
        let renderer: import('three').WebGLRenderer;
        try {
          renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: false, powerPreference: 'high-performance' });
        } catch (err) { return; }
      const dpr = Math.min(window.devicePixelRatio || 1, 1.5);
      renderer.setPixelRatio(dpr);
      renderer.setSize(window.innerWidth, window.innerHeight, false);

      const scene = new THREE.Scene();
      const camera = new THREE.OrthographicCamera(-1, 1, 1, -1, 0, 1);

      const palettes: Record<string, [THREE.Vector3, THREE.Vector3]> = {
        electric: [new THREE.Vector3(0.18, 0.50, 1.00), new THREE.Vector3(0.50, 0.30, 1.00)],
        performance: [new THREE.Vector3(0.15, 0.85, 0.70), new THREE.Vector3(0.20, 0.55, 1.00)],
        violet: [new THREE.Vector3(0.55, 0.40, 1.00), new THREE.Vector3(0.30, 0.45, 1.00)],
        warm: [new THREE.Vector3(1.00, 0.65, 0.30), new THREE.Vector3(1.00, 0.45, 0.45)],
      };

      const uniforms = {
        uTime: { value: 0 },
        uMouse: { value: new THREE.Vector2(0.5, 0.5) },
        uRes: { value: new THREE.Vector2(window.innerWidth, window.innerHeight) },
        uColorA: { value: palettes.electric[0].clone() },
        uColorB: { value: palettes.electric[1].clone() },
        uColorATarget: { value: palettes.electric[0].clone() },
        uColorBTarget: { value: palettes.electric[1].clone() },
        uIntensity: { value: 1.0 },
      };

      const material = new THREE.ShaderMaterial({
        uniforms,
        transparent: true,
        vertexShader: `
          varying vec2 vUv;
          void main() { vUv = uv; gl_Position = vec4(position, 1.0); }
        `,
        fragmentShader: `
          precision highp float;
          varying vec2 vUv;
          uniform float uTime;
          uniform vec2 uMouse;
          uniform vec2 uRes;
          uniform vec3 uColorA;
          uniform vec3 uColorB;
          uniform float uIntensity;
          vec3 mod289(vec3 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
          vec2 mod289(vec2 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
          vec3 permute(vec3 x) { return mod289(((x*34.0)+1.0)*x); }
          float snoise(vec2 v) {
            const vec4 C = vec4(0.211324865405187, 0.366025403784439, -0.577350269189626, 0.024390243902439);
            vec2 i  = floor(v + dot(v, C.yy) );
            vec2 x0 = v -   i + dot(i, C.xx);
            vec2 i1; i1 = (x0.x > x0.y) ? vec2(1.0, 0.0) : vec2(0.0, 1.0);
            vec4 x12 = x0.xyxy + C.xxzz; x12.xy -= i1;
            i = mod289(i);
            vec3 p = permute( permute( i.y + vec3(0.0, i1.y, 1.0 )) + i.x + vec3(0.0, i1.x, 1.0 ));
            vec3 m = max(0.5 - vec3(dot(x0,x0), dot(x12.xy,x12.xy), dot(x12.zw,x12.zw)), 0.0);
            m = m*m; m = m*m;
            vec3 x = 2.0 * fract(p * C.www) - 1.0;
            vec3 h = abs(x) - 0.5;
            vec3 ox = floor(x + 0.5);
            vec3 a0 = x - ox;
            m *= 1.79284291400159 - 0.85373472095314 * ( a0*a0 + h*h );
            vec3 g;
            g.x  = a0.x  * x0.x  + h.x  * x0.y;
            g.yz = a0.yz * x12.xz + h.yz * x12.yw;
            return 130.0 * dot(m, g);
          }
          float fbm(vec2 p) {
            float v = 0.0; float a = 0.5;
            for (int i = 0; i < 4; i++) { v += a * snoise(p); p *= 2.0; a *= 0.5; }
            return v;
          }
          void main() {
            vec2 st = vUv;
            vec2 aspect = vec2(uRes.x / uRes.y, 1.0);
            vec2 p = (st - 0.5) * aspect;
            vec2 m = (uMouse - 0.5) * aspect;
            float t = uTime * 0.06;
            float n1 = fbm(p * 1.4 + vec2(t, t * 0.7));
            float n2 = fbm(p * 2.6 - vec2(t * 0.5, t));
            float flow = n1 * 0.6 + n2 * 0.4;
            float d = length(p - m);
            float pull = smoothstep(0.8, 0.0, d) * 0.45;
            vec3 col = mix(uColorA, uColorB, flow * 0.5 + 0.5);
            col += pull * uColorB * 0.35;
            float vign = smoothstep(1.1, 0.2, length(p));
            float alpha = vign * (0.25 + flow * 0.18 + pull * 0.3) * uIntensity;
            alpha = clamp(alpha, 0.0, 0.55);
            gl_FragColor = vec4(col, alpha);
          }
        `,
      });

      const mesh = new THREE.Mesh(new THREE.PlaneGeometry(2, 2), material);
      scene.add(mesh);

      let mouseX = 0.5, mouseY = 0.5;
      let targetX = 0.5, targetY = 0.5;
      window.addEventListener('mousemove', (e) => {
        targetX = e.clientX / window.innerWidth;
        targetY = 1.0 - (e.clientY / window.innerHeight);
      }, { passive: true });

      function syncPalette() {
        const accent = root!.dataset.activeAccent || 'electric';
        const pair = palettes[accent] || palettes.electric;
        uniforms.uColorATarget.value.copy(pair[0]);
        uniforms.uColorBTarget.value.copy(pair[1]);
      }
      const accentObs = new MutationObserver(syncPalette);
      accentObs.observe(root!, { attributes: true, attributeFilter: ['data-active-accent'] });
      syncPalette();

      window.addEventListener('resize', () => {
        renderer.setSize(window.innerWidth, window.innerHeight, false);
        uniforms.uRes.value.set(window.innerWidth, window.innerHeight);
      }, { passive: true });

      const start = performance.now();
      let rafId = 0;
      let running = true;
      function loop(now: number) {
        if (!running) return;
        uniforms.uTime.value = (now - start) / 1000;
        mouseX += (targetX - mouseX) * 0.05;
        mouseY += (targetY - mouseY) * 0.05;
        uniforms.uMouse.value.set(mouseX, mouseY);
        uniforms.uColorA.value.lerp(uniforms.uColorATarget.value, 0.04);
        uniforms.uColorB.value.lerp(uniforms.uColorBTarget.value, 0.04);
        renderer.render(scene, camera);
        rafId = requestAnimationFrame(loop);
      }
      rafId = requestAnimationFrame(loop);

      document.addEventListener('visibilitychange', () => {
        if (document.hidden) { running = false; cancelAnimationFrame(rafId); }
        else if (!running) { running = true; rafId = requestAnimationFrame(loop); }
      });
      };

      // Trigger the paint: only on idle (desktop), or when the canvas
      // scrolls into view (touch / mobile). Disconnecting IO after fire
      // avoids duplicate imports.
      const startPaint = () => {
        if ((window as any).__v2PaintStarted) return;
        (window as any).__v2PaintStarted = true;
        void paintedBg(paintCanvas);
      };
      if ('IntersectionObserver' in window) {
        const paintIO = new IntersectionObserver(
          (entries) => {
            if (entries.some((e) => e.isIntersecting)) {
              startPaint();
              paintIO.disconnect();
            }
          },
          { rootMargin: '200px' },
        );
        paintIO.observe(paintCanvas);
      }
      const idle = (cb: () => void) =>
        'requestIdleCallback' in window
          ? (window as any).requestIdleCallback(cb, { timeout: 2000 })
          : window.setTimeout(cb, 1500);
      idle(startPaint);
    }

    // ============================================================
    // Lenis smooth scroll — additive
    // ============================================================
    let lenisInstance: any = null;
    (async function smoothScroll() {
      if (reduced) return;
      if (!window.matchMedia('(pointer: fine)').matches) return;
      try {
        const { default: Lenis } = await import('lenis');
        lenisInstance = new Lenis({
          duration: 1.1,
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          smoothWheel: true,
          wheelMultiplier: 1.0,
          touchMultiplier: 1.0,
        });
        function raf(time: number) { lenisInstance.raf(time); requestAnimationFrame(raf); }
        requestAnimationFrame(raf);
      } catch (err) { /* native scroll still works */ }
    })();

    // ============================================================
    // GSAP ScrollTrigger — cinematic accent only
    // ============================================================
    (async function cinematicAccents() {
      if (reduced) return;
      let gsap: any, ScrollTrigger: any;
      try {
        const gsapMod = await import('gsap');
        const stMod = await import('gsap/ScrollTrigger');
        gsap = gsapMod.gsap || gsapMod.default;
        ScrollTrigger = stMod.ScrollTrigger || stMod.default;
        gsap.registerPlugin(ScrollTrigger);
      } catch (err) { return; }

      if (lenisInstance) lenisInstance.on('scroll', ScrollTrigger.update);

      document.querySelectorAll<HTMLElement>('.v2-chapter__n').forEach((el) => {
        gsap.to(el, { y: -40, ease: 'none', scrollTrigger: { trigger: el.closest('.v2-chapter'), start: 'top bottom', end: 'bottom top', scrub: 1.2 } });
      });
      document.querySelectorAll<HTMLElement>('.v2-chapter__head').forEach((el) => {
        gsap.to(el, { y: -24, ease: 'none', scrollTrigger: { trigger: el.closest('.v2-chapter'), start: 'top 80%', end: 'bottom 20%', scrub: 1.5 } });
      });
    })();
  })();
</script>
